---
interface Props {
  scene: string;
  class?: string;
}

const { scene, class: className = '' } = Astro.props;
---

<canvas data-spline-scene={scene} class={`spline-canvas ${className}`}></canvas>

<script>
  import { Application } from '@splinetool/runtime';

  document.querySelectorAll<HTMLCanvasElement>('canvas[data-spline-scene]').forEach((canvas) => {
    const scene = canvas.dataset.splineScene;
    if (scene) {
      const app = new Application(canvas);
      app.load(scene);
    }
  });
</script>

<style>
  .spline-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
