---
import Layout from '../layouts/Layout.astro';

const contactOptions = [
	{
		title: 'LinkedIn Portal',
		label: 'connect professionally',
		href: 'https://www.linkedin.com/in/lizbeth-trujillo-salgado-099304267',
		icon: '/img/profile/linkedin-pixel.png',
		aria: 'Open LinkedIn profile',
	},
	{
		title: 'Inventory',
		label: 'view resume',
		href: '#inventory',
		icon: '/img/menu/4.png',
		aria: 'View resume inventory',
	},
	{
		title: 'Levels',
		label: 'view projects',
		href: '#levels',
		icon: '/img/menu/1.png',
		aria: 'View projects levels',
	},
];
---

<Layout>
	<main class="contact-screen" aria-labelledby="contact-title">
		<a class="back-link" href="/" aria-label="Back to Lizzy World menu">Back</a>

		<header class="contact-header">
			<img src="/img/menu/7.png" alt="" width="42" height="42" />
			<div>
				<h1 id="contact-title">Talk to NPC</h1>
				<p>You found Lizzy&apos;s contact portal</p>
			</div>
		</header>

		<section class="contact-layout" aria-label="Contact options">
			<nav class="contact-menu" aria-label="Contact menu">
				{
					contactOptions.map((option) => (
						<a class="contact-option" href={option.href} aria-label={option.aria}>
							<span class="contact-option-title">
								<img src={option.icon} alt="" width="42" height="42" loading="eager" />
								{option.title}
							</span>
							<span class="contact-button">{option.label}</span>
						</a>
					))
				}
			</nav>

			<figure class="dear-card-wrap">
				<img
					class="dear-card"
					src="/img/profile/dear-user-contact-card.png"
					alt="Pixel art Dear User contact card from Lizzy World"
				/>
			</figure>
		</section>
	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		overflow-x: hidden;
		background: #f4f4de;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.contact-screen {
		min-height: 100svh;
		padding: clamp(32px, 6vh, 64px) clamp(24px, 7vw, 92px) 64px;
		background: #f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.contact-header {
		display: flex;
		align-items: center;
		gap: 14px;
		width: min(100%, 1180px);
		margin: 0 auto;
		padding-left: clamp(70px, 8vw, 110px);
	}

	.contact-header img,
	.contact-option img,
	.dear-card {
		object-fit: contain;
		image-rendering: pixelated;
	}

	.contact-header h1 {
		margin: 0;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(2.6rem, 5vw, 4.4rem);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.contact-header p {
		margin: 6px 0 0;
		color: #7b716c;
		font-size: clamp(0.95rem, 1.2vw, 1.1rem);
	}

	.contact-layout {
		display: grid;
		grid-template-columns: minmax(290px, 0.38fr) minmax(520px, 0.62fr);
		align-items: center;
		gap: clamp(48px, 8vw, 120px);
		width: min(100%, 1180px);
		margin: clamp(58px, 11vh, 104px) auto 0;
	}

	.contact-menu {
		display: grid;
		gap: clamp(42px, 8vh, 70px);
	}

	.contact-option {
		display: grid;
		width: fit-content;
		gap: 14px;
	}

	.contact-option-title {
		display: flex;
		align-items: center;
		gap: 10px;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.8rem, 3vw, 2.35rem);
		font-weight: 800;
		line-height: 1;
	}

	.contact-option-title img {
		width: 42px;
		height: 42px;
	}

	.contact-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		min-width: 178px;
		min-height: 42px;
		margin-left: 52px;
		padding: 10px 28px;
		border-radius: 14px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		line-height: 1.2;
		text-align: center;
		transition:
			transform 170ms ease,
			background 170ms ease,
			box-shadow 170ms ease;
	}

	.contact-option:hover .contact-button,
	.contact-option:focus-visible .contact-button {
		background: #f9e4e8;
		box-shadow: 0 8px 20px rgba(244, 166, 189, 0.25);
		transform: translateY(-2px);
	}

	.contact-option:focus-visible {
		outline: 3px solid #d6c6f5;
		outline-offset: 8px;
	}

	.dear-card-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
	}

	.dear-card {
		width: min(760px, 100%);
		filter: drop-shadow(0 18px 28px rgba(233, 223, 209, 0.45));
		transition:
			transform 180ms ease,
			filter 180ms ease;
	}

	.dear-card:hover {
		filter: drop-shadow(0 22px 34px rgba(233, 223, 209, 0.55));
		transform: translateY(-3px);
	}

	@media (max-width: 860px) {
		.contact-screen {
			padding: 80px 22px 54px;
		}

		.contact-header {
			padding-left: 0;
		}

		.contact-layout {
			grid-template-columns: 1fr;
			gap: 42px;
			margin-top: 48px;
		}

		.dear-card-wrap {
			order: -1;
		}

		.contact-menu {
			justify-items: center;
			gap: 34px;
		}

		.contact-option {
			justify-items: center;
			width: 100%;
		}

		.contact-button {
			margin-left: 0;
			width: min(280px, 100%);
		}
	}

	@media (max-width: 520px) {
		.contact-header h1 {
			font-size: 2.9rem;
		}

		.contact-option-title {
			font-size: 1.85rem;
		}

		.contact-option-title img {
			width: 36px;
			height: 36px;
		}
	}
</style>
