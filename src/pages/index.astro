---
import Layout from '../layouts/Layout.astro';

const menuItems = [
	{
		title: 'Levels',
		label: 'Select Projects',
		icon: '/img/menu/1.png',
		href: '/levels',
	},
	{
		title: 'Inventory',
		label: 'Resume & Experience',
		icon: '/img/menu/4.png',
		href: '#resume',
	},
	{
		title: 'Player Profile',
		label: 'About Me',
		icon: '/img/menu/3.png',
		href: '/about',
	},
	{
		title: 'Talk to NPC',
		label: 'Contact me',
		icon: '/img/menu/7.png',
		href: '/contact',
	},
	{
		title: 'Skill Tree',
		label: 'Tools & Expertise',
		icon: '/img/menu/6.png',
		href: '#skills',
	},
	{
		title: 'Secret Lab',
		label: 'Experiment & Playground',
		icon: '/img/menu/5.png',
		href: '#lab',
	},
];
---

<Layout>
	<main class="world-screen" aria-labelledby="welcome-title">
		<section class="welcome-panel">
			<header class="intro">
				<h1 id="welcome-title">Welcome To Lizzy World</h1>
				<p>Chose what you want to explote</p>
			</header>

			<nav class="menu-grid" aria-label="Lizzy World sections">
				{
					menuItems.map((item) => (
						<a class="menu-item" href={item.href}>
							<span class="menu-title">
								<img src={item.icon} alt="" width="34" height="34" loading="eager" />
								{item.title}
							</span>
							<span class="menu-button">{item.label}</span>
						</a>
					))
				}
			</nav>
		</section>

	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		overflow-x: hidden;
		background: #ffffec;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.world-screen {
		display: grid;
		min-height: 100svh;
		background: #ffffec;
		color: #5e5858;
		font-family: 'Comfortaa', 'Comfortaa Regular', 'Trebuchet MS', sans-serif;
	}

	.welcome-panel {
		width: min(100%, 1160px);
		margin: 0 auto;
		padding: clamp(36px, 7vh, 68px) clamp(24px, 7vw, 92px) 38px;
	}

	.intro {
		margin-bottom: clamp(58px, 10vh, 84px);
	}

	h1 {
		margin: 0 0 4px;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(2rem, 4.1vw, 3.25rem);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1.05;
		text-wrap: balance;
	}

	p {
		margin: 0;
		color: #211f21;
		font-size: clamp(0.95rem, 1.45vw, 1.15rem);
		line-height: 1.5;
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(260px, 1fr));
		column-gap: clamp(80px, 24vw, 380px);
		row-gap: clamp(66px, 12vh, 92px);
	}

	.menu-item {
		display: grid;
		width: fit-content;
		min-width: 236px;
		gap: 16px;
		color: inherit;
		text-decoration: none;
	}

	.menu-title {
		display: flex;
		align-items: center;
		gap: 8px;
		min-height: 34px;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.6rem, 2.6vw, 2.2rem);
		font-weight: 800;
		line-height: 1;
	}

	.menu-title img {
		width: 34px;
		height: 34px;
		object-fit: contain;
		image-rendering: pixelated;
	}

	.menu-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		min-width: 128px;
		min-height: 36px;
		margin-left: 18px;
		padding: 0 24px;
		border-radius: 10px;
		background: #f3a4ba;
		color: #6b5260;
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.2;
		text-align: center;
		transition:
			transform 160ms ease,
			background 160ms ease,
			box-shadow 160ms ease;
	}

	.menu-item:hover .menu-button,
	.menu-item:focus-visible .menu-button {
		background: #f08eac;
		box-shadow: 0 8px 0 rgba(94, 88, 88, 0.12);
		transform: translateY(-3px);
	}

	.menu-item:focus-visible {
		outline: 3px solid #b8977a;
		outline-offset: 8px;
	}

	@media (max-width: 760px) {
		.welcome-panel {
			padding: 34px 24px 42px;
		}

		.intro {
			margin-bottom: 42px;
		}

		.menu-grid {
			grid-template-columns: 1fr;
			row-gap: 38px;
		}

		.menu-item {
			min-width: 0;
		}

		.menu-button {
			margin-left: 42px;
		}

	}
</style>
