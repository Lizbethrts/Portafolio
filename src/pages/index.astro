---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		title: 'Proyecto destacado',
		description: 'Una breve descripcion del problema, tu solucion y el impacto que lograste.',
		tags: ['Astro', 'Frontend', 'UI'],
		link: '#',
	},
	{
		title: 'Dashboard o app web',
		description: 'Resume aqui una aplicacion, experimento o caso de estudio que quieras mostrar.',
		tags: ['JavaScript', 'Datos', 'Producto'],
		link: '#',
	},
	{
		title: 'Sitio para cliente',
		description: 'Cuenta que construiste, que decisiones tomaste y que aprendiste en el proceso.',
		tags: ['Diseno', 'Performance', 'SEO'],
		link: '#',
	},
];
---

<Layout>
	<main class="site-shell">
		<nav class="nav" aria-label="Navegacion principal">
			<a class="brand" href="/">Tu Nombre</a>
			<div class="nav-links">
				<a href="#proyectos">Proyectos</a>
				<a href="#experiencia">Experiencia</a>
				<a href="#contacto">Contacto</a>
			</div>
		</nav>

		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Portafolio personal</p>
				<h1>Construyo experiencias web claras, rapidas y faciles de usar.</h1>
				<p class="intro">
					Soy Tu Nombre, desarrollador/a enfocado/a en crear interfaces modernas,
					sitios responsivos y productos digitales con buena atencion al detalle.
				</p>
				<div class="actions">
					<a class="button primary" href="#proyectos">Ver proyectos</a>
					<a class="button secondary" href="mailto:tu-correo@example.com">Contactar</a>
				</div>
			</div>
			<aside class="profile-panel" aria-label="Resumen profesional">
				<p class="panel-label">Disponible para</p>
				<h2>Frontend, sitios web y prototipos</h2>
				<p>
					Edita este bloque con tu especialidad, ciudad, tecnologias favoritas o el tipo de
					oportunidades que estas buscando.
				</p>
			</aside>
		</section>

		<section id="proyectos" class="section">
			<div class="section-heading">
				<p class="eyebrow">Trabajo reciente</p>
				<h2>Proyectos</h2>
			</div>
			<div class="project-grid">
				{
					projects.map((project) => (
						<article class="project-card">
							<div>
								<h3>{project.title}</h3>
								<p>{project.description}</p>
							</div>
							<div class="tag-row">
								{project.tags.map((tag) => (
									<span>{tag}</span>
								))}
							</div>
							<a href={project.link}>Ver detalle</a>
						</article>
					))
				}
			</div>
		</section>

		<section id="experiencia" class="section split">
			<div>
				<p class="eyebrow">Sobre mi</p>
				<h2>Una base simple para contar tu historia profesional.</h2>
			</div>
			<div class="timeline">
				<p>
					<strong>2026</strong>
					<span>Describe tu rol actual, practica profesional, servicio social o proyecto principal.</span>
				</p>
				<p>
					<strong>2025</strong>
					<span>Agrega logros, cursos, colaboraciones o aprendizajes importantes.</span>
				</p>
				<p>
					<strong>Skills</strong>
					<span>Astro, HTML, CSS, JavaScript, Git, diseno responsivo y las herramientas que uses.</span>
				</p>
			</div>
		</section>

		<section id="contacto" class="contact">
			<p class="eyebrow">Contacto</p>
			<h2>Hablemos de tu siguiente proyecto.</h2>
			<div class="contact-links">
				<a href="mailto:tu-correo@example.com">tu-correo@example.com</a>
				<a href="https://github.com/tu-usuario">GitHub</a>
				<a href="https://www.linkedin.com/in/tu-usuario">LinkedIn</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.site-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 24px 0 56px;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 16px 0 40px;
	}

	.brand {
		font-weight: 800;
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		color: #4b5870;
		font-size: 0.95rem;
	}

	.nav-links a,
	.project-card a,
	.contact-links a {
		text-decoration: none;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.55fr);
		gap: 28px;
		align-items: stretch;
		min-height: 560px;
	}

	.hero-copy,
	.profile-panel,
	.project-card,
	.contact {
		border: 1px solid #d8dee9;
		background: #ffffff;
		box-shadow: 0 22px 60px rgba(23, 32, 51, 0.08);
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: clamp(32px, 8vw, 82px);
		background:
			linear-gradient(135deg, rgba(15, 118, 110, 0.13), transparent 35%),
			linear-gradient(315deg, rgba(220, 38, 38, 0.09), transparent 34%), #ffffff;
	}

	.eyebrow,
	.panel-label {
		margin: 0 0 12px;
		color: #0f766e;
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 850px;
		margin-bottom: 22px;
		font-size: clamp(2.7rem, 6.6vw, 4.85rem);
		line-height: 1;
	}

	h2 {
		font-size: clamp(2rem, 5vw, 3.6rem);
		line-height: 1;
	}

	h3 {
		font-size: 1.35rem;
	}

	.intro {
		max-width: 680px;
		color: #4b5870;
		font-size: 1.15rem;
		line-height: 1.7;
	}

	.actions,
	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 16px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 0 18px;
		border: 1px solid #172033;
		font-weight: 800;
		text-decoration: none;
	}

	.primary {
		background: #172033;
		color: #ffffff;
	}

	.secondary {
		background: #ffffff;
	}

	.profile-panel {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 30px;
		background: #172033;
		color: #ffffff;
	}

	.profile-panel p:last-child {
		color: #cdd6e4;
		line-height: 1.65;
	}

	.section {
		padding: 86px 0 0;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 24px;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.project-card {
		display: flex;
		min-height: 300px;
		flex-direction: column;
		justify-content: space-between;
		padding: 24px;
	}

	.project-card p,
	.timeline span {
		color: #4b5870;
		line-height: 1.65;
	}

	.project-card a {
		font-weight: 800;
		color: #0f766e;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 20px 0;
	}

	.tag-row span {
		border: 1px solid #d8dee9;
		padding: 6px 10px;
		color: #4b5870;
		font-size: 0.85rem;
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1.15fr);
		gap: 40px;
	}

	.timeline {
		display: grid;
		gap: 18px;
	}

	.timeline p {
		display: grid;
		grid-template-columns: 90px 1fr;
		gap: 18px;
		margin: 0;
		border-top: 1px solid #d8dee9;
		padding-top: 18px;
	}

	.contact {
		margin-top: 86px;
		padding: clamp(28px, 7vw, 64px);
		background: #e9f7f5;
	}

	.contact h2 {
		max-width: 680px;
		margin-bottom: 0;
	}

	.contact-links a {
		border-bottom: 2px solid #172033;
		font-weight: 800;
	}

	@media (max-width: 820px) {
		.nav,
		.section-heading {
			align-items: flex-start;
			flex-direction: column;
		}

		.hero,
		.project-grid,
		.split {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
		}

		h1 {
			font-size: 3rem;
		}

		.timeline p {
			grid-template-columns: 1fr;
		}
	}
</style>
