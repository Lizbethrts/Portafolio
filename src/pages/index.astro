---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="world-screen">
		<button id="annotations-toggle" class="annotations-toggle" aria-label="Mostrar anotaciones" title="Mostrar guía">👁️</button>
		<div class="console-frame">
			<canvas id="spline-canvas"></canvas>
			<svg class="annotations" id="annotations" viewBox="0 0 100 107.5"
				xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">

				<!-- Player Class → mystery box 1 (tecla izquierda) -->
				<g class="ann">
					<path d="M19,15 C29,24 39,34 46.5,44" />
					<path d="M46.5,44 L42.6,42.4 M46.5,44 L44.9,40.1" />
					<text x="2" y="13" transform="rotate(-4,2,13)">Player Class</text>
				</g>

				<!-- Idioma → mystery box 2 (?) -->
				<g class="ann">
					<path d="M73,16 C71,27 65,38 56.1,47.2" />
					<path d="M56.1,47.2 L59.8,46 M56.1,47.2 L57.8,43.7" />
					<text x="67" y="13" transform="rotate(3,67,13)">Idioma</text>
				</g>

				<!-- Quick CV → tab del corazón (♥) -->
				<g class="ann">
					<path d="M11,40 C18,41 25,42 32,42.5" />
					<path d="M32,42.5 L27.9,43.5 M32,42.5 L28.4,40.4" />
					<text x="1" y="38" transform="rotate(-3,1,38)">Quick CV</text>
				</g>

				<!-- Click to enter! → screen (from right) -->
				<g class="ann">
					<path d="M78,46 C71,49 58,52 44,55" />
					<path d="M44,55 L47.8,54 M44,55 L45.6,51.7" />
					<text x="71" y="44" transform="rotate(3,71,44)">Click to enter!</text>
				</g>

				<!-- Navegar → botón izquierdo del D-pad -->
				<g class="ann">
					<path d="M16,95.5 C20,94.6 23,93.9 26.6,93.2" />
					<path d="M26.6,93.2 L22.6,92 M26.6,93.2 L23.2,95" />
					<text x="0" y="101" transform="rotate(-3,0,101)">Navegar</text>
				</g>

				<!-- On / Off → botón "minus" (línea horizontal) -->
				<g class="ann">
					<path d="M85,74 C82,79 70,83 47.8,85.9" />
					<path d="M47.8,85.9 L51,83.3 M47.8,85.9 L51.8,86.2" />
					<text x="78" y="71" transform="rotate(4,78,71)">On / Off</text>
				</g>

			</svg>
		</div>
	</main>
</Layout>

<script>
	import { Application } from '@splinetool/runtime';
	import * as THREE from 'three';
	import { CSS3DRenderer, CSS3DObject } from 'three/addons/renderers/CSS3DRenderer.js';

	// ── Secciones ──────────────────────────────────────────────────────────────
	const SECTIONS = [
		{ title: 'LEVELS',         label: 'Select Projects',         href: '/levels',     icon: '/img/menu/1.png' },
		{ title: 'PLAYER PROFILE', label: 'About Me',                href: '/about',      icon: '/img/menu/3.png' },
		{ title: 'INVENTORY',      label: 'Equipped Skills & Tools', href: '/inventory',  icon: '/img/menu/4.png' },
		{ title: 'SECRET LAB',     label: 'Experiment & Playground', href: '/secret-lab', icon: '/img/menu/5.png' },
		{ title: 'TALK TO NPC',    label: 'Contact Me',              href: '/contact',    icon: '/img/menu/7.png' },
	];

	// ── Traducciones de la pantalla de la consola (toggle ES/EN vía mystery box 2) ──
	const SECTIONS_ES = [
		{ title: 'NIVELES',            label: 'Selecciona Proyectos' },
		{ title: 'PERFIL DEL JUGADOR', label: 'Sobre Mí' },
		{ title: 'INVENTARIO',         label: 'Habilidades y Herramientas' },
		{ title: 'LABORATORIO SECRETO', label: 'Experimentos y Juegos' },
		{ title: 'HABLAR CON NPC',      label: 'Contáctame' },
	];
	const HINT_EN = '◀ use d-pad ▶';
	const HINT_ES = '◀ usa el d-pad ▶';

	let currentIndex = 0;
	let consoleOn = true;
	let lang: 'en' | 'es' = 'en';
	let panelMode: 'menu' | 'class' = 'menu';

	const canvas = document.getElementById('spline-canvas') as HTMLCanvasElement;
	const consoleFrame = document.querySelector('.console-frame') as HTMLElement;

	// ── Elemento HTML que se "monta" sobre la pantalla 3D vía CSS3DRenderer ─────
	const menuEl = document.createElement('div');
	menuEl.className = 'menu-3d';
	menuEl.setAttribute('role', 'button');
	menuEl.setAttribute('tabindex', '0');
	menuEl.setAttribute('aria-label', 'Abrir sección');
	menuEl.innerHTML = `
		<img class="menu-icon" alt="" />
		<div class="menu-text">
			<p class="menu-title"></p>
			<p class="menu-label"></p>
			<p class="menu-hint"></p>
		</div>
		<div class="class-panel">
			<p class="class-kicker">PLAYER CLASS</p>
			<ul class="class-list">
				<li><span class="class-label">Class</span><span class="class-value">UX/UI Designer</span></li>
				<li><span class="class-label">Special skill</span><span class="class-value">UX + Code</span></li>
				<li><span class="class-label">Current mode</span><span class="class-value">Creative</span></li>
			</ul>
		</div>
		<div class="menu-off"></div>
	`;
	const menuIcon   = menuEl.querySelector('.menu-icon') as HTMLImageElement;
	const menuTitle  = menuEl.querySelector('.menu-title') as HTMLElement;
	const menuLabel  = menuEl.querySelector('.menu-label') as HTMLElement;
	const menuHint   = menuEl.querySelector('.menu-hint') as HTMLElement;

	function updateMenuContent() {
		if (panelMode === 'class') return;
		const s = SECTIONS[currentIndex];
		const sEs = SECTIONS_ES[currentIndex];
		menuIcon.src = s.icon;
		menuTitle.textContent = lang === 'es' ? sEs.title : s.title;
		menuLabel.textContent = lang === 'es' ? sEs.label : s.label;
		menuHint.textContent = lang === 'es' ? HINT_ES : HINT_EN;
	}
	updateMenuContent();

	function goToCurrentSection() {
		if (!consoleOn || panelMode === 'class') return;
		window.location.href = SECTIONS[currentIndex].href;
	}
	menuEl.addEventListener('click', goToCurrentSection);
	menuEl.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' || e.key === ' ') {
			e.preventDefault();
			goToCurrentSection();
		}
	});

	function showSection(index: number) {
		currentIndex = (index + SECTIONS.length) % SECTIONS.length;
		updateMenuContent();
	}

	// ── CSS3DRenderer: monta el div como un objeto 3D real dentro de la escena ──
	const cssScene = new THREE.Scene();
	const cssObject = new CSS3DObject(menuEl);
	cssScene.add(cssObject);

	const cssRenderer = new CSS3DRenderer();
	cssRenderer.domElement.style.position = 'absolute';
	cssRenderer.domElement.style.inset = '0';
	cssRenderer.domElement.style.pointerEvents = 'none';
	consoleFrame.appendChild(cssRenderer.domElement);

	function resizeCssRenderer() {
		cssRenderer.setSize(canvas.clientWidth, canvas.clientHeight);
	}
	resizeCssRenderer();
	window.addEventListener('resize', resizeCssRenderer);

	// ── Iniciar Spline ─────────────────────────────────────────────────────────
	const app = new Application(canvas);
	(window as any).__splineApp = app;
	await app.load('https://prod.spline.design/DFYUH0FqBWoYc67j/scene.splinecode');

	const camera = (app as any)._camera;

	// Ajuste único de zoom para que la consola completa (incluido el dial inferior) sea visible
	if (camera) {
		camera.zoom = 0.73;
		camera.updateProjectionMatrix();
	}

	// Rotar para quedar de frente
	const gameObj = app.findObjectByName('Game');
	if (gameObj) gameObj.rotation.y = 0;

	// ── Acceder a la escena Three.js ─────────────────────────────────────────
	const rawScene = (app as any)._scene;

	// ── Helper: forzar invisibilidad permanente (Spline restaura .visible cada frame) ──
	function forceHide(obj: any) {
		try {
			Object.defineProperty(obj, 'visible', {
				get() { return false; },
				set(_v: any) {},
				configurable: true
			});
		} catch (_e) {}
	}

	// ── Ocultar grupos de juego que muestran imágenes ajenas (mantiene visibles los botones D-pad) ──
	let gameGroup: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'Game' && o.type === 'Group' && !gameGroup) gameGroup = o;
	});

	const hideByName = [
		'Group',          // crew, crew 2, crew 1 (Pixel Starships characters)
		'Buttons below screen',
		'Slide button',
		'Button edge',
		'Link',
		'contra',
		'mushroom',
		'Rectangle',      // card de juego en Game group
	];

	if (gameGroup) {
		gameGroup.children.forEach((c: any) => {
			if (hideByName.includes(c.name)) {
				forceHide(c);
				c.traverse((o: any) => forceHide(o));
			}
		});
	}

	// ── Ocultar la pantalla del juego (carrusel animado) y preparar el plano CSS3D ──
	let screenMesh: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'SCREEN inner' && !screenMesh) screenMesh = o;
	});

	let centerX = 0, centerY = 0, frontZ = 0;
	if (screenMesh) {
		forceHide(screenMesh);
		screenMesh.geometry.computeBoundingBox();
		const box = screenMesh.geometry.boundingBox;

		const planeWidth = box.max.x - box.min.x;
		const planeHeight = box.max.y - box.min.y;
		centerX = (box.max.x + box.min.x) / 2;
		centerY = (box.max.y + box.min.y) / 2;
		frontZ = box.max.z + 2;

		menuEl.style.width = `${planeWidth}px`;
		menuEl.style.height = `${planeHeight}px`;
	}

	// ── RAF loop: mantener la consola de frente y alinear el panel CSS3D con la pantalla ──
	const worldMatrix = new THREE.Matrix4();
	const cssPosition = new THREE.Vector3();
	const cssQuaternion = new THREE.Quaternion();
	const cssScale = new THREE.Vector3();

	function syncFrame() {
		if (gameObj) gameObj.rotation.y = 0;

		if (screenMesh && camera) {
			screenMesh.updateWorldMatrix(true, false);
			camera.updateMatrixWorld(true);

			worldMatrix.fromArray(screenMesh.matrixWorld.elements);
			worldMatrix.decompose(cssPosition, cssQuaternion, cssScale);

			cssObject.position.copy(
				new THREE.Vector3(centerX, centerY, frontZ).applyMatrix4(worldMatrix)
			);
			cssObject.quaternion.copy(cssQuaternion);
			cssObject.scale.copy(cssScale);

			cssScene.updateMatrixWorld(true);
			cssRenderer.render(cssScene, camera);
		}

		requestAnimationFrame(syncFrame);
	}
	syncFrame();

	// ── D-pad: raycasting propio sobre los botones (Spline no emite eventos para ellos) ──
	const dpadButtons: { mesh: any; dir: 'next' | 'prev' }[] = [];
	let dialGrip: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'Small button Instance' || o.name === 'Small button Instance 5') {
			const cylinder = o.children.find((c: any) => c.name === 'Cylinder');
			if (!cylinder) return;
			const { x, y } = o.position;
			const dir: 'next' | 'prev' = (Math.abs(x) > Math.abs(y) ? x > 0 : y < 0) ? 'next' : 'prev';
			dpadButtons.push({ mesh: cylinder, dir });
		}
		if (o.name === 'Dial Grip' && !dialGrip) dialGrip = o;
	});

	// ── Dial de poder: gira la pieza "Dial Grip" entre las posiciones ON/OFF ──
	const DIAL_ON_X = -Math.PI / 2;
	const DIAL_OFF_X = 0;
	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function rotateDialGrip(on: boolean) {
		if (!dialGrip) return;
		const from = dialGrip.rotation.x;
		const to = on ? DIAL_ON_X : DIAL_OFF_X;

		if (reduceMotion) {
			dialGrip.rotation.x = to;
			return;
		}

		const duration = 200;
		const start = performance.now();
		function step(now: number) {
			const t = Math.min((now - start) / duration, 1);
			dialGrip.rotation.x = from + (to - from) * t;
			if (t < 1) requestAnimationFrame(step);
		}
		requestAnimationFrame(step);
	}

	function setConsoleOn(on: boolean) {
		consoleOn = on;
		menuEl.classList.toggle('menu-3d--off', !consoleOn);
		rotateDialGrip(consoleOn);
	}

	const raycaster = new THREE.Raycaster();
	const pointerNDC = new THREE.Vector2();

	canvas.addEventListener('click', (e: MouseEvent) => {
		if (!consoleOn || panelMode === 'class') return;

		const rect = canvas.getBoundingClientRect();
		pointerNDC.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
		pointerNDC.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

		raycaster.setFromCamera(pointerNDC, camera);
		const hits = raycaster.intersectObjects(dpadButtons.map((b) => b.mesh), true);
		if (hits.length === 0) return;

		const btn = dpadButtons.find((b) => b.mesh === hits[0].object);
		if (!btn) return;

		showSection(btn.dir === 'next' ? currentIndex + 1 : currentIndex - 1);
	});

	// Auto-hide annotations after 10s; eye button to restore
	const annotationsSvg = document.getElementById('annotations');
	const toggleBtn      = document.getElementById('annotations-toggle');
	setTimeout(() => {
		annotationsSvg?.classList.add('annotations--hidden');
	}, 10000);
	toggleBtn?.addEventListener('click', () => {
		annotationsSvg?.classList.toggle('annotations--hidden');
	});

	// ── Botones de la consola con interacción "On Mouse Down" configurada en Spline ──
	app.addEventListener('mouseDown', (e: any) => {
		const name = e?.target?.name ?? '';

		switch (name) {
			case 'SMILE BUTTON':
			case 'Power button':
				setConsoleOn(!consoleOn);
				break;

			case 'CARD': {
				const a = document.createElement('a');
				a.href = '/resume.pdf';
				a.download = 'Lizbeth-Trujillo-CV.pdf';
				document.body.appendChild(a);
				a.click();
				a.remove();
				break;
			}

			case 'mystery box 1':
				if (!consoleOn) break;
				panelMode = panelMode === 'class' ? 'menu' : 'class';
				menuEl.classList.toggle('menu-3d--class', panelMode === 'class');
				updateMenuContent();
				break;

			case 'mystery box 2':
				if (!consoleOn) break;
				lang = lang === 'en' ? 'es' : 'en';
				updateMenuContent();
				break;
		}
	});
</script>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	*, *::before, *::after { box-sizing: border-box; }

	html, body {
		margin: 0; padding: 0;
		width: 100%; height: 100%;
		overflow-x: hidden;
		overflow-y: auto;
		background: #ffeeee;
	}

	.world-screen {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100svh;
		padding-top: clamp(4px, 0.5vh, 12px);
		padding-bottom: clamp(48px, 8vh, 80px);
		padding-left: clamp(16px, 4vw, 48px);
		padding-right: clamp(16px, 4vw, 48px);
		overflow: visible;
	}

	.console-frame {
		position: relative;
		width: min(92vw, calc((100svh - clamp(4px, 0.5vh, 12px) - clamp(48px, 8vh, 80px)) * 0.93));
		aspect-ratio: 0.93;
	}

	#spline-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	.menu-3d {
		position: relative;
		display: flex;
		align-items: center;
		gap: 24px;
		padding: 28px 32px;
		background: linear-gradient(to bottom, rgba(40, 15, 80, 0.95), rgba(10, 6, 20, 1));
		border-top: 4px solid #f3a4ba;
		border-bottom: 4px solid #f3a4ba;
		font-family: 'Comfortaa', sans-serif;
		color: #b8e0ff;
		overflow: hidden;
		cursor: pointer;
		transition: opacity 180ms ease;
	}

	.menu-3d:focus-visible {
		outline: 3px solid #f0e68c;
		outline-offset: -6px;
	}

	.menu-icon {
		width: 96px;
		height: 96px;
		object-fit: contain;
		image-rendering: pixelated;
		flex-shrink: 0;
	}

	.menu-text {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 0;
	}

	.menu-title {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 30px;
		color: #f0e68c;
		margin: 0;
		line-height: 1.15;
		letter-spacing: 1px;
	}

	.menu-label {
		font-size: 16px;
		margin: 0;
	}

	.menu-hint {
		font-size: 14px;
		margin: 6px 0 0;
		color: #f3a4ba;
		font-weight: 700;
		font-family: monospace;
	}

	/* ── Tarjeta de clase de personaje (mystery box 1) ──────────────────────── */
	.class-panel {
		display: none;
		flex-direction: column;
		gap: 14px;
	}

	.menu-3d--class .class-panel {
		display: flex;
	}

	.menu-3d--class .menu-icon,
	.menu-3d--class .menu-text {
		display: none;
	}

	.class-kicker {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 18px;
		color: #f3a4ba;
		margin: 0;
		letter-spacing: 2px;
	}

	.class-list {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.class-list li {
		display: flex;
		gap: 10px;
		align-items: baseline;
	}

	.class-label {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 14px;
		color: #b8e0ff;
		letter-spacing: 1px;
	}

	.class-value {
		font-size: 16px;
		color: #f0e68c;
		font-weight: 600;
	}

	/* ── Anotaciones tipo boceto ─────────────────────────────────────────────── */
	.annotations {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		overflow: visible;
		animation: ann-fadein 0.9s ease 1.2s both;
	}

	@keyframes ann-fadein {
		from { opacity: 0; transform: translateY(5px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	.ann path {
		fill: none;
		stroke: rgba(30, 8, 28, 0.72);
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.ann text {
		font-family: 'Caveat', cursive;
		font-weight: 700;
		font-size: 6.8px;
		fill: rgba(30, 8, 28, 0.80);
	}

	.annotations--hidden {
		opacity: 0 !important;
		transition: opacity 600ms ease;
	}

	.annotations-toggle {
		position: fixed;
		top: 14px;
		right: 18px;
		z-index: 20;
		background: rgba(255, 238, 238, 0.75);
		border: 1.5px solid rgba(30, 8, 28, 0.18);
		border-radius: 50%;
		width: 38px;
		height: 38px;
		font-size: 18px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		backdrop-filter: blur(6px);
		transition: opacity 200ms ease;
		opacity: 0.45;
	}
	.annotations-toggle:hover { opacity: 1; }

	/* ── Consola apagada (SMILE BUTTON / Power button) ──────────────────────── */
	.menu-off {
		display: none;
		position: absolute;
		inset: 0;
		background: #171321;
		box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.45);
		transition: background 220ms ease, opacity 180ms ease, box-shadow 220ms ease;
	}

	.menu-3d--off {
		cursor: default;
	}

	.menu-3d--off .menu-icon,
	.menu-3d--off .menu-text,
	.menu-3d--off .class-panel {
		display: none;
	}

	.menu-3d--off .menu-off {
		display: block;
	}
</style>
