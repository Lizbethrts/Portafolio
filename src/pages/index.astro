---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="world-screen">
		<button id="annotations-toggle" class="annotations-toggle" aria-label="Mostrar anotaciones" title="Mostrar guía">👁️</button>
		<div class="console-frame">
			<canvas id="spline-canvas"></canvas>
			<svg class="annotations" id="annotations" viewBox="0 0 100 107.5"
				xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">

				<!-- Player Class → mystery box 1 (tecla izquierda) -->
				<g class="ann">
					<path d="M19,15 C29,24 39,34 46.5,44" />
					<path d="M46.5,44 L42.6,42.4 M46.5,44 L44.9,40.1" />
					<text x="2" y="13" transform="rotate(-4,2,13)">Player Class</text>
				</g>

				<!-- Idioma → mystery box 2 (?) -->
				<g class="ann">
					<path d="M73,16 C71,27 65,38 56.1,47.2" />
					<path d="M56.1,47.2 L59.8,46 M56.1,47.2 L57.8,43.7" />
					<text x="67" y="13" transform="rotate(3,67,13)">Idioma</text>
				</g>

				<!-- Quick CV → tab del corazón (♥) -->
				<g class="ann">
					<path d="M11,40 C18,41 25,42 32,42.5" />
					<path d="M32,42.5 L27.9,43.5 M32,42.5 L28.4,40.4" />
					<text x="1" y="38" transform="rotate(-3,1,38)">Quick CV</text>
				</g>

				<!-- Click to enter! → screen (from right) -->
				<g class="ann">
					<path d="M78,46 C71,49 58,52 44,55" />
					<path d="M44,55 L47.8,54 M44,55 L45.6,51.7" />
					<text x="71" y="44" transform="rotate(3,71,44)">Click to enter!</text>
				</g>

				<!-- Navegar → botón izquierdo del D-pad -->
				<g class="ann">
					<path d="M16,95.5 C20,94.6 23,93.9 26.6,93.2" />
					<path d="M26.6,93.2 L22.6,92 M26.6,93.2 L23.2,95" />
					<text x="0" y="101" transform="rotate(-3,0,101)">Navegar</text>
				</g>

				<!-- On / Off → botón "minus" (línea horizontal) -->
				<g class="ann">
					<path d="M85,74 C82,79 70,83 47.8,85.9" />
					<path d="M47.8,85.9 L51,83.3 M47.8,85.9 L51.8,86.2" />
					<text x="78" y="71" transform="rotate(4,78,71)">On / Off</text>
				</g>

			</svg>

			<!-- Contenedor donde se renderiza la view del portafolio dentro de la pantalla -->
			<div class="screen-view" id="screen-view" aria-hidden="true">
				<iframe id="screen-iframe" title="Contenido de la sección"></iframe>
			</div>
		</div>

		<button id="screen-back" class="screen-back" hidden aria-label="Volver al menú de la consola">← Volver</button>
	</main>
</Layout>

<script>
	import { Application } from '@splinetool/runtime';
	import * as THREE from 'three';
	import { CSS3DRenderer, CSS3DObject } from 'three/addons/renderers/CSS3DRenderer.js';

	// ── Secciones ──────────────────────────────────────────────────────────────
	const SECTIONS = [
		{ title: 'LEVELS',         label: 'Select Projects',         href: '/levels',     icon: '/img/menu/1.png' },
		{ title: 'PLAYER PROFILE', label: 'About Me',                href: '/about',      icon: '/img/menu/3.png' },
		{ title: 'INVENTORY',      label: 'Equipped Skills & Tools', href: '/inventory',  icon: '/img/menu/4.png' },
		{ title: 'SECRET LAB',     label: 'Experiment & Playground', href: '/secret-lab', icon: '/img/menu/5.png' },
		{ title: 'TALK TO NPC',    label: 'Contact Me',              href: '/contact',    icon: '/img/menu/7.png' },
	];

	// ── Traducciones de la pantalla de la consola (toggle ES/EN vía mystery box 2) ──
	const SECTIONS_ES = [
		{ title: 'NIVELES',            label: 'Selecciona Proyectos' },
		{ title: 'PERFIL DEL JUGADOR', label: 'Sobre Mí' },
		{ title: 'INVENTARIO',         label: 'Habilidades y Herramientas' },
		{ title: 'LABORATORIO SECRETO', label: 'Experimentos y Juegos' },
		{ title: 'HABLAR CON NPC',      label: 'Contáctame' },
	];
	const HINT_EN = '◀ use d-pad ▶';
	const HINT_ES = '◀ usa el d-pad ▶';

	let currentIndex = 0;
	let consoleOn = true;
	let lang: 'en' | 'es' = (localStorage.getItem('lizzy-lang') as 'en' | 'es') || 'en';
	let panelMode: 'menu' | 'class' = 'menu';
	let viewActive = false;   // true cuando una view está abierta dentro de la pantalla
	let animating = false;    // true mientras corre la animación de zoom (entrar/salir)

	const canvas = document.getElementById('spline-canvas') as HTMLCanvasElement;
	const consoleFrame = document.querySelector('.console-frame') as HTMLElement;
	const screenView   = document.getElementById('screen-view') as HTMLElement;
	const screenIframe = document.getElementById('screen-iframe') as HTMLIFrameElement;
	const screenBack   = document.getElementById('screen-back') as HTMLButtonElement;

	// ── Elemento HTML que se "monta" sobre la pantalla 3D vía CSS3DRenderer ─────
	const menuEl = document.createElement('div');
	menuEl.className = 'menu-3d';
	menuEl.setAttribute('role', 'button');
	menuEl.setAttribute('tabindex', '0');
	menuEl.setAttribute('aria-label', 'Abrir sección');
	menuEl.innerHTML = `
		<img class="menu-icon" alt="" />
		<div class="menu-text">
			<p class="menu-title"></p>
			<p class="menu-label"></p>
			<p class="menu-hint"></p>
		</div>
		<div class="class-panel">
			<p class="class-kicker">PLAYER CLASS</p>
			<ul class="class-list">
				<li><span class="class-label">Class</span><span class="class-value">UX/UI Designer</span></li>
				<li><span class="class-label">Special skill</span><span class="class-value">UX + Code</span></li>
				<li><span class="class-label">Current mode</span><span class="class-value">Creative</span></li>
			</ul>
		</div>
		<div class="menu-off"></div>
	`;
	const menuIcon   = menuEl.querySelector('.menu-icon') as HTMLImageElement;
	const menuTitle  = menuEl.querySelector('.menu-title') as HTMLElement;
	const menuLabel  = menuEl.querySelector('.menu-label') as HTMLElement;
	const menuHint   = menuEl.querySelector('.menu-hint') as HTMLElement;

	const CLASS_PANEL = {
		en: { kicker: 'PLAYER CLASS', class: 'Class', classVal: 'UX/UI Designer', skill: 'Special skill', skillVal: 'UX + Code', mode: 'Current mode', modeVal: 'Creative' },
		es: { kicker: 'CLASE DEL JUGADOR', class: 'Clase', classVal: 'Diseñadora UX/UI', skill: 'Habilidad especial', skillVal: 'UX + Código', mode: 'Modo actual', modeVal: 'Creativo' },
	};

	function updateClassPanel() {
		const p = CLASS_PANEL[lang];
		const kicker = menuEl.querySelector('.class-kicker') as HTMLElement;
		const items  = menuEl.querySelectorAll('.class-list li');
		if (kicker) kicker.textContent = p.kicker;
		if (items[0]) {
			(items[0].querySelector('.class-label') as HTMLElement).textContent = p.class;
			(items[0].querySelector('.class-value') as HTMLElement).textContent = p.classVal;
		}
		if (items[1]) {
			(items[1].querySelector('.class-label') as HTMLElement).textContent = p.skill;
			(items[1].querySelector('.class-value') as HTMLElement).textContent = p.skillVal;
		}
		if (items[2]) {
			(items[2].querySelector('.class-label') as HTMLElement).textContent = p.mode;
			(items[2].querySelector('.class-value') as HTMLElement).textContent = p.modeVal;
		}
	}

	function updateMenuContent() {
		if (panelMode === 'class') return;
		const s = SECTIONS[currentIndex];
		const sEs = SECTIONS_ES[currentIndex];
		menuIcon.src = s.icon;
		menuTitle.textContent = lang === 'es' ? sEs.title : s.title;
		menuLabel.textContent = lang === 'es' ? sEs.label : s.label;
		menuHint.textContent = lang === 'es' ? HINT_ES : HINT_EN;
	}
	updateMenuContent();

	// Abre la sección actual DENTRO de la pantalla de la consola (zoom + iframe).
	// Se reasigna tras cargar Spline; fallback (pre-carga): navega directo.
	let openCurrentView: () => void = () => { window.location.href = SECTIONS[currentIndex].href; };

	function goToCurrentSection() {
		if (!consoleOn || panelMode === 'class') return;
		openCurrentView();
	}
	menuEl.addEventListener('click', goToCurrentSection);
	menuEl.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' || e.key === ' ') {
			e.preventDefault();
			goToCurrentSection();
		}
	});

	function showSection(index: number) {
		currentIndex = (index + SECTIONS.length) % SECTIONS.length;
		updateMenuContent();
	}

	// ── CSS3DRenderer: monta el div como un objeto 3D real dentro de la escena ──
	const cssScene = new THREE.Scene();
	const cssObject = new CSS3DObject(menuEl);
	cssScene.add(cssObject);

	const cssRenderer = new CSS3DRenderer();
	cssRenderer.domElement.style.position = 'absolute';
	cssRenderer.domElement.style.inset = '0';
	cssRenderer.domElement.style.pointerEvents = 'none';
	consoleFrame.appendChild(cssRenderer.domElement);

	function resizeCssRenderer() {
		cssRenderer.setSize(canvas.clientWidth, canvas.clientHeight);
	}
	resizeCssRenderer();
	window.addEventListener('resize', resizeCssRenderer);

	// ── Iniciar Spline ─────────────────────────────────────────────────────────
	const app = new Application(canvas);
	(window as any).__splineApp = app;
	await app.load('https://prod.spline.design/DFYUH0FqBWoYc67j/scene.splinecode');

	const camera = (app as any)._camera;

	// Ajuste único de zoom para que la consola completa (incluido el dial inferior) sea visible
	if (camera) {
		camera.zoom = 0.73;
		camera.updateProjectionMatrix();
	}

	// Rotar para quedar de frente
	const gameObj = app.findObjectByName('Game');
	if (gameObj) gameObj.rotation.y = 0;

	// ── Acceder a la escena Three.js ─────────────────────────────────────────
	const rawScene = (app as any)._scene;

	// ── Helper: forzar invisibilidad permanente (Spline restaura .visible cada frame) ──
	function forceHide(obj: any) {
		try {
			Object.defineProperty(obj, 'visible', {
				get() { return false; },
				set(_v: any) {},
				configurable: true
			});
		} catch (_e) {}
	}

	// ── Ocultar grupos de juego que muestran imágenes ajenas (mantiene visibles los botones D-pad) ──
	let gameGroup: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'Game' && o.type === 'Group' && !gameGroup) gameGroup = o;
	});

	const hideByName = [
		'Group',          // crew, crew 2, crew 1 (Pixel Starships characters)
		'Buttons below screen',
		'Slide button',
		'Button edge',
		'Link',
		'contra',
		'mushroom',
		'Rectangle',      // card de juego en Game group
	];

	if (gameGroup) {
		gameGroup.children.forEach((c: any) => {
			if (hideByName.includes(c.name)) {
				forceHide(c);
				c.traverse((o: any) => forceHide(o));
			}
		});
	}

	// ── Ocultar la pantalla del juego (carrusel animado) y preparar el plano CSS3D ──
	let screenMesh: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'SCREEN inner' && !screenMesh) screenMesh = o;
	});

	let centerX = 0, centerY = 0, frontZ = 0;
	if (screenMesh) {
		forceHide(screenMesh);
		screenMesh.geometry.computeBoundingBox();
		const box = screenMesh.geometry.boundingBox;

		const planeWidth = box.max.x - box.min.x;
		const planeHeight = box.max.y - box.min.y;
		centerX = (box.max.x + box.min.x) / 2;
		centerY = (box.max.y + box.min.y) / 2;
		frontZ = box.max.z + 2;

		menuEl.style.width = `${planeWidth}px`;
		menuEl.style.height = `${planeHeight}px`;
	}

	// ── RAF loop: mantener la consola de frente y alinear el panel CSS3D con la pantalla ──
	const worldMatrix = new THREE.Matrix4();
	const cssPosition = new THREE.Vector3();
	const cssQuaternion = new THREE.Quaternion();
	const cssScale = new THREE.Vector3();

	function syncFrame() {
		if (gameObj) gameObj.rotation.y = 0;

		// Mantener el encuadre de la view contra el re-ajuste de cámara de Spline
		if (viewActive && !animating) applyFit(1);

		if (screenMesh && camera) {
			screenMesh.updateWorldMatrix(true, false);
			camera.updateMatrixWorld(true);

			worldMatrix.fromArray(screenMesh.matrixWorld.elements);
			worldMatrix.decompose(cssPosition, cssQuaternion, cssScale);

			cssObject.position.copy(
				new THREE.Vector3(centerX, centerY, frontZ).applyMatrix4(worldMatrix)
			);
			cssObject.quaternion.copy(cssQuaternion);
			cssObject.scale.copy(cssScale);

			cssScene.updateMatrixWorld(true);
			cssRenderer.render(cssScene, camera);
		}

		requestAnimationFrame(syncFrame);
	}
	syncFrame();

	// ── D-pad: raycasting propio sobre los botones (Spline no emite eventos para ellos) ──
	const dpadButtons: { mesh: any; dir: 'next' | 'prev' }[] = [];
	let dialGrip: any = null;
	rawScene.traverse((o: any) => {
		if (o.name === 'Small button Instance' || o.name === 'Small button Instance 5') {
			const cylinder = o.children.find((c: any) => c.name === 'Cylinder');
			if (!cylinder) return;
			const { x, y } = o.position;
			const dir: 'next' | 'prev' = (Math.abs(x) > Math.abs(y) ? x > 0 : y < 0) ? 'next' : 'prev';
			dpadButtons.push({ mesh: cylinder, dir });
		}
		if (o.name === 'Dial Grip' && !dialGrip) dialGrip = o;
	});

	// ── Dial de poder: gira la pieza "Dial Grip" entre las posiciones ON/OFF ──
	const DIAL_ON_X = -Math.PI / 2;
	const DIAL_OFF_X = 0;
	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function rotateDialGrip(on: boolean) {
		if (!dialGrip) return;
		const from = dialGrip.rotation.x;
		const to = on ? DIAL_ON_X : DIAL_OFF_X;

		if (reduceMotion) {
			dialGrip.rotation.x = to;
			return;
		}

		const duration = 200;
		const start = performance.now();
		function step(now: number) {
			const t = Math.min((now - start) / duration, 1);
			dialGrip.rotation.x = from + (to - from) * t;
			if (t < 1) requestAnimationFrame(step);
		}
		requestAnimationFrame(step);
	}

	function setConsoleOn(on: boolean) {
		consoleOn = on;
		menuEl.classList.toggle('menu-3d--off', !consoleOn);
		rotateDialGrip(consoleOn);
	}

	// ── Vista dentro de la pantalla: zoom de cámara hasta que el screen ocupa la
	//    medida objetivo (≤90vh, ≤92vw) y se monta un iframe alineado a la pantalla ──
	let fit: {
		baseZoom: number; targetZoom: number; screenWorld: any;
		ndc0x: number; ndc0y: number; pxPerZoomH: number; pxPerZoomW: number;
	} | null = null;
	const _right = new THREE.Vector3();
	const _up    = new THREE.Vector3();
	const _proj  = new THREE.Vector3();

	function computeFit() {
		camera.updateMatrixWorld(true);
		screenMesh.updateWorldMatrix(true, false);
		const baseZoom = camera.zoom;
		const screenWorld = new THREE.Vector3(centerX, centerY, frontZ).applyMatrix4(screenMesh.matrixWorld);
		const ndc0 = screenWorld.clone().project(camera);      // posición del screen en reposo (descentrado)
		const r = menuEl.getBoundingClientRect();              // tamaño del screen en zoom base
		fit = {
			baseZoom, targetZoom: 0, screenWorld, ndc0x: ndc0.x, ndc0y: ndc0.y,
			pxPerZoomH: r.height / baseZoom, pxPerZoomW: r.width / baseZoom,
		};
		recomputeTargetZoom();
	}
	function recomputeTargetZoom() {
		if (!fit) return;
		// La pantalla domina el viewport pero dejando ver el bisel/borde del modelo alrededor.
		const zH = (0.80 * window.innerHeight) / fit.pxPerZoomH;
		const zW = (0.80 * window.innerWidth)  / fit.pxPerZoomW;
		fit.targetZoom = Math.min(zH, zW);
	}
	// Centrado en lazo cerrado: en vez de fijar la posición analíticamente (Spline la
	// re-ajusta cada frame), medimos dónde cae el centro del screen y corregimos. k: 0=base, 1=centrado.
	function applyFit(k: number) {
		if (!fit) return;
		camera.zoom = fit.baseZoom + (fit.targetZoom - fit.baseZoom) * k;
		camera.updateProjectionMatrix();
		camera.updateMatrixWorld(true);
		_proj.copy(fit.screenWorld).project(camera);
		const e = camera.matrixWorld.elements;
		_right.set(e[0], e[1], e[2]);
		_up.set(e[4], e[5], e[6]);
		const halfW = camera.right / camera.zoom;
		const halfH = camera.top   / camera.zoom;
		const tx = fit.ndc0x * (1 - k);                       // NDC objetivo del screen este frame
		const ty = fit.ndc0y * (1 - k);
		camera.position
			.addScaledVector(_right, (_proj.x - tx) * halfW)
			.addScaledVector(_up,    (_proj.y - ty) * halfH);
		camera.updateProjectionMatrix();
	}
	function runZoom(target: 0 | 1, onDone?: () => void) {
		if (reduceMotion) { applyFit(target); onDone && onDone(); return; }
		animating = true;
		const from = target === 1 ? 0 : 1;
		const t0   = performance.now();
		// easeInOutSine: soft start and end, feels more natural than cubic
		const ease = (t: number) => -(Math.cos(Math.PI * t) - 1) / 2;
		const step = (now: number) => {
			const p = Math.min((now - t0) / 950, 1);
			applyFit(from + (target - from) * ease(p));
			if (p < 1) requestAnimationFrame(step);
			else { animating = false; onDone && onDone(); }
		};
		requestAnimationFrame(step);
	}

	// Alinea el iframe (overlay fijo en viewport) para que llene el cristal de la pantalla;
	// el inset mínimo evita derramarse sobre el bisel del modelo, que queda como borde.
	function syncViewRect() {
		const r = menuEl.getBoundingClientRect();
		const inset = r.width * 0.008;
		screenView.style.left   = (r.left + inset) + 'px';
		screenView.style.top    = (r.top  + inset) + 'px';
		screenView.style.width  = (r.width  - inset * 2) + 'px';
		screenView.style.height = (r.height - inset * 2) + 'px';
	}

	function openView() {
		if (animating || viewActive || !consoleOn || panelMode === 'class') return;
		if (!camera || !screenMesh) { window.location.href = SECTIONS[currentIndex].href; return; }
		try {
			computeFit();
			const href = SECTIONS[currentIndex].href;
			screenIframe.src = href + (href.includes('?') ? '&' : '?') + 'embed=1';
			screenView.style.left = '0';
			screenView.style.top = '0';
			screenView.style.width = '100vw';
			screenView.style.height = '100svh';
			screenView.style.borderRadius = '0';
			screenView.classList.add('is-active');
			screenView.setAttribute('aria-hidden', 'false');
			screenBack.hidden = false;
			if (toggleBtn) toggleBtn.hidden = true;
			runZoom(1, () => { viewActive = true; });
		} catch (_err) {
			window.location.href = SECTIONS[currentIndex].href;
		}
	}
	function closeView() {
		if (animating || !viewActive) return;
		viewActive = false;
		screenView.classList.remove('is-active');
		screenView.setAttribute('aria-hidden', 'true');
		screenBack.hidden = true;
		if (toggleBtn) toggleBtn.hidden = false;
		runZoom(0, () => {
			fit = null;
			screenIframe.src = 'about:blank';
			screenView.style.cssText = '';
		});
	}

	openCurrentView = openView;
	screenBack.addEventListener('click', closeView);
	window.addEventListener('message', (e) => {
		if (e.data === 'console:back') {
			closeView();
		} else if (typeof e.data === 'string' && e.data.startsWith('console:navigate:')) {
			const href = e.data.slice('console:navigate:'.length);
			const idx = SECTIONS.findIndex(s => s.href === href);
			if (idx !== -1 && viewActive && !animating) {
				currentIndex = idx;
				updateMenuContent();
				const fullHref = SECTIONS[idx].href;
				// Soft fade: hide current page, swap src, fade new page in
				screenIframe.style.transition = 'opacity 180ms ease';
				screenIframe.style.opacity = '0';
				setTimeout(() => {
					screenIframe.src = fullHref + (fullHref.includes('?') ? '&' : '?') + 'embed=1';
					screenIframe.addEventListener('load', () => {
						screenIframe.style.opacity = '1';
					}, { once: true });
				}, 180);
			}
		}
	});
	window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeView(); });
	window.addEventListener('resize', () => { if (viewActive) { recomputeTargetZoom(); applyFit(1); } });

	const raycaster = new THREE.Raycaster();
	const pointerNDC = new THREE.Vector2();

	canvas.addEventListener('click', (e: MouseEvent) => {
		if (animating || viewActive || !consoleOn || panelMode === 'class') return;

		const rect = canvas.getBoundingClientRect();
		pointerNDC.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
		pointerNDC.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

		raycaster.setFromCamera(pointerNDC, camera);
		const hits = raycaster.intersectObjects(dpadButtons.map((b) => b.mesh), true);
		if (hits.length === 0) return;

		const btn = dpadButtons.find((b) => b.mesh === hits[0].object);
		if (!btn) return;

		showSection(btn.dir === 'next' ? currentIndex + 1 : currentIndex - 1);
	});

	// Auto-hide annotations after 10s; eye button to restore
	const annotationsSvg = document.getElementById('annotations');
	const toggleBtn      = document.getElementById('annotations-toggle');
	setTimeout(() => {
		annotationsSvg?.classList.add('annotations--hidden');
	}, 10000);
	toggleBtn?.addEventListener('click', () => {
		annotationsSvg?.classList.toggle('annotations--hidden');
	});

	// ── Botones de la consola con interacción "On Mouse Down" configurada en Spline ──
	app.addEventListener('mouseDown', (e: any) => {
		if (animating || viewActive) return;
		const name = e?.target?.name ?? '';

		switch (name) {
			case 'SMILE BUTTON':
			case 'Power button':
				setConsoleOn(!consoleOn);
				break;

			case 'CARD': {
				const a = document.createElement('a');
				a.href = '/LizbethTujilloCV.pdf';
				a.download = 'Lizbeth-Trujillo-CV.pdf';
				document.body.appendChild(a);
				a.click();
				a.remove();
				break;
			}

			case 'mystery box 1':
				if (!consoleOn) break;
				panelMode = panelMode === 'class' ? 'menu' : 'class';
				menuEl.classList.toggle('menu-3d--class', panelMode === 'class');
				updateMenuContent();
				break;

			case 'mystery box 2':
				if (!consoleOn) break;
				lang = lang === 'en' ? 'es' : 'en';
				localStorage.setItem('lizzy-lang', lang);
				updateMenuContent();
				updateClassPanel();
				if (viewActive) {
					screenIframe.contentWindow?.postMessage('console:setlang:' + lang, '*');
				}
				break;
		}
	});
</script>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	*, *::before, *::after { box-sizing: border-box; }

	html, body {
		margin: 0; padding: 0;
		width: 100%; height: 100%;
		overflow-x: hidden;
		overflow-y: auto;
		background: #ffeeee;
	}

	.world-screen {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100svh;
		padding-top: clamp(4px, 0.5vh, 12px);
		padding-bottom: clamp(48px, 8vh, 80px);
		padding-left: clamp(16px, 4vw, 48px);
		padding-right: clamp(16px, 4vw, 48px);
		overflow: visible;
	}

	.console-frame {
		position: relative;
		width: min(92vw, calc((100svh - clamp(4px, 0.5vh, 12px) - clamp(48px, 8vh, 80px)) * 0.93));
		aspect-ratio: 0.93;
	}

	#spline-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	.menu-3d {
		position: relative;
		display: flex;
		align-items: center;
		gap: 24px;
		padding: 28px 32px;
		background: linear-gradient(to bottom, rgba(40, 15, 80, 0.95), rgba(10, 6, 20, 1));
		border-top: 4px solid #f3a4ba;
		border-bottom: 4px solid #f3a4ba;
		font-family: 'Comfortaa', sans-serif;
		color: #b8e0ff;
		overflow: hidden;
		cursor: pointer;
		transition: opacity 180ms ease;
	}

	.menu-3d:focus-visible {
		outline: 3px solid #f0e68c;
		outline-offset: -6px;
	}

	.menu-icon {
		width: 96px;
		height: 96px;
		object-fit: contain;
		image-rendering: pixelated;
		flex-shrink: 0;
	}

	.menu-text {
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 0;
	}

	.menu-title {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 30px;
		color: #f0e68c;
		margin: 0;
		line-height: 1.15;
		letter-spacing: 1px;
	}

	.menu-label {
		font-size: 16px;
		margin: 0;
	}

	.menu-hint {
		font-size: 14px;
		margin: 6px 0 0;
		color: #f3a4ba;
		font-weight: 700;
		font-family: monospace;
	}

	/* ── Tarjeta de clase de personaje (mystery box 1) ──────────────────────── */
	.class-panel {
		display: none;
		flex-direction: column;
		gap: 14px;
	}

	.menu-3d--class .class-panel {
		display: flex;
	}

	.menu-3d--class .menu-icon,
	.menu-3d--class .menu-text {
		display: none;
	}

	.class-kicker {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 18px;
		color: #f3a4ba;
		margin: 0;
		letter-spacing: 2px;
	}

	.class-list {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.class-list li {
		display: flex;
		gap: 10px;
		align-items: baseline;
	}

	.class-label {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
		font-size: 14px;
		color: #b8e0ff;
		letter-spacing: 1px;
	}

	.class-value {
		font-size: 16px;
		color: #f0e68c;
		font-weight: 600;
	}

	/* ── Anotaciones tipo boceto ─────────────────────────────────────────────── */
	.annotations {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		overflow: visible;
		animation: ann-fadein 0.9s ease 1.2s both;
	}

	@keyframes ann-fadein {
		from { opacity: 0; transform: translateY(5px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	.ann path {
		fill: none;
		stroke: rgba(30, 8, 28, 0.72);
		stroke-width: 1.5;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.ann text {
		font-family: 'Caveat', cursive;
		font-weight: 700;
		font-size: 6.8px;
		fill: rgba(30, 8, 28, 0.80);
	}

	.annotations--hidden {
		opacity: 0 !important;
		transition: opacity 600ms ease;
	}

	.annotations-toggle {
		position: fixed;
		top: 14px;
		right: 18px;
		z-index: 20;
		background: rgba(255, 238, 238, 0.75);
		border: 1.5px solid rgba(30, 8, 28, 0.18);
		border-radius: 50%;
		width: 38px;
		height: 38px;
		font-size: 18px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		backdrop-filter: blur(6px);
		transition: opacity 200ms ease;
		opacity: 0.45;
	}
	.annotations-toggle:hover { opacity: 1; }

	/* ── View del portafolio renderizada dentro de la pantalla de la consola ──── */
	.screen-view {
		position: fixed;
		z-index: 10;
		overflow: hidden;
		border-radius: 10px;
		background: #f4f4de;
		opacity: 0;
		pointer-events: none;
		transition: opacity 240ms ease;
	}
	/* Pantalla completa cuando la sección está activa.
	   !important garantiza que el CSS gana sobre cualquier estilo inline que el RAF pueda escribir. */
	.screen-view.is-active {
		opacity: 1;
		pointer-events: auto;
		left: 0 !important;
		top: 0 !important;
		width: 100vw !important;
		height: 100svh !important;
		border-radius: 0 !important;
		z-index: 30;
	}
	.screen-view iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
		background: #f4f4de;
	}

	.screen-back {
		display: none; /* la navegación de vuelta la gestiona el botón Back de cada sección */
		position: fixed;
		top: 16px;
		left: 16px;
		z-index: 40;
		font-family: 'Pixelify Sans', monospace;
		font-size: 15px;
		letter-spacing: 0.5px;
		color: #2a0a1c;
		background: rgba(255, 238, 238, 0.85);
		border: 1.5px solid rgba(30, 8, 28, 0.2);
		border-radius: 999px;
		padding: 8px 16px;
		cursor: pointer;
		backdrop-filter: blur(6px);
		transition: opacity 200ms ease, transform 120ms ease;
	}
	.screen-back:hover { transform: translateY(-1px); }
	.screen-back[hidden] { display: none; }

	/* ── Consola apagada (SMILE BUTTON / Power button) ──────────────────────── */
	.menu-off {
		display: none;
		position: absolute;
		inset: 0;
		background: #171321;
		box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.45);
		transition: background 220ms ease, opacity 180ms ease, box-shadow 220ms ease;
	}

	.menu-3d--off {
		cursor: default;
	}

	.menu-3d--off .menu-icon,
	.menu-3d--off .menu-text,
	.menu-3d--off .class-panel {
		display: none;
	}

	.menu-3d--off .menu-off {
		display: block;
	}

	/* ── Responsive ─────────────────────────────────────────────────────────── */

	/* Mobile: lock page to viewport height — no dead scroll below console */
	@media (max-width: 640px) {
		.world-screen {
			height: 100svh;
			min-height: unset;
			overflow: hidden;
			padding-bottom: 0;
		}
		/* Slightly more canvas width on tiny screens */
		.console-frame {
			width: min(97vw, calc((100svh - 12px) * 0.93));
		}
	}

	/* Tablet: lock to viewport, remove horizontal padding so console centers cleanly */
	@media (min-width: 641px) and (max-width: 1024px) {
		.world-screen {
			height: 100svh;
			min-height: unset;
			overflow: hidden;
			padding-inline: 0;
			padding-bottom: 0;
		}
		.console-frame {
			width: min(92vw, calc((100svh - clamp(4px, 0.5vh, 12px)) * 0.93));
		}
	}
</style>

<!-- Lock body scroll on mobile/tablet: Spline injects a watermark that adds page height -->
<style is:global>
	@media (max-width: 1024px) {
		html, body {
			height: 100%;
			max-height: 100svh;
			overflow: hidden;
		}
	}
</style>
