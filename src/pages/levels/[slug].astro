---
import Layout from '../../layouts/Layout.astro';
import { levelProjects } from '../../data/levelProjects';

export function getStaticPaths() {
	return levelProjects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const projectIndex = levelProjects.findIndex((item) => item.slug === project.slug);
const previousProject = projectIndex > 0 ? levelProjects[projectIndex - 1] : null;
const nextProject =
	projectIndex >= 0 && projectIndex < levelProjects.length - 1
		? levelProjects[projectIndex + 1]
		: null;
const metadata = 'metadata' in project ? project.metadata : null;
const contributionNote = 'contributionNote' in project ? project.contributionNote : null;
const projectContext = 'projectContext' in project ? project.projectContext : null;
const systemOverview = 'systemOverview' in project ? project.systemOverview : null;
const impactMetrics = 'impactMetrics' in project ? project.impactMetrics : null;
const clientContext = 'clientContext' in project ? project.clientContext : null;
const useCase = 'useCase' in project ? project.useCase : null;
const blockers = 'blockers' in project ? project.blockers : null;
const deliveryScope = 'deliveryScope' in project ? project.deliveryScope : null;
const whyMatters = 'whyMatters' in project ? project.whyMatters : null;
const roleIntro = 'roleIntro' in project ? project.roleIntro : null;
const processTitle = 'processTitle' in project ? project.processTitle : 'Process';
const keyFeaturesTitle = 'keyFeaturesTitle' in project ? project.keyFeaturesTitle : 'Key Features';
const outcomeTitle = 'outcomeTitle' in project ? project.outcomeTitle : 'Outcome / Level Complete';
const artifactsIntro = 'artifactsIntro' in project ? project.artifactsIntro : null;
const artifactPlaceholders = 'artifactPlaceholders' in project ? project.artifactPlaceholders : null;
---

<Layout title={`${project.title} | Lizzy World`}>
	<main class="level-detail-screen" aria-labelledby="project-title">
		<a class="back-link" href="/levels" aria-label="Back to Levels map">Back</a>

		<header class:list={['project-hero', metadata && 'project-hero-grid']}>
			<div>
				<p class="level-label">{project.level}</p>
				<h1 id="project-title">{project.title}</h1>
				<p>{project.intro}</p>
				<ul class="tag-list" aria-label="Project tags">
					{project.tags.map((tag) => <li>{tag}</li>)}
				</ul>
				{
					metadata && (
						<div class="hero-actions" aria-label="Project actions">
							<a href="#quest-artifacts-title">View Screens</a>
							<a href="/levels">Back to Map</a>
						</div>
					)
				}
			</div>
			{
				metadata && (
					<aside class="level-meta-card" aria-label="Level metadata">
						<p class="unlock-badge">Level Unlocked</p>
						{metadata.map((item) => (
							<div>
								<span>{item.label}</span>
								<strong>{item.value}</strong>
							</div>
						))}
					</aside>
				)
			}
		</header>

		<section class="quest-window">
			<div class="window-bar">
				<span></span>
				<span></span>
				<span></span>
			</div>

			<div class="window-body">
				{
					contributionNote && (
						<section class="content-block contribution-note">
							<h2>Contribution Note</h2>
							{contributionNote.map((paragraph) => <p>{paragraph}</p>)}
						</section>
					)
				}

				<section class="content-block">
					<h2>Mission Brief</h2>
					{project.missionBrief.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<section class="content-block">
					<h2>Problem</h2>
					{project.problem.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				{
					impactMetrics && (
						<section class="content-block impact-block" aria-labelledby="impact-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Impact Snapshot</p>
								<h2 id="impact-title">Product Impact</h2>
							</div>
							<div class="impact-grid">
								{impactMetrics.map((metric) => (
									<article>
										<strong>{metric.value}</strong>
										<span>{metric.label}</span>
									</article>
								))}
							</div>
							{clientContext && <p class="context-note">{clientContext}</p>}
						</section>
					)
				}

				{
					useCase && (
						<section class="content-block product-context-card">
							<div class="product-context-copy">
								<h2>Use Case</h2>
								<p>{useCase}</p>
								{whyMatters && (
									<>
										<h3>Why It Matters</h3>
										<p>{whyMatters}</p>
									</>
								)}
								<section class="inline-role-card" aria-labelledby="inline-role-title">
									<h2 id="inline-role-title">My Role</h2>
									{roleIntro && <p>{roleIntro}</p>}
									<ul>
										{project.role.map((item) => <li>{item}</li>)}
									</ul>
								</section>
							</div>
							<div class="scope-panels">
								{blockers && (
									<article>
										<h3>What Was Slowing the Operation</h3>
										<ul>
											{blockers.map((item) => <li>{item}</li>)}
										</ul>
									</article>
								)}
								{deliveryScope && (
									<article>
										<h3>What Was Built</h3>
										<ul>
											{deliveryScope.map((item) => <li>{item}</li>)}
										</ul>
									</article>
								)}
							</div>
						</section>
					)
				}

				{
					projectContext && (
						<section class="content-block project-context-block">
							<div>
								<h2>Project Context</h2>
								{projectContext.map((paragraph) => <p>{paragraph}</p>)}
							</div>
							{
								systemOverview && (
									<div class="system-overview-card" aria-label="Project system overview">
										{systemOverview.map((item) => (
											<span>{item}</span>
										))}
									</div>
								)
							}
						</section>
					)
				}

				<div class:list={['two-column', useCase && 'two-column-achievement-only']}>
					{
						!useCase && (
							<section class="content-block">
								<h2>My Role</h2>
								{roleIntro && <p>{roleIntro}</p>}
								<ul>
									{project.role.map((item) => <li>{item}</li>)}
								</ul>
							</section>
						)
					}

					<section class="content-block achievement-card">
						<h2>Achievement Unlocked</h2>
						<p>{project.achievement}</p>
					</section>
				</div>

				<section class="content-block">
					<div class="section-heading-row">
						<h2>{processTitle}</h2>
					</div>
					<div id="level-process-carousel" class="process-grid process-carousel" tabindex="0">
						{
							project.process.map((step, index) => (
								<article>
									<p class="step-number">0{index + 1}</p>
									<h3>{step.title}</h3>
									{step.body.map((paragraph) => <p>{paragraph}</p>)}
								</article>
							))
						}
					</div>
					<div class="carousel-controls" aria-label="Process carousel controls">
						<button type="button" data-process-prev aria-label="Previous process step"></button>
						<button type="button" data-process-next aria-label="Next process step"></button>
					</div>
				</section>

				{
					project.slug === 'learning-path-platform' && (
						<section class="content-block quest-artifacts" aria-labelledby="quest-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Evidence Collected</p>
								<h2 id="quest-artifacts-title">Quest Artifacts</h2>
								<p>
									Research and design artifacts that shaped the learning experience.
								</p>
							</div>

							<div class="wireframe-gallery" aria-label="Learning path platform wireframe screens">
								<div class="wireframe-heading">
									<span class="artifact-label">Wireframe Screens</span>
									<h3>Selected Learning Flow Screens</h3>
								</div>
								<div class="wireframe-strip">
									<a
										class="wireframe-preview"
										href="/img/levels/learning-path/wireframe-home.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open home wireframe"
									>
										<img
											src="/img/levels/learning-path/wireframe-home.png"
											alt="Home mobile wireframe for the learning path platform"
											loading="lazy"
										/>
									</a>
									<a
										class="wireframe-preview"
										href="/img/levels/learning-path/wireframe-onboarding.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open onboarding wireframe"
									>
										<img
											src="/img/levels/learning-path/wireframe-onboarding.png"
											alt="Onboarding mobile wireframe for the learning path platform"
											loading="lazy"
										/>
									</a>
								</div>
							</div>

							<div class="artifact-feature-grid">
								<article class="artifact-card personas-artifact-card">
									<span class="artifact-label">Research Artifact</span>
									<h3>User Personas</h3>
									<p>
										User personas helped identify educator profiles based on digital
										confidence, motivation, access to technology, frustrations, and available
										time.
									</p>
									<div class="persona-gallery" aria-label="User persona research artifacts">
										<a
											class="persona-preview persona-preview-maria"
											href="/img/levels/learning-path/persona-maria.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open Maria user persona artifact"
										>
											<img
												src="/img/levels/learning-path/persona-maria.png"
												alt="User persona research artifact for Maria, educator profile"
												loading="lazy"
											/>
										</a>
										<a
											class="persona-preview persona-preview-alejandro"
											href="/img/levels/learning-path/persona-alejandro.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open Alejandro user persona artifact"
										>
											<img
												src="/img/levels/learning-path/persona-alejandro.png"
												alt="User persona research artifact for Alejandro, educator profile"
												loading="lazy"
											/>
										</a>
									</div>
								</article>

								<article class="artifact-card journey-artifact-card">
									<span class="artifact-label">Research Artifact</span>
									<h3>Customer Journey Map</h3>
									<p>
										The journey map helped identify moments of friction, motivation, and
										support across the educator's learning experience.
									</p>
									<a
										class="artifact-image-frame journey-frame"
										href="/img/levels/learning-path/customer-journey-map.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open full customer journey map"
									>
										<img
											src="/img/levels/learning-path/customer-journey-map.png"
											alt="Customer journey map for educator learning experience"
											loading="lazy"
										/>
									</a>
								</article>
							</div>

							<article class="artifact-card artifact-card-wide final-screens-card">
								<span class="artifact-label">Final Evidence</span>
								<h3>Final Screens</h3>
								<p>
									The mockups translated the research into a clearer, more accessible platform
									experience focused on personalized routes, resources, and progress tracking.
								</p>
								<div class="mockup-showcase">
									<a
										class="mockup-frame phone-frame phone-left"
										href="/img/levels/learning-path/final-screen-mobile-route.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform route mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-mobile-route.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
									<a
										class="showcase-main"
										href="/img/levels/learning-path/final-screen-tablet-resource.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform tablet mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-tablet-resource.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
									<a
										class="mockup-frame phone-frame phone-right"
										href="/img/levels/learning-path/final-screen-mobile-feedback.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform feedback mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-mobile-feedback.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
								</div>
							</article>
						</section>
					)
				}

				{
					project.slug === 'digital-entertainment-redesign' && (
						<section class="content-block quest-artifacts entertainment-artifacts" aria-labelledby="entertainment-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Final Evidence</p>
								<h2 id="entertainment-artifacts-title">Quest Artifacts</h2>
								<p>
									Wireframes and mobile mockups showing how the redesign expanded discovery,
									wallet actions, and casino cross-navigation without breaking the core
									purchase flow.
								</p>
							</div>

							<div class="journey-map-gallery" aria-label="Digital entertainment user journey maps">
								<div class="journey-map-heading">
									<span class="artifact-label">User Journey Maps</span>
									<h3>Payment and Full App Flow</h3>
									<p>
										Two journey maps were used to compare the direct game-payment flow with the
										full experience from opening the app, registering, playing, and needing to
										load money.
									</p>
								</div>
								<div class="journey-map-strip">
									<a
										class="journey-map-preview"
										href="/img/levels/digital-entertainment/journey-map-pay-game.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open game payment journey map"
									>
										<img
											src="/img/levels/digital-entertainment/journey-map-pay-game.png"
											alt="User journey map for selecting, playing, and paying for a game"
											loading="lazy"
										/>
									</a>
									<a
										class="journey-map-preview"
										href="/img/levels/digital-entertainment/journey-map-full-flow.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open full app journey map"
									>
										<img
											src="/img/levels/digital-entertainment/journey-map-full-flow.png"
											alt="Complete user journey map from app entry and registration to play, wallet loading, and payment"
											loading="lazy"
										/>
									</a>
								</div>
							</div>

							<div class="wireframe-gallery" aria-label="Digital entertainment wireframes">
								<div class="wireframe-heading">
									<span class="artifact-label">Wireframe Screens</span>
									<h3>Selected Flow Screens</h3>
								</div>
								<div class="wireframe-strip">
									<a
											class="wireframe-preview"
											href="/img/levels/digital-entertainment/wireframe-tickets.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open tickets wireframe"
										>
											<img
												src="/img/levels/digital-entertainment/wireframe-tickets.png"
												alt="Tickets mobile wireframe for digital entertainment app"
												loading="lazy"
											/>
										</a>
									<a
											class="wireframe-preview"
											href="/img/levels/digital-entertainment/wireframe-wallet.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open wallet wireframe"
										>
											<img
												src="/img/levels/digital-entertainment/wireframe-wallet.png"
												alt="Wallet mobile wireframe for digital entertainment app"
												loading="lazy"
											/>
										</a>
								</div>
							</div>

							<div class="entertainment-mockup-grid" aria-label="Digital entertainment redesign mockups">
								<a
									class="entertainment-mockup entertainment-mockup-primary"
									href="/img/levels/digital-entertainment/mockup-home-casino.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open home and casino discovery mockup"
								>
									<img
										src="/img/levels/digital-entertainment/mockup-home-casino.png"
										alt="Mobile app redesign mockup showing home screen, casino discovery, and promotional modules"
										loading="lazy"
									/>
								</a>
								<a
									class="entertainment-mockup entertainment-mockup-secondary"
									href="/img/levels/digital-entertainment/mockup-purchase-wallet.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open purchase confirmation and wallet mockup"
								>
									<img
										src="/img/levels/digital-entertainment/mockup-purchase-wallet.png"
										alt="Mobile app redesign mockup showing purchase confirmation, wallet, and casino entry points"
										loading="lazy"
									/>
								</a>
							</div>
						</section>
					)
				}

				{
					project.slug === 'fixia-service-platform' && (
						<section class="content-block quest-artifacts fixia-artifacts" aria-labelledby="fixia-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Final Evidence</p>
								<h2 id="fixia-artifacts-title">Quest Artifacts</h2>
								<p>
									Desktop and mobile mockups showing how FIXIA turns service uncertainty into a clearer path: diagnose the problem, compare verified technicians, and request help with more trust.
								</p>
							</div>

							<div class="fixia-showcase" aria-label="FIXIA final mockups">
								<a
									class="fixia-mockup fixia-mockup-desktop"
									href="/img/levels/fixia/fixia-imac.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open FIXIA desktop mockup"
								>
									<img
										src="/img/levels/fixia/fixia-imac.png"
										alt="FIXIA desktop mockup showing verified plumber cards and service filters"
										loading="lazy"
									/>
								</a>
								<a
									class="fixia-mockup fixia-mockup-mobile"
									href="/img/levels/fixia/fixia-iphone.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open FIXIA mobile app mockup"
								>
									<img
										src="/img/levels/fixia/fixia-iphone.png"
										alt="FIXIA mobile mockup showing home-service app screens and splash screen"
										loading="lazy"
									/>
								</a>
							</div>
						</section>
					)
				}

				{
					artifactPlaceholders && project.slug !== 'ai-hiring-platform' && (
						<section class="content-block quest-artifacts hiring-artifacts" aria-labelledby="quest-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Evidence Collected</p>
								<h2 id="quest-artifacts-title">Quest Artifacts</h2>
								<p>{artifactsIntro}</p>
							</div>

							<div class="hiring-artifact-grid">
								{artifactPlaceholders.map((artifact, index) => (
									<article class="artifact-card hiring-artifact-card">
										<span class="artifact-label">{index === 3 ? 'Screen Contribution' : 'Research Artifact'}</span>
										<h3>{artifact.title}</h3>
										<p>{artifact.description}</p>
										<div class="artifact-placeholder" role="img" aria-label={artifact.alt}>
											<span>{artifact.title}</span>
											<small>Image slot ready</small>
										</div>
									</article>
								))}
							</div>
						</section>
					)
				}

				<div class="two-column decision-feature-grid">
					<section class="content-block decision-summary-card">
						<h2>Design Decisions</h2>
						<ul class="decision-list">
							{project.designDecisions.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="content-block feature-summary-card">
						<h2>{keyFeaturesTitle}</h2>
						<ul class="feature-chip-list">
							{project.keyFeatures.map((item) => <li>{item}</li>)}
						</ul>
					</section>
				</div>

				<section class="content-block outcome">
					<h2>{outcomeTitle}</h2>
					{project.outcome.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<nav class="level-nav" aria-label="Level navigation">
					<a href="/levels">Back to Map</a>
					{
						previousProject && (
							<a href={`/levels/${previousProject.slug}`}>
								<span class="nav-arrow" aria-hidden="true">&lt;</span>
								Previous Level
							</a>
						)
					}
					{
						nextProject && (
							<a href={`/levels/${nextProject.slug}`}>
								Next Level
								<span class="nav-arrow" aria-hidden="true">&gt;</span>
							</a>
						)
					}
					<a href="/contact">Contact Player</a>
				</nav>
			</div>
		</section>
	</main>

</Layout>

<script>
	const processCarousel = document.getElementById('level-process-carousel');
	const processPrevButton = document.querySelector('[data-process-prev]');
	const processNextButton = document.querySelector('[data-process-next]');

	const scrollProcessCarousel = (direction: number) => {
		if (!(processCarousel instanceof HTMLElement)) return;

		const firstCard = processCarousel.querySelector('article');
		const cardWidth = firstCard instanceof HTMLElement ? firstCard.offsetWidth : 360;
		const gap = parseFloat(getComputedStyle(processCarousel).columnGap || '0');

		processCarousel.scrollBy({
			left: direction * (cardWidth + gap),
			behavior: 'smooth',
		});
	};

	processPrevButton?.addEventListener('click', () => scrollProcessCarousel(-1));
	processNextButton?.addEventListener('click', () => scrollProcessCarousel(1));
</script>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		background: #f4f4de;
	}

	.level-detail-screen {
		min-height: 100svh;
		padding: clamp(84px, 10vh, 112px) clamp(18px, 5vw, 70px) 54px;
		background: #f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}

	.project-hero,
	.quest-window {
		width: min(100%, 1080px);
		margin-inline: auto;
	}

	.project-hero {
		margin-bottom: 32px;
	}

	.project-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
		gap: clamp(24px, 4vw, 48px);
		align-items: end;
	}

	.level-label {
