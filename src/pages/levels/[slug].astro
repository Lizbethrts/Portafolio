---
import Layout from '../../layouts/Layout.astro';
import { levelProjects } from '../../data/levelProjects';

export function getStaticPaths() {
	return levelProjects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const projectIndex = levelProjects.findIndex((item) => item.slug === project.slug);
const previousProject = projectIndex > 0 ? levelProjects[projectIndex - 1] : null;
const nextProject =
	projectIndex >= 0 && projectIndex < levelProjects.length - 1
		? levelProjects[projectIndex + 1]
		: null;
const metadata = 'metadata' in project ? project.metadata : null;
const contributionNote = 'contributionNote' in project ? project.contributionNote : null;
const projectContext = 'projectContext' in project ? project.projectContext : null;
const systemOverview = 'systemOverview' in project ? project.systemOverview : null;
const impactMetrics = 'impactMetrics' in project ? project.impactMetrics : null;
const clientContext = 'clientContext' in project ? project.clientContext : null;
const useCase = 'useCase' in project ? project.useCase : null;
const blockers = 'blockers' in project ? project.blockers : null;
const deliveryScope = 'deliveryScope' in project ? project.deliveryScope : null;
const whyMatters = 'whyMatters' in project ? project.whyMatters : null;
const roleIntro = 'roleIntro' in project ? project.roleIntro : null;
const processTitle = 'processTitle' in project ? project.processTitle : 'Process';
const keyFeaturesTitle = 'keyFeaturesTitle' in project ? project.keyFeaturesTitle : 'Key Features';
const outcomeTitle = 'outcomeTitle' in project ? project.outcomeTitle : 'Outcome / Level Complete';
const artifactsIntro = 'artifactsIntro' in project ? project.artifactsIntro : null;
const artifactPlaceholders = 'artifactPlaceholders' in project ? project.artifactPlaceholders : null;
const ctaLabel = 'ctaLabel' in project ? project.ctaLabel : null;
const statusLabel = 'statusLabel' in project ? project.statusLabel : null;
const missionHighlight = 'missionHighlight' in project ? project.missionHighlight : null;
const problemThemes = 'problemThemes' in project ? project.problemThemes : null;
const systemStatsMain = 'systemStatsMain' in project ? project.systemStatsMain : null;
const systemScopeSupport = 'systemScopeSupport' in project ? project.systemScopeSupport : null;
const systemScopeDiagram = 'systemScopeDiagram' in project ? project.systemScopeDiagram : null;
const usersRoles = 'usersRoles' in project ? project.usersRoles : null;
const rolePullQuote = 'rolePullQuote' in project ? project.rolePullQuote : null;
const modules = 'modules' in project ? project.modules : null;
const workflows = 'workflows' in project ? project.workflows : null;
const designPrinciples = 'designPrinciples' in project ? project.designPrinciples : null;
const uxBizTech = 'uxBizTech' in project ? project.uxBizTech : null;
const artifactThemes = 'artifactThemes' in project ? project.artifactThemes : null;
const sapTraceability = 'sapTraceability' in project ? project.sapTraceability : null;
const expectedImpact = 'expectedImpact' in project ? project.expectedImpact : null;
const mainChallenge = 'mainChallenge' in project ? project.mainChallenge : null;
const mainChallengeHighlight = 'mainChallengeHighlight' in project ? project.mainChallengeHighlight : null;

const es = ('es' in project ? project.es : null) as Record<string, any> | null;
const esProject = es ? { ...project, ...es } : project;
const esMetadata = es && 'metadata' in es ? es.metadata : metadata;
const esContributionNote = es && 'contributionNote' in es ? es.contributionNote : contributionNote;
const esProjectContext = es && 'projectContext' in es ? es.projectContext : projectContext;
const esSystemOverview = es && 'systemOverview' in es ? es.systemOverview : systemOverview;
const esImpactMetrics = es && 'impactMetrics' in es ? es.impactMetrics : impactMetrics;
const esClientContext = es && 'clientContext' in es ? es.clientContext : clientContext;
const esUseCase = es && 'useCase' in es ? es.useCase : useCase;
const esBlockers = es && 'blockers' in es ? es.blockers : blockers;
const esDeliveryScope = es && 'deliveryScope' in es ? es.deliveryScope : deliveryScope;
const esWhyMatters = es && 'whyMatters' in es ? es.whyMatters : whyMatters;
const esRoleIntro = es && 'roleIntro' in es ? es.roleIntro : roleIntro;
const esProcessTitle = es && 'processTitle' in es ? es.processTitle : (processTitle === 'Process' ? 'Proceso' : processTitle);
const esKeyFeaturesTitle = es && 'keyFeaturesTitle' in es ? es.keyFeaturesTitle : (keyFeaturesTitle === 'Key Features' ? 'Funcionalidades Clave' : keyFeaturesTitle);
const esOutcomeTitle = es && 'outcomeTitle' in es ? es.outcomeTitle : (outcomeTitle === 'Outcome / Level Complete' ? 'Resultado / Nivel Completado' : outcomeTitle);
const esArtifactsIntro = es && 'artifactsIntro' in es ? es.artifactsIntro : artifactsIntro;
const esArtifactPlaceholders = es && 'artifactPlaceholders' in es ? es.artifactPlaceholders : artifactPlaceholders;
const esCtaLabel = es && 'ctaLabel' in es ? es.ctaLabel : ctaLabel;
const esStatusLabel = es && 'statusLabel' in es ? es.statusLabel : statusLabel;
const esMissionHighlight = es && 'missionHighlight' in es ? es.missionHighlight : missionHighlight;
const esProblemThemes = es && 'problemThemes' in es ? es.problemThemes : problemThemes;
const esSystemStatsMain = es && 'systemStatsMain' in es ? es.systemStatsMain : systemStatsMain;
const esSystemScopeSupport = es && 'systemScopeSupport' in es ? es.systemScopeSupport : systemScopeSupport;
const esSystemScopeDiagram = es && 'systemScopeDiagram' in es ? es.systemScopeDiagram : systemScopeDiagram;
const esUsersRoles = es && 'usersRoles' in es ? es.usersRoles : usersRoles;
const esRolePullQuote = es && 'rolePullQuote' in es ? es.rolePullQuote : rolePullQuote;
const esModules = es && 'modules' in es ? es.modules : modules;
const esWorkflows = es && 'workflows' in es ? es.workflows : workflows;
const esDesignPrinciples = es && 'designPrinciples' in es ? es.designPrinciples : designPrinciples;
const esUxBizTech = es && 'uxBizTech' in es ? es.uxBizTech : uxBizTech;
const esArtifactThemes = es && 'artifactThemes' in es ? es.artifactThemes : artifactThemes;
const esSapTraceability = es && 'sapTraceability' in es ? es.sapTraceability : sapTraceability;
const esExpectedImpact = es && 'expectedImpact' in es ? es.expectedImpact : expectedImpact;
const esMainChallenge = es && 'mainChallenge' in es ? es.mainChallenge : mainChallenge;
const esMainChallengeHighlight = es && 'mainChallengeHighlight' in es ? es.mainChallengeHighlight : mainChallengeHighlight;

const L = {
	en: {
		back: 'Back', backAria: 'Back to Levels map',
		levelUnlocked: 'Level Unlocked', viewScreens: 'View Screens', backToMap: 'Back to Map',
		contributionNote: 'Contribution Note', missionBrief: 'Mission Brief', problem: 'Problem',
		impactSnapshot: 'Impact Snapshot', productImpact: 'Product Impact',
		useCase: 'Use Case', whyItMatters: 'Why It Matters', myRole: 'My Role',
		whatWasSlowing: 'What Was Slowing the Operation', whatWasBuilt: 'What Was Built',
		projectContext: 'Project Context', achievementUnlocked: 'Achievement Unlocked',
		evidenceCollected: 'Evidence Collected', finalEvidence: 'Final Evidence',
		questArtifacts: 'Quest Artifacts', designDecisions: 'Design Decisions',
		previousLevel: 'Previous Level', nextLevel: 'Next Level', contactPlayer: 'Contact Player',
		imageSlotReady: 'Image slot ready',
		wireframeScreens: 'Wireframe Screens', selectedLearningFlow: 'Selected Learning Flow Screens',
		researchArtifact: 'Research Artifact', userPersonasTitle: 'User Personas',
		customerJourneyMapTitle: 'Customer Journey Map', finalScreensTitle: 'Final Screens',
		personasCopy: 'User personas helped identify educator profiles based on digital confidence, motivation, access to technology, frustrations, and available time.',
		journeyCopy: 'The journey map helped identify moments of friction, motivation, and support across the educator’s learning experience.',
		finalScreensCopy: 'The mockups translated the research into a clearer, more accessible platform experience focused on personalized routes, resources, and progress tracking.',
		userJourneyMapsTitle: 'User Journey Maps', paymentFlowTitle: 'Payment and Full App Flow',
		journeyMapsCopy: 'Two journey maps were used to compare the direct game-payment flow with the full experience from opening the app, registering, playing, and needing to load money.',
		selectedFlowScreens: 'Selected Flow Screens',
		entertainmentArtifactsIntro: 'Wireframes and mobile mockups showing how the redesign expanded discovery, wallet actions, and casino cross-navigation without breaking the core purchase flow.',
		fixiaArtifactsIntro: 'Desktop and mobile mockups showing how FIXIA turns service uncertainty into a clearer path: diagnose the problem, compare verified technicians, and request help with more trust.',
		aiHiringArtifactsIntro: 'Screen design contributions supporting the gamified hiring platform experience.',
		screenContribution: 'Screen Contribution',
		operationalChallenge: 'The Operational Challenge', systemScope: 'System Scope',
		usersAndRoles: 'Users & Roles', internalUsers: 'Internal Users', externalUsers: 'External Users',
		theSevenModules: 'The Seven Modules', module: 'Module', viewFlow: 'View Flow',
		featuredWorkflows: 'Featured Workflows', keyUxDecisions: 'Key UX Decisions',
		connectingTitle: 'Connecting UX, Business & Technology', uxLabel: 'UX', businessLabel: 'Business', technologyLabel: 'Technology',
		sapAndTraceability: 'SAP & Traceability', expectedImpactTitle: 'Expected Operational Impact',
		whatILearned: 'What I Learned',
		definedProfilesTitle: 'Defined User Profiles', empathyMapTitle: 'Empathy Map', painstormingTitle: 'PAINstorming',
		affinityClusteringTitle: 'Affinity Clustering', matrixTitle: 'Impact × Effort Matrix', interfaceExplorationsTitle: 'Selected Interface Explorations',
		definedProfilesCopy: 'Workshop-defined archetypes representing the entrepreneurs and stakeholders this concept was designed for.',
		empathyMapCopy: 'Stakeholders explored what entrepreneurs see, hear, think, feel, say, and do when facing a valuation, sale, or investment decision.',
		painstormingCopy: 'Participants identified specific frustrations, improvised processes, and risks experienced by small business owners.',
		affinityClusteringCopy: 'Related observations were grouped into three recurring themes: information gap, time and confidence, and actions and processes.',
		matrixCopy: 'Opportunities were evaluated by expected user impact and implementation effort to align the team around a shared direction.',
		interfaceExplorationsCopy: 'Early screens explored how the product could guide users through valuation, scenarios, and financial learning.',
	},
	es: {
		back: 'Volver', backAria: 'Volver al mapa de Niveles',
		levelUnlocked: 'Nivel Desbloqueado', viewScreens: 'Ver Pantallas', backToMap: 'Volver al Mapa',
		contributionNote: 'Nota de Contribución', missionBrief: 'Resumen de la Misión', problem: 'Problema',
		impactSnapshot: 'Resumen de Impacto', productImpact: 'Impacto del Producto',
		useCase: 'Caso de Uso', whyItMatters: 'Por Qué Importa', myRole: 'Mi Rol',
		whatWasSlowing: 'Qué Frenaba la Operación', whatWasBuilt: 'Qué se Construyó',
		projectContext: 'Contexto del Proyecto', achievementUnlocked: 'Logro Desbloqueado',
		evidenceCollected: 'Evidencia Recolectada', finalEvidence: 'Evidencia Final',
		questArtifacts: 'Artefactos de la Misión', designDecisions: 'Decisiones de Diseño',
		previousLevel: 'Nivel Anterior', nextLevel: 'Siguiente Nivel', contactPlayer: 'Contactar Jugador',
		imageSlotReady: 'Espacio de imagen listo',
		wireframeScreens: 'Pantallas de Wireframe', selectedLearningFlow: 'Pantallas Seleccionadas del Flujo de Aprendizaje',
		researchArtifact: 'Artefacto de Investigación', userPersonasTitle: 'Personas de Usuario',
		customerJourneyMapTitle: 'Customer Journey Map', finalScreensTitle: 'Pantallas Finales',
		personasCopy: 'Las personas de usuario ayudaron a identificar perfiles docentes según su confianza digital, motivación, acceso a tecnología, frustraciones y tiempo disponible.',
		journeyCopy: 'El journey map ayudó a identificar momentos de fricción, motivación y apoyo a lo largo de la experiencia de aprendizaje docente.',
		finalScreensCopy: 'Los mockups tradujeron la investigación en una experiencia de plataforma más clara y accesible, enfocada en rutas personalizadas, recursos y seguimiento de progreso.',
		userJourneyMapsTitle: 'Mapas de Customer Journey', paymentFlowTitle: 'Flujo de Pago y App Completa',
		journeyMapsCopy: 'Se usaron dos journey maps para comparar el flujo directo de pago de juego con la experiencia completa desde abrir la app, registrarse, jugar y necesitar cargar dinero.',
		selectedFlowScreens: 'Pantallas Seleccionadas del Flujo',
		entertainmentArtifactsIntro: 'Wireframes y mockups móviles que muestran cómo el rediseño amplió el descubrimiento, las acciones de billetera y la navegación cruzada al casino sin romper el flujo principal de compra.',
		fixiaArtifactsIntro: 'Mockups de escritorio y móvil que muestran cómo FIXIA convierte la incertidumbre del servicio en un camino más claro: diagnosticar el problema, comparar técnicos verificados y solicitar ayuda con más confianza.',
		aiHiringArtifactsIntro: 'Contribuciones de diseño de pantallas que apoyan la experiencia de la plataforma de contratación gamificada.',
		screenContribution: 'Contribución de Pantalla',
		operationalChallenge: 'El Reto Operativo', systemScope: 'Alcance del Sistema',
		usersAndRoles: 'Usuarios y Roles', internalUsers: 'Usuarios Internos', externalUsers: 'Usuarios Externos',
		theSevenModules: 'Los Siete Módulos', module: 'Módulo', viewFlow: 'Ver Flujo',
		featuredWorkflows: 'Flujos Destacados', keyUxDecisions: 'Decisiones Clave de UX',
		connectingTitle: 'Conectando UX, Negocio y Tecnología', uxLabel: 'UX', businessLabel: 'Negocio', technologyLabel: 'Tecnología',
		sapAndTraceability: 'SAP y Trazabilidad', expectedImpactTitle: 'Impacto Operativo Esperado',
		whatILearned: 'Lo Que Aprendí',
		definedProfilesTitle: 'Perfiles de Usuario Definidos', empathyMapTitle: 'Mapa de Empatía', painstormingTitle: 'PAINstorming',
		affinityClusteringTitle: 'Agrupación por Afinidad', matrixTitle: 'Matriz de Impacto × Esfuerzo', interfaceExplorationsTitle: 'Exploraciones de Interfaz Seleccionadas',
		definedProfilesCopy: 'Arquetipos definidos en el taller que representan a los emprendedores y stakeholders para quienes se diseñó este concepto.',
		empathyMapCopy: 'Los stakeholders exploraron qué ven, escuchan, piensan, sienten, dicen y hacen los emprendedores al enfrentar una decisión de valuación, venta o inversión.',
		painstormingCopy: 'Los participantes identificaron frustraciones específicas, procesos improvisados y riesgos que experimentan los dueños de pequeños negocios.',
		affinityClusteringCopy: 'Las observaciones relacionadas se agruparon en tres temas recurrentes: brecha de información, tiempo y confianza, y acciones y procesos.',
		matrixCopy: 'Las oportunidades se evaluaron según el impacto esperado para el usuario y el esfuerzo de implementación para alinear al equipo en una dirección compartida.',
		interfaceExplorationsCopy: 'Pantallas tempranas que exploraron cómo el producto podría guiar a los usuarios a través de la valuación, escenarios y aprendizaje financiero.',
	},
};

const views = (['en', 'es'] as const).map((lang) => ({
	lang,
	t: L[lang],
	p: lang === 'en' ? project : esProject,
	metadata: lang === 'en' ? metadata : esMetadata,
	contributionNote: lang === 'en' ? contributionNote : esContributionNote,
	projectContext: lang === 'en' ? projectContext : esProjectContext,
	systemOverview: lang === 'en' ? systemOverview : esSystemOverview,
	impactMetrics: lang === 'en' ? impactMetrics : esImpactMetrics,
	clientContext: lang === 'en' ? clientContext : esClientContext,
	useCase: lang === 'en' ? useCase : esUseCase,
	blockers: lang === 'en' ? blockers : esBlockers,
	deliveryScope: lang === 'en' ? deliveryScope : esDeliveryScope,
	whyMatters: lang === 'en' ? whyMatters : esWhyMatters,
	roleIntro: lang === 'en' ? roleIntro : esRoleIntro,
	processTitle: lang === 'en' ? processTitle : esProcessTitle,
	keyFeaturesTitle: lang === 'en' ? keyFeaturesTitle : esKeyFeaturesTitle,
	outcomeTitle: lang === 'en' ? outcomeTitle : esOutcomeTitle,
	artifactsIntro: lang === 'en' ? artifactsIntro : esArtifactsIntro,
	artifactPlaceholders: lang === 'en' ? artifactPlaceholders : esArtifactPlaceholders,
	ctaLabel: lang === 'en' ? ctaLabel : esCtaLabel,
	statusLabel: lang === 'en' ? statusLabel : esStatusLabel,
	missionHighlight: lang === 'en' ? missionHighlight : esMissionHighlight,
	problemThemes: lang === 'en' ? problemThemes : esProblemThemes,
	systemStatsMain: lang === 'en' ? systemStatsMain : esSystemStatsMain,
	systemScopeSupport: lang === 'en' ? systemScopeSupport : esSystemScopeSupport,
	systemScopeDiagram: lang === 'en' ? systemScopeDiagram : esSystemScopeDiagram,
	usersRoles: lang === 'en' ? usersRoles : esUsersRoles,
	rolePullQuote: lang === 'en' ? rolePullQuote : esRolePullQuote,
	modules: lang === 'en' ? modules : esModules,
	workflows: lang === 'en' ? workflows : esWorkflows,
	designPrinciples: lang === 'en' ? designPrinciples : esDesignPrinciples,
	uxBizTech: lang === 'en' ? uxBizTech : esUxBizTech,
	artifactThemes: lang === 'en' ? artifactThemes : esArtifactThemes,
	sapTraceability: lang === 'en' ? sapTraceability : esSapTraceability,
	expectedImpact: lang === 'en' ? expectedImpact : esExpectedImpact,
	mainChallenge: lang === 'en' ? mainChallenge : esMainChallenge,
	mainChallengeHighlight: lang === 'en' ? mainChallengeHighlight : esMainChallengeHighlight,
}));
---

<Layout title={`${project.title} | Lizzy World`} frame>
	<script is:inline>
	window.__i18nStrings = {
		en: { nav: { backAria: 'Back to Levels map' } },
		es: { nav: { backAria: 'Volver al mapa de Niveles' } },
	};
	</script>
	<main class="level-detail-screen" aria-labelledby="project-title-en">
		<a class="back-link" href="/levels" aria-label="Back to Levels map" data-i18n="nav.back" data-i18n-aria="nav.backAria">Back</a>

		{views.map(({ lang, t, p, metadata, contributionNote, projectContext, systemOverview, impactMetrics, clientContext, useCase, blockers, deliveryScope, whyMatters, roleIntro, processTitle, keyFeaturesTitle, outcomeTitle, artifactsIntro, artifactPlaceholders, ctaLabel, statusLabel, missionHighlight, problemThemes, systemStatsMain, systemScopeSupport, systemScopeDiagram, usersRoles, rolePullQuote, modules, workflows, designPrinciples, uxBizTech, artifactThemes, sapTraceability, expectedImpact, mainChallenge, mainChallengeHighlight }) => (
		<div class="lang-pane" data-plang={lang} hidden={lang !== 'en'}>
		<header class:list={['project-hero', metadata && 'project-hero-grid']}>
			<div>
				<p class="level-label">{p.level}</p>
				<h1 id={`project-title-${lang}`}>{p.title}</h1>
				<p>{p.intro}</p>
				<ul class="tag-list" aria-label="Project tags">
					{p.tags.map((tag) => <li>{tag}</li>)}
				</ul>
				{
					metadata && (
						<div class="hero-actions" aria-label="Project actions">
							<a href="#quest-artifacts-title">{ctaLabel || t.viewScreens}</a>
							<a href="/levels">{t.backToMap}</a>
						</div>
					)
				}
			</div>
			{
				metadata && (
					<aside class="level-meta-card" aria-label="Level metadata">
						<p class="unlock-badge">
							{modules && (
								<svg class="unlock-badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path d="M3 9.5 12 4l9 5.5V20a1 1 0 0 1-1 1h-4v-6H9v6H4a1 1 0 0 1-1-1Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
								</svg>
							)}
							{statusLabel || t.levelUnlocked}
						</p>
						{metadata.map((item) => (
							<div>
								<span>{item.label}</span>
								<strong>{item.value}</strong>
							</div>
						))}
					</aside>
				)
			}
		</header>

		<section class="quest-window">
			<div class="window-bar">
				<span></span>
				<span></span>
				<span></span>
			</div>

			<div class="window-body">
				{
					contributionNote && (
						<section class="content-block contribution-note">
							<h2>{t.contributionNote}</h2>
							{contributionNote.map((paragraph) => <p>{paragraph}</p>)}
						</section>
					)
				}

				{
					missionHighlight ? (
						<section class="content-block editorial-block">
							<div class="editorial-heading">
								<span class="editorial-number">01</span>
								<h2>{t.missionBrief}</h2>
							</div>
							<div class="editorial-copy">
								<p class="editorial-highlight">{missionHighlight}</p>
								{p.missionBrief.map((paragraph) => <p>{paragraph}</p>)}
							</div>
						</section>
					) : (
						<section class="content-block">
							<h2>{t.missionBrief}</h2>
							{p.missionBrief.map((paragraph) => <p>{paragraph}</p>)}
						</section>
					)
				}

				{
					problemThemes ? (
						<section class="content-block">
							<h2>{t.operationalChallenge}</h2>
							{p.problem.map((paragraph) => <p>{paragraph}</p>)}
							<div class="theme-list">
								{problemThemes.map((group: { theme: string; items: string[] }, themeIndex: number) => (
									<div class="theme-row">
										<p class="theme-label">{group.theme}</p>
										<ul class="theme-items">
											{group.items.map((item, itemIndex) => (
												<li><span class="theme-marker">{themeIndex + 1}.{itemIndex + 1}</span>{item}</li>
											))}
										</ul>
									</div>
								))}
							</div>
						</section>
					) : (
						<section class="content-block">
							<h2>{t.problem}</h2>
							{p.problem.map((paragraph) => <p>{paragraph}</p>)}
						</section>
					)
				}

				{
					systemStatsMain && (
						<section class="content-block">
							<h2>{t.systemScope}</h2>
							<div class="stat-row">
								{systemStatsMain.map((stat: { value: string; label: string }) => (
									<div class="stat-block">
										<strong>{stat.value}</strong>
										<span>{stat.label}</span>
									</div>
								))}
							</div>
							{systemScopeSupport && <p class="stat-support">{systemScopeSupport}</p>}
							{
								systemScopeDiagram && (
									<div class="flow-path" aria-label={t.systemScope}>
										{systemScopeDiagram.map((step: string) => (
											<span class="flow-node">{step}</span>
										))}
									</div>
								)
							}
						</section>
					)
				}

				{
					usersRoles && (
						<section class="content-block">
							<h2>{t.usersAndRoles}</h2>
							<div class="plain-columns">
								<div>
									<h3>{t.internalUsers}</h3>
									<ul class="plain-list">
										{usersRoles.internal.map((item) => <li>{item}</li>)}
									</ul>
								</div>
								<div>
									<h3>{t.externalUsers}</h3>
									<ul class="plain-list">
										{usersRoles.external.map((item) => <li>{item}</li>)}
									</ul>
								</div>
							</div>
							<p class="context-note">{usersRoles.note}</p>
						</section>
					)
				}

				{
					impactMetrics && (
						<section class="content-block impact-block" aria-labelledby={`impact-title-${lang}`}>
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">{t.impactSnapshot}</p>
								<h2 id={`impact-title-${lang}`}>{t.productImpact}</h2>
							</div>
							<div class="impact-grid">
								{impactMetrics.map((metric) => (
									<article>
										<strong>{metric.value}</strong>
										<span>{metric.label}</span>
									</article>
								))}
							</div>
							{clientContext && <p class="context-note">{clientContext}</p>}
						</section>
					)
				}

				{
					useCase && (
						<section class="content-block product-context-card">
							<div class="product-context-copy">
								<h2>{t.useCase}</h2>
								<p>{useCase}</p>
								{whyMatters && (
									<>
										<h3>{t.whyItMatters}</h3>
										<p>{whyMatters}</p>
									</>
								)}
								<section class="inline-role-card" aria-labelledby={`inline-role-title-${lang}`}>
									<h2 id={`inline-role-title-${lang}`}>{t.myRole}</h2>
									{roleIntro && <p>{roleIntro}</p>}
									<ul>
										{p.role.map((item) => <li>{item}</li>)}
									</ul>
								</section>
							</div>
							<div class="scope-panels">
								{blockers && (
									<article>
										<h3>{t.whatWasSlowing}</h3>
										<ul>
											{blockers.map((item) => <li>{item}</li>)}
										</ul>
									</article>
								)}
								{deliveryScope && (
									<article>
										<h3>{t.whatWasBuilt}</h3>
										<ul>
											{deliveryScope.map((item) => <li>{item}</li>)}
										</ul>
