---
import Layout from '../../layouts/Layout.astro';
import { levelProjects } from '../../data/levelProjects';

export function getStaticPaths() {
	return levelProjects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const projectIndex = levelProjects.findIndex((item) => item.slug === project.slug);
const previousProject = projectIndex > 0 ? levelProjects[projectIndex - 1] : null;
const nextProject =
	projectIndex >= 0 && projectIndex < levelProjects.length - 1
		? levelProjects[projectIndex + 1]
		: null;
const metadata = 'metadata' in project ? project.metadata : null;
const contributionNote = 'contributionNote' in project ? project.contributionNote : null;
const projectContext = 'projectContext' in project ? project.projectContext : null;
const systemOverview = 'systemOverview' in project ? project.systemOverview : null;
const roleIntro = 'roleIntro' in project ? project.roleIntro : null;
const processTitle = 'processTitle' in project ? project.processTitle : 'Process';
const keyFeaturesTitle = 'keyFeaturesTitle' in project ? project.keyFeaturesTitle : 'Key Features';
const outcomeTitle = 'outcomeTitle' in project ? project.outcomeTitle : 'Outcome / Level Complete';
const artifactsIntro = 'artifactsIntro' in project ? project.artifactsIntro : null;
const artifactPlaceholders = 'artifactPlaceholders' in project ? project.artifactPlaceholders : null;
---

<Layout title={`${project.title} | Lizzy World`}>
	<main class="level-detail-screen" aria-labelledby="project-title">
		<a class="back-link" href="/levels" aria-label="Back to Levels map">Back</a>

		<header class:list={['project-hero', metadata && 'project-hero-grid']}>
			<div>
				<p class="level-label">{project.level}</p>
				<h1 id="project-title">{project.title}</h1>
				<p>{project.intro}</p>
				<ul class="tag-list" aria-label="Project tags">
					{project.tags.map((tag) => <li>{tag}</li>)}
				</ul>
				{
					metadata && (
						<div class="hero-actions" aria-label="Project actions">
							<a href="#quest-artifacts-title">View Screens</a>
							<a href="/levels">Back to Map</a>
						</div>
					)
				}
			</div>
			{
				metadata && (
					<aside class="level-meta-card" aria-label="Level metadata">
						<p class="unlock-badge">Level Unlocked</p>
						{metadata.map((item) => (
							<div>
								<span>{item.label}</span>
								<strong>{item.value}</strong>
							</div>
						))}
					</aside>
				)
			}
		</header>

		<section class="quest-window">
			<div class="window-bar">
				<span></span>
				<span></span>
				<span></span>
			</div>

			<div class="window-body">
				{
					contributionNote && (
						<section class="content-block contribution-note">
							<h2>Contribution Note</h2>
							{contributionNote.map((paragraph) => <p>{paragraph}</p>)}
						</section>
					)
				}

				<section class="content-block">
					<h2>Mission Brief</h2>
					{project.missionBrief.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<section class="content-block">
					<h2>Problem</h2>
					{project.problem.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				{
					projectContext && (
						<section class="content-block project-context-block">
							<div>
								<h2>Project Context</h2>
								{projectContext.map((paragraph) => <p>{paragraph}</p>)}
							</div>
							{
								systemOverview && (
									<div class="system-overview-card" aria-label="Project system overview">
										{systemOverview.map((item) => (
											<span>{item}</span>
										))}
									</div>
								)
							}
						</section>
					)
				}

				<div class="two-column">
					<section class="content-block">
						<h2>My Role</h2>
						{roleIntro && <p>{roleIntro}</p>}
						<ul>
							{project.role.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="content-block achievement-card">
						<h2>Achievement Unlocked</h2>
						<p>{project.achievement}</p>
					</section>
				</div>

				<section class="content-block">
					<h2>{processTitle}</h2>
					<div class="process-grid">
						{
							project.process.map((step, index) => (
								<article>
									<p class="step-number">0{index + 1}</p>
									<h3>{step.title}</h3>
									{step.body.map((paragraph) => <p>{paragraph}</p>)}
								</article>
							))
						}
					</div>
				</section>

				{
					project.slug === 'learning-path-platform' && (
						<section class="content-block quest-artifacts" aria-labelledby="quest-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Evidence Collected</p>
								<h2 id="quest-artifacts-title">Quest Artifacts</h2>
								<p>
									Research and design artifacts that shaped the learning experience.
								</p>
							</div>

							<div class="artifact-feature-grid">
								<article class="artifact-card">
									<span class="artifact-label">Research Artifact</span>
									<h3>User Personas</h3>
									<p>
										User personas helped identify educator profiles based on digital
										confidence, motivation, access to technology, frustrations, and available
										time.
									</p>
									<div class="persona-gallery" aria-label="User persona research artifacts">
										<a
											class="persona-preview persona-preview-maria"
											href="/img/levels/learning-path/persona-maria.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open Maria user persona artifact"
										>
											<img
												src="/img/levels/learning-path/persona-maria.png"
												alt="User persona research artifact for Maria, educator profile"
												loading="lazy"
											/>
										</a>
										<a
											class="persona-preview persona-preview-alejandro"
											href="/img/levels/learning-path/persona-alejandro.png"
											target="_blank"
											rel="noreferrer"
											aria-label="Open Alejandro user persona artifact"
										>
											<img
												src="/img/levels/learning-path/persona-alejandro.png"
												alt="User persona research artifact for Alejandro, educator profile"
												loading="lazy"
											/>
										</a>
									</div>
								</article>

								<article class="artifact-card">
									<span class="artifact-label">Research Artifact</span>
									<h3>Customer Journey Map</h3>
									<p>
										The journey map helped identify moments of friction, motivation, and
										support across the educator's learning experience.
									</p>
									<a
										class="artifact-image-frame journey-frame"
										href="/img/levels/learning-path/customer-journey-map.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open full customer journey map"
									>
										<img
											src="/img/levels/learning-path/customer-journey-map.png"
											alt="Customer journey map for educator learning experience"
											loading="lazy"
										/>
									</a>
								</article>
							</div>

							<article class="artifact-card artifact-card-wide final-screens-card">
								<span class="artifact-label">Final Evidence</span>
								<h3>Final Screens</h3>
								<p>
									The mockups translated the research into a clearer, more accessible platform
									experience focused on personalized routes, resources, and progress tracking.
								</p>
								<div class="mockup-showcase">
									<a
										class="mockup-frame phone-frame phone-left"
										href="/img/levels/learning-path/final-screen-mobile-route.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform route mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-mobile-route.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
									<a
										class="showcase-main"
										href="/img/levels/learning-path/final-screen-tablet-resource.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform tablet mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-tablet-resource.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
									<a
										class="mockup-frame phone-frame phone-right"
										href="/img/levels/learning-path/final-screen-mobile-feedback.png"
										target="_blank"
										rel="noreferrer"
										aria-label="Open final platform feedback mockup screen"
									>
										<img
											src="/img/levels/learning-path/final-screen-mobile-feedback.png"
											alt="Final platform mockup screen"
											loading="lazy"
										/>
									</a>
								</div>
							</article>
						</section>
					)
				}

				{
					project.slug === 'digital-entertainment-redesign' && (
						<section class="content-block quest-artifacts entertainment-artifacts" aria-labelledby="entertainment-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Final Evidence</p>
								<h2 id="entertainment-artifacts-title">Quest Artifacts</h2>
								<p>
									Mobile mockups showing how the redesign expanded discovery, wallet actions,
									and casino cross-navigation without breaking the core purchase flow.
								</p>
							</div>

							<div class="entertainment-mockup-grid" aria-label="Digital entertainment redesign mockups">
								<a
									class="entertainment-mockup entertainment-mockup-primary"
									href="/img/levels/digital-entertainment/mockup-home-casino.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open home and casino discovery mockup"
								>
									<img
										src="/img/levels/digital-entertainment/mockup-home-casino.png"
										alt="Mobile app redesign mockup showing home screen, casino discovery, and promotional modules"
										loading="lazy"
									/>
								</a>
								<a
									class="entertainment-mockup entertainment-mockup-secondary"
									href="/img/levels/digital-entertainment/mockup-purchase-wallet.png"
									target="_blank"
									rel="noreferrer"
									aria-label="Open purchase confirmation and wallet mockup"
								>
									<img
										src="/img/levels/digital-entertainment/mockup-purchase-wallet.png"
										alt="Mobile app redesign mockup showing purchase confirmation, wallet, and casino entry points"
										loading="lazy"
									/>
								</a>
							</div>
						</section>
					)
				}

				{
					artifactPlaceholders && (
						<section class="content-block quest-artifacts hiring-artifacts" aria-labelledby="quest-artifacts-title">
							<div class="artifacts-heading">
								<p class="artifact-eyebrow">Evidence Collected</p>
								<h2 id="quest-artifacts-title">Quest Artifacts</h2>
								<p>{artifactsIntro}</p>
							</div>

							<div class="hiring-artifact-grid">
								{artifactPlaceholders.map((artifact, index) => (
									<article class="artifact-card hiring-artifact-card">
										<span class="artifact-label">{index === 3 ? 'Screen Contribution' : 'Research Artifact'}</span>
										<h3>{artifact.title}</h3>
										<p>{artifact.description}</p>
										<div class="artifact-placeholder" role="img" aria-label={artifact.alt}>
											<span>{artifact.title}</span>
											<small>Image slot ready</small>
										</div>
									</article>
								))}
							</div>
						</section>
					)
				}

				<div class="two-column">
					<section class="content-block">
						<h2>Design Decisions</h2>
						<ul>
							{project.designDecisions.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="content-block">
						<h2>{keyFeaturesTitle}</h2>
						<ul>
							{project.keyFeatures.map((item) => <li>{item}</li>)}
						</ul>
					</section>
				</div>

				<section class="content-block outcome">
					<h2>{outcomeTitle}</h2>
					{project.outcome.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<nav class="level-nav" aria-label="Level navigation">
					<a href="/levels">Back to Map</a>
					{previousProject && <a href={`/levels/${previousProject.slug}`}>Previous Level</a>}
					{nextProject && <a href={`/levels/${nextProject.slug}`}>Next Level</a>}
					<a href="/contact">Contact Player</a>
				</nav>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		background: #f4f4de;
	}

	.level-detail-screen {
		min-height: 100svh;
		padding: clamp(84px, 10vh, 112px) clamp(18px, 5vw, 70px) 54px;
		background: #f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}

	.project-hero,
	.quest-window {
		width: min(100%, 1080px);
		margin-inline: auto;
	}

	.project-hero {
		margin-bottom: 32px;
	}

	.project-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
		gap: clamp(24px, 4vw, 48px);
		align-items: end;
	}

	.level-label {
		margin: 0 0 8px;
		color: #f4a6bd;
		font-size: 0.88rem;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.project-hero h1 {
		margin: 0;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(3rem, 7vw, 5.8rem);
		line-height: 0.92;
	}

	.project-hero p:not(.level-label):not(.unlock-badge) {
		max-width: 760px;
		margin: 16px 0 0;
		color: #6b625d;
		font-size: clamp(1rem, 1.5vw, 1.15rem);
		line-height: 1.7;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 22px 0 0;
		padding: 0;
		list-style: none;
	}

	.tag-list li,
	.content-block li {
		border-radius: 999px;
		background: #fff0d6;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		padding: 8px 12px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 24px;
	}

	.hero-actions a,
	.level-nav a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 14px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.82rem;
		font-weight: 800;
		padding: 11px 22px;
		text-decoration: none;
		transition:
			box-shadow 180ms ease,
			transform 180ms ease,
			background 180ms ease;
	}

	.hero-actions a:hover,
	.level-nav a:hover {
		background: #f9e4e8;
		box-shadow: 0 8px 20px rgba(244, 166, 189, 0.25);
		transform: translateY(-2px);
	}

	.level-meta-card {
		border: 6px solid #d6c6f5;
		border-radius: 28px;
		background:
			radial-gradient(circle at 82% 14%, rgba(249, 231, 163, 0.8) 0 9%, transparent 10%),
			linear-gradient(135deg, #ffffff, #fff7f1);
		box-shadow: 0 18px 38px rgba(214, 198, 245, 0.22);
		padding: 22px;
	}

	.unlock-badge {
		width: fit-content;
		margin: 0 0 18px;
		border-radius: 999px;
		background: #f9e4e8;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 1rem;
		font-weight: 800;
		padding: 8px 14px;
	}

	.level-meta-card div {
		display: grid;
		gap: 5px;
		border-top: 2px dashed rgba(214, 198, 245, 0.75);
		padding: 14px 0;
	}

	.level-meta-card div:last-child {
		padding-bottom: 0;
	}

	.level-meta-card span {
		color: #7b716c;
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.level-meta-card strong {
		color: #4a403a;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.quest-window {
		overflow: hidden;
		border: 10px solid #d6c6f5;
		border-radius: 30px;
		background: #ffffff;
		box-shadow: 0 18px 40px rgba(214, 198, 245, 0.24);
	}

	.window-bar {
		display: flex;
		justify-content: flex-end;
		gap: 14px;
		min-height: 42px;
		padding: 11px 22px;
		background: #cdb4f5;
	}

	.window-bar span {
		width: 18px;
		height: 18px;
		border-radius: 50%;
	}

	.window-bar span:nth-child(1) {
		background: #f9e7a3;
	}

	.window-bar span:nth-child(2) {
		background: #b8f2a3;
	}

	.window-bar span:nth-child(3) {
		background: #f9c4d2;
	}

	.window-body {
		display: grid;
		gap: 30px;
		padding: clamp(24px, 4vw, 44px);
	}

	.content-block h2 {
		margin: 0 0 14px;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		line-height: 1;
	}

	.content-block h3 {
		margin: 0 0 10px;
		color: #4a403a;
		font-size: 1rem;
	}

	.content-block p {
		margin: 0 0 14px;
		color: #6b625d;
		font-size: 0.96rem;
		line-height: 1.8;
	}

	.content-block p:last-child {
		margin-bottom: 0;
	}

	.content-block ul {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.two-column {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 26px;
	}

	.contribution-note {
		border: 5px solid #f9e7a3;
		border-radius: 24px;
		background:
			radial-gradient(circle at 96% 18%, rgba(168, 216, 112, 0.55) 0 8%, transparent 9%),
			#fffdf3;
		padding: 24px;
	}

	.project-context-block {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(240px, 330px);
		gap: 24px;
		align-items: start;
	}

	.system-overview-card {
		display: grid;
		gap: 12px;
		border: 5px solid #bfd7ed;
		border-radius: 24px;
		background: #f7fbff;
		padding: 20px;
	}

	.system-overview-card span {
		border-radius: 999px;
		background: #ffffff;
		color: #4a403a;
		font-size: 0.82rem;
		font-weight: 800;
		padding: 10px 12px;
		box-shadow: inset 0 0 0 2px rgba(191, 215, 237, 0.75);
	}

	.achievement-card {
		border: 6px solid #a8d870;
		border-radius: 24px;
		padding: 24px;
		background: #fbfff5;
	}

	.achievement-card p {
		color: #4a403a;
		font-weight: 800;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.process-grid article {
		border: 4px solid #f9e4e8;
		border-radius: 22px;
		padding: 20px;
		background: #fffdf8;
	}

	.step-number {
		color: #f4a6bd !important;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 1.5rem !important;
		font-weight: 800;
		line-height: 1;
	}

	.quest-artifacts {
		display: grid;
		gap: 24px;
		border-top: 2px dashed #d6c6f5;
		padding-top: 30px;
	}

	.artifacts-heading {
		max-width: 680px;
	}

	.artifact-eyebrow {
		margin: 0 0 8px !important;
		color: #f4a6bd !important;
		font-size: 0.78rem !important;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.artifacts-heading p:not(.artifact-eyebrow) {
		margin: 0;
		font-size: 0.96rem;
		line-height: 1.7;
	}

	.artifact-feature-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 22px;
	}

	.artifact-card {
		display: grid;
		align-content: start;
		gap: 14px;
		border: 2px solid #d6c6f5;
		border-radius: 24px;
		background: #fff7f1;
		box-shadow: 0 12px 30px rgba(214, 198, 245, 0.18);
		padding: clamp(18px, 2.5vw, 24px);
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.artifact-card:hover {
		box-shadow: 0 18px 38px rgba(214, 198, 245, 0.24);
		transform: translateY(-3px);
	}

	.artifact-card h3 {
		margin: 0;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.55rem, 2.6vw, 2rem);
		line-height: 1;
	}

	.artifact-card p {
		margin: 0;
		color: #6b625d;
		font-size: 0.94rem;
		line-height: 1.7;
	}

	.persona-gallery {
		display: grid;
		gap: 18px;
		margin-top: 4px;
	}

	.persona-preview {
		display: block;
		overflow: hidden;
		border: 2px solid rgba(214, 198, 245, 0.88);
