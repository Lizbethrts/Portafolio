---
import Layout from '../../layouts/Layout.astro';
import { levelProjects } from '../../data/levelProjects';

export function getStaticPaths() {
	return levelProjects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Lizzy World`}>
	<main class="level-detail-screen" aria-labelledby="project-title">
		<a class="back-link" href="/levels" aria-label="Back to Levels map">Back</a>

		<header class="project-hero">
			<p class="level-label">{project.level}</p>
			<h1 id="project-title">{project.title}</h1>
			<p>{project.intro}</p>
			<ul class="tag-list" aria-label="Project tags">
				{project.tags.map((tag) => <li>{tag}</li>)}
			</ul>
		</header>

		<section class="quest-window">
			<div class="window-bar">
				<span></span>
				<span></span>
				<span></span>
			</div>

			<div class="window-body">
				<section class="content-block">
					<h2>Mission Brief</h2>
					{project.missionBrief.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<section class="content-block">
					<h2>Problem</h2>
					{project.problem.map((paragraph) => <p>{paragraph}</p>)}
				</section>

				<div class="two-column">
					<section class="content-block">
						<h2>My Role</h2>
						<ul>
							{project.role.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="content-block achievement-card">
						<h2>Achievement Unlocked</h2>
						<p>{project.achievement}</p>
					</section>
				</div>

				<section class="content-block">
					<h2>Process</h2>
					<div class="process-grid">
						{
							project.process.map((step, index) => (
								<article>
									<p class="step-number">0{index + 1}</p>
									<h3>{step.title}</h3>
									{step.body.map((paragraph) => <p>{paragraph}</p>)}
								</article>
							))
						}
					</div>
				</section>

				<div class="two-column">
					<section class="content-block">
						<h2>Design Decisions</h2>
						<ul>
							{project.designDecisions.map((item) => <li>{item}</li>)}
						</ul>
					</section>

					<section class="content-block">
						<h2>Key Features</h2>
						<ul>
							{project.keyFeatures.map((item) => <li>{item}</li>)}
						</ul>
					</section>
				</div>

				<section class="content-block outcome">
					<h2>Outcome / Level Complete</h2>
					{project.outcome.map((paragraph) => <p>{paragraph}</p>)}
				</section>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		background: #f4f4de;
	}

	.level-detail-screen {
		min-height: 100svh;
		padding: clamp(84px, 10vh, 112px) clamp(18px, 5vw, 70px) 54px;
		background: #f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		text-decoration: none;
	}

	.project-hero,
	.quest-window {
		width: min(100%, 1080px);
		margin-inline: auto;
	}

	.project-hero {
		margin-bottom: 32px;
	}

	.level-label {
		margin: 0 0 8px;
		color: #f4a6bd;
		font-size: 0.88rem;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	.project-hero h1 {
		margin: 0;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(3rem, 7vw, 5.8rem);
		line-height: 0.92;
	}

	.project-hero > p:not(.level-label) {
		max-width: 760px;
		margin: 16px 0 0;
		color: #6b625d;
		font-size: clamp(1rem, 1.5vw, 1.15rem);
		line-height: 1.7;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 22px 0 0;
		padding: 0;
		list-style: none;
	}

	.tag-list li,
	.content-block li {
		border-radius: 999px;
		background: #fff0d6;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
		padding: 8px 12px;
	}

	.quest-window {
		overflow: hidden;
		border: 10px solid #d6c6f5;
		border-radius: 30px;
		background: #ffffff;
		box-shadow: 0 18px 40px rgba(214, 198, 245, 0.24);
	}

	.window-bar {
		display: flex;
		justify-content: flex-end;
		gap: 14px;
		min-height: 42px;
		padding: 11px 22px;
		background: #cdb4f5;
	}

	.window-bar span {
		width: 18px;
		height: 18px;
		border-radius: 50%;
	}

	.window-bar span:nth-child(1) {
		background: #f9e7a3;
	}

	.window-bar span:nth-child(2) {
		background: #b8f2a3;
	}

	.window-bar span:nth-child(3) {
		background: #f9c4d2;
	}

	.window-body {
		display: grid;
		gap: 30px;
		padding: clamp(24px, 4vw, 44px);
	}

	.content-block h2 {
		margin: 0 0 14px;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		line-height: 1;
	}

	.content-block h3 {
		margin: 0 0 10px;
		color: #4a403a;
		font-size: 1rem;
	}

	.content-block p {
		margin: 0 0 14px;
		color: #6b625d;
		font-size: 0.96rem;
		line-height: 1.8;
	}

	.content-block p:last-child {
		margin-bottom: 0;
	}

	.content-block ul {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.two-column {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 26px;
	}

	.achievement-card {
		border: 6px solid #a8d870;
		border-radius: 24px;
		padding: 24px;
		background: #fbfff5;
	}

	.achievement-card p {
		color: #4a403a;
		font-weight: 800;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.process-grid article {
		border: 4px solid #f9e4e8;
		border-radius: 22px;
		padding: 20px;
		background: #fffdf8;
	}

	.step-number {
		color: #f4a6bd !important;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 1.5rem !important;
		font-weight: 800;
		line-height: 1;
	}

	.outcome {
		border-top: 2px dashed #d6c6f5;
		padding-top: 28px;
	}

	@media (max-width: 760px) {
		.level-detail-screen {
			padding-inline: 14px;
		}

		.two-column,
		.process-grid {
			grid-template-columns: 1fr;
		}

		.quest-window {
			border-width: 7px;
			border-radius: 24px;
		}
	}
</style>
