<script>
	document.querySelectorAll('[data-level-process-carousel]').forEach((processCarousel) => {
		if (!(processCarousel instanceof HTMLElement)) return;
		const controls = processCarousel.parentElement?.querySelector('.carousel-controls');
		const processPrevButton = controls?.querySelector('[data-process-prev]');
		const processNextButton = controls?.querySelector('[data-process-next]');

		const scrollProcessCarousel = (direction: number) => {
			const firstCard = processCarousel.querySelector('article');
			const cardWidth = firstCard instanceof HTMLElement ? firstCard.offsetWidth : 360;
			const gap = parseFloat(getComputedStyle(processCarousel).columnGap || '0');

			processCarousel.scrollBy({
				left: direction * (cardWidth + gap),
				behavior: 'smooth',
			});
		};

		processPrevButton?.addEventListener('click', () => scrollProcessCarousel(-1));
		processNextButton?.addEventListener('click', () => scrollProcessCarousel(1));
	});

	function applyProjectLang(lang: string) {
		document.querySelectorAll('[data-plang]').forEach((el) => {
			if (el instanceof HTMLElement) el.hidden = el.getAttribute('data-plang') !== lang;
		});
	}
	const savedProjectLang = (typeof localStorage !== 'undefined' && localStorage.getItem('lizzy-lang')) || 'en';
	applyProjectLang(savedProjectLang);
	document.addEventListener('langchange', (e) => applyProjectLang((e as CustomEvent).detail.lang));

	const lightboxDialog = document.querySelector('.lightbox-dialog');
	const lightboxImage = lightboxDialog?.querySelector('[data-lightbox-image]');
	const lightboxCaption = lightboxDialog?.querySelector('[data-lightbox-caption]');

	document.querySelectorAll('[data-lightbox-trigger], .artifact-lightbox-trigger').forEach((trigger) => {
		trigger.addEventListener('click', () => {
			if (!(lightboxDialog instanceof HTMLDialogElement) || !(lightboxImage instanceof HTMLImageElement)) return;
			lightboxImage.src = trigger.getAttribute('data-lightbox-src') || '';
			lightboxImage.alt = trigger.getAttribute('data-lightbox-alt') || '';
			if (lightboxCaption instanceof HTMLElement) {
				lightboxCaption.textContent = trigger.getAttribute('data-lightbox-caption') || '';
			}
			lightboxDialog.showModal();
		});
	});

	document.querySelector('[data-lightbox-close]')?.addEventListener('click', () => {
		if (lightboxDialog instanceof HTMLDialogElement) lightboxDialog.close();
	});

	lightboxDialog?.addEventListener('click', (event) => {
		if (event.target === lightboxDialog && lightboxDialog instanceof HTMLDialogElement) lightboxDialog.close();
	});
</script>

