---
import Layout from '../layouts/Layout.astro';

const metadata = [
	['STATUS', 'UNLOCKED'],
	['TYPE', 'Creative Archive'],
	['MODE', 'Experimental'],
];

const photoGalleryItems = [
	{
		src: '/images/secret-lab/photo-01.jpg',
		alt: 'Photography archive preview',
		title: 'Photography Study 01',
	},
	{
		src: '/images/secret-lab/photo-02.jpg',
		alt: 'Photography archive preview',
		title: 'Photography Study 02',
	},
	{
		src: '/images/secret-lab/product-01.jpg',
		alt: 'Product photography preview',
		title: 'Product Shot Study',
	},
	{
		src: '/images/secret-lab/audiovisual-01.jpg',
		alt: 'Audiovisual experiment preview',
		title: 'Character Edit',
	},
	{
		src: '/images/secret-lab/audiovisual-02.jpg',
		alt: 'Digital editing experiment preview',
		title: 'Visual Storytelling Edit',
	},
	{
		src: '/images/secret-lab/product-02.jpg',
		alt: 'Product composition preview',
		title: 'Campaign Composition',
	},
	{
		src: '/images/secret-lab/audiovisual-03.jpg',
		alt: 'Retouching exercise preview',
		title: 'Retouching Study',
	},
];

const archiveCards = [
	{
		title: 'Photo & Audiovisual Archive',
		subtitle: 'Mood, composition, rhythm & visual storytelling',
		description:
			'A collection of photography and audiovisual explorations focused on mood, color, light, atmosphere, editing, sound, and small visual stories hidden in everyday moments.',
		status: 'gallery unlocked',
		cta: 'Open Archive',
		href: '#photo-audiovisual-archive',
		accent: 'photo',
		tags: ['Photography', 'Product Shots', 'City Details', 'Video', 'Sound', 'Editing', 'Atmosphere'],
		images: photoGalleryItems,
	},
	{
		title: 'Interactive Tech',
		subtitle: 'Games, VR & haptic experiences',
		description:
			'Experiments exploring interaction beyond the screen through gameplay, immersive environments, spatial experiences, and physical feedback.',
		status: 'prototype unlocked',
		cta: 'Open Experiments',
		href: '#interactive-tech',
		accent: 'tech',
		tags: ['Unity', 'VR', 'Haptics', 'Game Design', 'Interaction', 'Prototyping'],
		images: [
			{ src: '/images/secret-lab/vr-01.jpg', alt: 'VR experiment preview' },
			{ src: '/images/secret-lab/haptic-01.jpg', alt: 'Haptic interaction experiment preview' },
			{ src: '/images/secret-lab/game-01.jpg', alt: 'Game prototype preview' },
		],
	},
];

const navLinks = [
	['Back to Map', '/'],
	['View Inventory', '/inventory'],
	['Talk to NPC', '/contact'],
];
---

<Layout title="Secret Lab | Lizzy World" frame>
	<main class="lab-screen" aria-labelledby="lab-title">
		<a class="back-link" href="/" aria-label="Back to Lizzy World menu">Back</a>

		<header class="lab-hero">
			<div class="screen-icon" aria-hidden="true">
				<img src="/img/menu/5.png" alt="" width="46" height="46" />
			</div>
			<div class="hero-copy">
				<p class="pixel-kicker">Hidden Area</p>
				<h1 id="lab-title">Secret Lab</h1>
				<p class="hero-subtitle">Creative side quests &amp; experimental worlds</p>
				<p>
					A hidden gallery for photography, audiovisual experiments, and interactive tech
					explorations that shaped how I see, design, and build digital experiences.
				</p>
			</div>
			<dl class="metadata-panel" aria-label="Secret Lab metadata">
				{metadata.map(([label, value]) => (
					<div>
						<dt>{label}</dt>
						<dd>{value}</dd>
					</div>
				))}
			</dl>
		</header>

		<section class="archive-grid" aria-label="Secret Lab archive areas">
			{archiveCards.map((card) => (
				<article id={card.href.replace('#', '')} class:list={['archive-card', `archive-card-${card.accent}`]}>
					{card.accent === 'photo' ? (
						<div class="photo-gallery-panel" aria-label={`${card.title} preview`}>
							<span class="file-label">{card.status}</span>
							<div class="photo-gallery">
								{card.images.slice(0, 4).map((image, index) => (
									<button
										class:list={['photo-frame', index === 0 && 'photo-frame-featured']}
										type="button"
										data-gallery-open
										data-gallery-index={index}
										aria-label={`Open ${image.title} in gallery`}
									>
										<img src={image.src} alt={image.alt} loading="lazy" />
									</button>
								))}
							</div>
						</div>
					) : (
						<div class="thumbnail-panel" aria-label={`${card.title} preview`}>
							<span class="file-label">{card.status}</span>
							<div class="thumbnail-grid">
								{card.images.map((image, index) => (
									<figure class:list={['thumb', index === 0 && 'thumb-large']}>
										<img src={image.src} alt={image.alt} loading="lazy" onerror="this.hidden=true" />
										<span aria-hidden="true">{index + 1}</span>
									</figure>
								))}
							</div>
						</div>
					)}

					<div class="archive-copy">
						<span class="status-label">SIDE QUEST</span>
						<h2>{card.title}</h2>
						<p class="card-subtitle">{card.subtitle}</p>
						<p>{card.description}</p>
						<ul class="tag-list" aria-label={`${card.title} tags`}>
							{card.tags.map((tag) => <li>{tag}</li>)}
						</ul>
						{card.accent === 'photo' ? (
							<button class="lab-button" type="button" data-gallery-open data-gallery-index="0">
								{card.cta}
							</button>
						) : (
							<a class="lab-button" href={card.href}>{card.cta}</a>
						)}
					</div>
				</article>
			))}
		</section>

		<section class="lab-note" aria-labelledby="lab-note-title">
			<div class="note-bar" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</div>
			<div class="note-body">
				<p class="pixel-kicker">Archive Note</p>
				<h2 id="lab-note-title">Why Secret Lab exists</h2>
				<p>
					Not every creative exploration becomes a full case study, but each one helps me
					understand image, movement, interaction, and emotion in a different way.
				</p>
			</div>
		</section>

		<nav class="lab-nav" aria-label="Secret Lab navigation">
			{navLinks.map(([label, href]) => (
				<a class="lab-button" href={href}>{label}</a>
			))}
		</nav>

		<dialog class="gallery-dialog" aria-label="Photo and audiovisual gallery">
			<div class="gallery-modal">
				<header class="gallery-header">
					<div>
						<p class="pixel-kicker">Archive Gallery</p>
						<h2>Photo &amp; Audiovisual Archive</h2>
					</div>
					<button class="gallery-close" type="button" data-gallery-close aria-label="Close gallery">
						Close
					</button>
				</header>

				<div class="gallery-overview" data-gallery-overview aria-label="All archive photos">
					{photoGalleryItems.map((item, index) => (
						<button
							class="masonry-item"
							type="button"
							data-gallery-detail-open
							data-gallery-index={index}
							aria-label={`View ${item.title} closer`}
						>
							<img src={item.src} alt={item.alt} loading="lazy" />
							<span>{item.title}</span>
						</button>
					))}
				</div>

				<div class="gallery-detail" data-gallery-detail hidden>
					<button class="secondary-button gallery-back" type="button" data-gallery-back>
						Back to Gallery
					</button>
				<div class="gallery-stage">
					<button class="gallery-arrow" type="button" data-gallery-prev aria-label="Previous image">
						‹
					</button>
					<figure class="gallery-figure">
						<img data-gallery-image src={photoGalleryItems[0].src} alt={photoGalleryItems[0].alt} />
						<figcaption>
							<span data-gallery-title>{photoGalleryItems[0].title}</span>
							<span data-gallery-count>1 / {photoGalleryItems.length}</span>
						</figcaption>
					</figure>
					<button class="gallery-arrow" type="button" data-gallery-next aria-label="Next image">
						›
					</button>
				</div>

				<div class="gallery-strip" aria-label="Gallery thumbnails">
					{photoGalleryItems.map((item, index) => (
						<button
							type="button"
							data-gallery-thumb
							data-gallery-index={index}
							aria-label={`View ${item.title}`}
							aria-current={index === 0 ? 'true' : 'false'}
						>
							<img src={item.src} alt="" loading="lazy" />
						</button>
					))}
				</div>
				</div>
			</div>
		</dialog>

		<script type="application/json" id="photo-gallery-data" set:html={JSON.stringify(photoGalleryItems)} />
	</main>
</Layout>

<script>
	const galleryDataElement = document.getElementById('photo-gallery-data');
	const galleryItems = galleryDataElement ? JSON.parse(galleryDataElement.textContent ?? '[]') : [];
	const dialog = document.querySelector('.gallery-dialog');
	const galleryOverview = document.querySelector('[data-gallery-overview]');
	const galleryDetail = document.querySelector('[data-gallery-detail]');
	const galleryImage = document.querySelector('[data-gallery-image]');
	const galleryTitle = document.querySelector('[data-gallery-title]');
	const galleryCount = document.querySelector('[data-gallery-count]');
	const thumbButtons = Array.from(document.querySelectorAll('[data-gallery-thumb]'));
	let currentGalleryIndex = 0;

	const setGalleryItem = (index) => {
		if (!galleryItems.length || !galleryImage || !galleryTitle || !galleryCount) return;
		currentGalleryIndex = (index + galleryItems.length) % galleryItems.length;
		const item = galleryItems[currentGalleryIndex];
		galleryImage.setAttribute('src', item.src);
		galleryImage.setAttribute('alt', item.alt);
		galleryTitle.textContent = item.title;
		galleryCount.textContent = `${currentGalleryIndex + 1} / ${galleryItems.length}`;
		thumbButtons.forEach((button, buttonIndex) => {
			button.setAttribute('aria-current', buttonIndex === currentGalleryIndex ? 'true' : 'false');
		});
	};

	const showGalleryOverview = () => {
		if (galleryOverview instanceof HTMLElement) galleryOverview.hidden = false;
		if (galleryDetail instanceof HTMLElement) galleryDetail.hidden = true;
	};

	const showGalleryDetail = (index) => {
		setGalleryItem(index);
		if (galleryOverview instanceof HTMLElement) galleryOverview.hidden = true;
		if (galleryDetail instanceof HTMLElement) galleryDetail.hidden = false;
	};

	document.querySelectorAll('[data-gallery-open]').forEach((button) => {
		button.addEventListener('click', () => {
			showGalleryOverview();
			if (dialog instanceof HTMLDialogElement) dialog.showModal();
		});
	});

	document.querySelectorAll('[data-gallery-detail-open]').forEach((button) => {
		button.addEventListener('click', () => {
			showGalleryDetail(Number(button.getAttribute('data-gallery-index') ?? 0));
		});
	});

	document.querySelector('[data-gallery-back]')?.addEventListener('click', () => {
		showGalleryOverview();
	});

	document.querySelector('[data-gallery-close]')?.addEventListener('click', () => {
		if (dialog instanceof HTMLDialogElement) dialog.close();
	});

	document.querySelector('[data-gallery-prev]')?.addEventListener('click', () => {
		setGalleryItem(currentGalleryIndex - 1);
	});

	document.querySelector('[data-gallery-next]')?.addEventListener('click', () => {
		setGalleryItem(currentGalleryIndex + 1);
	});

	thumbButtons.forEach((button) => {
		button.addEventListener('click', () => {
			setGalleryItem(Number(button.getAttribute('data-gallery-index') ?? 0));
		});
	});

	dialog?.addEventListener('click', (event) => {
		if (event.target === dialog && dialog instanceof HTMLDialogElement) {
			dialog.close();
		}
	});

	document.addEventListener('keydown', (event) => {
		if (!(dialog instanceof HTMLDialogElement) || !dialog.open) return;
		if (galleryDetail instanceof HTMLElement && galleryDetail.hidden) return;
		if (event.key === 'ArrowLeft') setGalleryItem(currentGalleryIndex - 1);
		if (event.key === 'ArrowRight') setGalleryItem(currentGalleryIndex + 1);
	});
</script>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		overflow-x: hidden;
		background: #fff7f1;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.lab-screen {
		min-height: 100svh;
		overflow-x: clip;
		padding: clamp(104px, 13vh, 132px) clamp(22px, 6vw, 84px) 72px;
		background:
			radial-gradient(circle at 11% 18%, rgba(249, 228, 232, 0.72), transparent 24%),
			radial-gradient(circle at 88% 12%, rgba(191, 215, 237, 0.54), transparent 27%),
			#fff7f1;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.lab-hero,
	.archive-grid,
	.lab-note,
	.lab-nav {
		width: min(100%, 1180px);
		margin-inline: auto;
	}

	.lab-hero {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) minmax(280px, 420px);
		align-items: center;
		gap: clamp(28px, 5vw, 58px);
	}

	.screen-icon {
		display: grid;
		place-items: center;
		width: 86px;
		aspect-ratio: 1;
		border: 4px solid #d6c6f5;
		border-radius: 24px;
		background: #ffffff;
		box-shadow: 0 14px 30px rgba(214, 198, 245, 0.22);
	}

	.screen-icon img {
		width: 48px;
		height: 48px;
		object-fit: contain;
		image-rendering: pixelated;
	}

	.pixel-kicker,
	.file-label,
	.status-label {
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.pixel-kicker {
		margin: 0 0 10px;
		color: #f4a6bd;
		font-size: 1rem;
	}

	.hero-copy h1 {
		margin: 0;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(3.4rem, 8vw, 6.6rem);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 0.88;
	}

	.hero-subtitle {
		margin: 16px 0 14px;
		color: #4a403a;
		font-size: clamp(1.08rem, 1.7vw, 1.38rem);
		font-weight: 700;
	}

	.hero-copy > p:last-child,
	.archive-copy p,
	.note-body p {
		color: #7b716c;
		font-size: clamp(0.96rem, 1.15vw, 1.05rem);
		line-height: 1.75;
	}

	.metadata-panel {
		display: grid;
		gap: 14px;
		margin: 0;
		padding: 26px;
		border: 5px solid #d6c6f5;
		border-radius: 30px;
		background: rgba(255, 255, 255, 0.74);
		box-shadow: 0 18px 42px rgba(214, 198, 245, 0.2);
	}

	.metadata-panel div {
		padding: 13px 16px;
		border-radius: 18px;
		background: #fff7f1;
	}

	.metadata-panel dt {
		color: #7b716c;
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.metadata-panel dd {
		margin: 6px 0 0;
		color: #4a403a;
		font-size: 1rem;
		font-weight: 700;
	}

	.archive-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
		align-items: stretch;
		gap: clamp(24px, 4vw, 34px);
		margin-top: clamp(74px, 12vh, 112px);
	}

	.archive-card {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 24px;
		min-width: 0;
		padding: clamp(22px, 3vw, 28px);
		border: 2px solid #d6c6f5;
		border-radius: 26px;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 14px 34px rgba(214, 198, 245, 0.18);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.archive-card:hover {
		box-shadow: 0 20px 44px rgba(214, 198, 245, 0.26);
		transform: translateY(-4px);
	}

	.archive-card-photo {
		grid-row: span 2;
	}

	.photo-gallery-panel {
		position: relative;
		overflow: hidden;
		padding: 18px;
		border: 2px solid rgba(214, 198, 245, 0.95);
		border-radius: 24px;
		background: #ffffff;
	}

	.photo-gallery {
		display: grid;
		grid-template-columns: minmax(170px, 0.72fr) minmax(0, 0.9fr);
		grid-template-rows: repeat(2, minmax(0, 1fr));
		gap: 14px;
		width: min(100%, 760px);
		margin-top: 18px;
		margin-inline: auto;
	}

	.photo-frame {
		display: grid;
		place-items: center;
		min-width: 0;
		overflow: hidden;
		margin: 0;
		padding: 0;
		aspect-ratio: 4 / 3;
		max-height: 180px;
		border: 0;
		border-radius: 0;
		background: transparent;
		color: inherit;
		cursor: pointer;
		font: inherit;
		box-shadow: none;
	}

	.photo-frame-featured {
		grid-row: 1 / span 2;
		aspect-ratio: 3 / 4;
		max-height: 380px;
	}

	.photo-frame img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 16px;
		background: transparent;
		transition: transform 220ms ease;
	}

	.archive-card-photo:hover .photo-frame img {
		transform: scale(1.015);
	}

	.photo-frame:focus-visible {
		outline: 3px solid #f4a6bd;
		outline-offset: 4px;
	}

	.thumbnail-panel {
		position: relative;
		min-height: 260px;
		overflow: hidden;
		padding: 18px;
		border: 2px dashed rgba(214, 198, 245, 0.9);
		border-radius: 24px;
		background:
			linear-gradient(135deg, rgba(249, 228, 232, 0.82), rgba(255, 247, 241, 0.94)),
			#ffffff;
	}

	.archive-card-tech .thumbnail-panel {
		background:
			linear-gradient(135deg, rgba(191, 215, 237, 0.82), rgba(168, 216, 112, 0.22)),
			#ffffff;
	}

	.file-label,
	.status-label {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		justify-content: center;
		padding: 6px 12px;
		border-radius: 999px;
		background: #f9e4e8;
		color: #4a403a;
		font-size: 0.78rem;
	}

	.file-label {
		position: relative;
		z-index: 2;
		background: #ffffff;
		box-shadow: 0 8px 18px rgba(214, 198, 245, 0.16);
	}

	.thumbnail-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		grid-auto-rows: 86px;
		gap: 12px;
		margin-top: 16px;
	}

	.thumb {
		position: relative;
		grid-column: span 3;
		min-width: 0;
		overflow: hidden;
		margin: 0;
		border: 2px solid #ffffff;
		border-radius: 18px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.22), rgba(74, 64, 58, 0.04)),
			#f9e7a3;
		box-shadow: 0 12px 24px rgba(74, 64, 58, 0.08);
	}

	.thumb-large {
		grid-column: span 6;
		grid-row: span 2;
	}

	.archive-card-tech .thumb {
		background: #bfd7ed;
	}

	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.16;
		filter: saturate(0.75);
		transition:
			transform 220ms ease,
			opacity 220ms ease;
	}

	.thumb::before {
		position: absolute;
		inset: 0;
		z-index: 1;
		content: '';
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.36) 1px, transparent 1px),
			linear-gradient(rgba(255, 255, 255, 0.3) 1px, transparent 1px);
		background-size: 18px 18px;
	}

	.thumb span {
		position: absolute;
		right: 10px;
		bottom: 8px;
		z-index: 2;
		color: rgba(74, 64, 58, 0.42);
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 1.1rem;
		font-weight: 800;
	}

	.archive-card:hover .thumb img {
		opacity: 0.28;
		transform: scale(1.04);
	}

	.archive-copy {
		display: flex;
		min-width: 0;
		flex-direction: column;
		align-items: flex-start;
	}

	.archive-copy h2,
	.note-body h2 {
		margin: 14px 0 8px;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(2rem, 3vw, 2.8rem);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.card-subtitle {
		margin: 0 0 14px;
		color: #4a403a;
		font-weight: 700;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 18px 0 24px;
		padding: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 7px 11px;
		border: 1px solid #d6c6f5;
		border-radius: 999px;
		background: #fff7f1;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.lab-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 10px 24px;
		border: 0;
		border-radius: 14px;
		background: #f4a6bd;
		color: #4a403a;
		cursor: pointer;
		font-family: inherit;
		font-size: 0.82rem;
		font-weight: 800;
		transition:
			transform 170ms ease,
			background 170ms ease,
			box-shadow 170ms ease;
	}

	.lab-button:hover,
