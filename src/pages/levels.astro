---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Levels | Lizzy World">
	<main class="levels-screen" aria-labelledby="levels-title">
		<a class="back-link" href="/" aria-label="Back to Lizzy World menu">Back</a>

		<header class="levels-header">
			<div class="screen-icon" aria-hidden="true">
				<img src="/img/menu/1.png" alt="" width="46" height="46" />
			</div>
			<div>
				<h1 id="levels-title">Levels</h1>
				<p>Select a project level</p>
			</div>
		</header>

		<section class="map-tip map-tip-top" id="map-tip" role="status" aria-live="polite">
			<p class="tip-kicker">Hover a level</p>
			<h2>Project preview</h2>
			<p>Move over a level marker to see a quick summary.</p>
		</section>

		<section class="levels-playfield" aria-label="Interactive project map">
			<div class="map-column">
				<article class="level-help" aria-live="polite">
					<p class="panel-kicker">Select mode</p>
					<h2>Press a flag</h2>
					<p>Hover or click a flag to preview the mission. Use Enter Level inside the card to open the project.</p>
				</article>

				<div class="map-shell">
					<div class="map-sparkle map-sparkle-one" aria-hidden="true"></div>
					<div class="map-sparkle map-sparkle-two" aria-hidden="true"></div>
					<canvas id="level-map" aria-label="Three.js project world map"></canvas>
					<div class="map-hotspots" id="map-hotspots" aria-label="Keyboard project map controls"></div>
					<div class="floating-tip" id="floating-tip" role="dialog" aria-label="Project preview"></div>
				</div>
			</div>
		</section>

		<section class="levels-fallback" aria-labelledby="levels-fallback-title">
			<div class="fallback-heading">
				<p class="panel-kicker">All levels</p>
				<h2 id="levels-fallback-title">Project list</h2>
				<p>The same levels are available here for keyboard, mobile, and reduced-motion browsing.</p>
			</div>
			<div class="fallback-grid" id="fallback-grid"></div>
		</section>
	</main>
</Layout>

<script>
	import * as THREE from 'three';

	const projects = [
		{
			id: 'level-1',
			level: 'LEVEL_01',
			title: 'Learning Path Platform',
			type: 'EdTech UX / AI-Assisted Learning',
			mission:
				'Design a personalized learning platform for educators with limited time, low connectivity, and different levels of digital confidence.',
			role: 'UX Research · Learning Experience · Information Architecture',
			difficulty: '★★★★☆',
			rewards: [
				'User Personas',
				'Personalized Learning Routes',
				'AI Prompt Strategy',
				'Dashboard Thinking',
			],
			href: '/levels/learning-path-platform',
			flag: '/img/levels/flag-1.png',
			position: [-5.2, -1.7, 0],
			color: 0xf4a6bd,
		},
		{
			id: 'level-2',
			level: 'LEVEL_02',
			title: 'Digital Entertainment Redesign',
			type: 'Mobile App Redesign / Entertainment UX',
			mission:
				'Redesign an existing mobile app to make it more scalable, intuitive, trustworthy, and engaging across multiple entertainment sections.',
			role: 'UX Flow Design · Competitive Analysis · Mobile UI · A/B Testing',
			difficulty: '★★★★☆',
			rewards: [
				'App Redesign Strategy',
				'User Flow Optimization',
				'Cross-Discovery UX',
				'Scalable Components',
			],
			href: '/levels/digital-entertainment-redesign',
			flag: '/img/levels/flag-2.png',
			position: [-2.7, 0.6, 0],
			color: 0xa8d870,
		},
		{
			id: 'level-3',
			level: 'LEVEL_03',
			title: 'AI Hiring Platform',
			type: 'HR Tech / Gamified Recruitment UX',
			mission:
				'Design and refine selected screens for a gamified recruitment platform focused on skills-based matching and clearer hiring flows.',
			role: 'UI Screen Design / UX Flow Support / Visual Consistency',
			difficulty: '★★★☆☆',
			rewards: [
				'Screen Iteration',
				'HR Tech UX',
				'Visual Consistency',
				'Platform Flow Support',
			],
			href: '/levels/ai-hiring-platform',
			flag: '/img/levels/flag-3.png',
			position: [0.2, -0.8, 0],
			color: 0xd6c6f5,
		},
		{
			id: 'level-4',
			level: 'LEVEL_04',
			title: 'FIXIA Service Platform',
			type: 'Home Services / Marketplace UX',
			mission:
				'Create a clearer and safer way to diagnose household problems, compare verified technicians, and book trusted repair services.',
			role: 'UX Research / Service Flow / Mobile + Web UI',
			difficulty: '****-',
			rewards: [
				'Trust Signal Design',
				'AI Diagnosis Flow',
				'Verified Technician Cards',
				'Service Marketplace UX',
			],
			href: '/levels/fixia-service-platform',
			flag: '/img/levels/flag-4.png',
			position: [2.8, 1.2, 0],
			color: 0xf9e7a3,
		},
		{
			id: 'level-5',
			level: 'LEVEL_05',
			title: 'Coming Soon',
			type: 'Locked Project',
			mission: 'This project level is waiting for its mission brief.',
			role: 'New quest pending',
			difficulty: '☆☆☆☆☆',
			rewards: ['Coming Soon'],
			href: '',
			flag: '/img/levels/flag-5.png',
			position: [5.2, -1.1, 0],
			color: 0x9edff2,
		},
	];

	const canvas = document.querySelector('#level-map');
	const tip = document.querySelector('#map-tip');
	const floatingTip = document.querySelector('#floating-tip');
	const hotspotLayer = document.querySelector('#map-hotspots');
	const fallbackGrid = document.querySelector('#fallback-grid');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (fallbackGrid instanceof HTMLElement) {
		fallbackGrid.innerHTML = projects
			.map(
				(project) => `
					<article class="fallback-card">
						<p class="tip-kicker">${project.level}</p>
						<h3>${project.title}</h3>
						<p>${project.mission}</p>
						<dl>
							<div>
								<dt>Type</dt>
								<dd>${project.type}</dd>
							</div>
							<div>
								<dt>Role</dt>
								<dd>${project.role}</dd>
							</div>
						</dl>
						<div class="fallback-chip-list">
							${project.rewards.map((reward) => `<span>${reward}</span>`).join('')}
						</div>
						${
							project.href
								? `<a class="tip-enter" href="${project.href}">Enter Level</a>`
								: '<span class="tip-enter is-disabled">Locked</span>'
						}
					</article>
				`
			)
			.join('');
	}

	if (
		canvas instanceof HTMLCanvasElement &&
		tip &&
		floatingTip instanceof HTMLElement &&
		hotspotLayer instanceof HTMLElement
	) {
		const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, alpha: true });
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
		renderer.setClearColor(0x000000, 0);

		const scene = new THREE.Scene();
		const camera = new THREE.OrthographicCamera(-7, 7, 4.2, -4.2, 0.1, 100);
		camera.position.set(0, 0, 10);

		const raycaster = new THREE.Raycaster();
		const pointer = new THREE.Vector2(-10, -10);
		const levelMeshes = [];
		const flagSprites = [];
		const hotspotButtons = [];
		const clock = new THREE.Clock();
		const textureLoader = new THREE.TextureLoader();
		let hovered = null;
		let selected = null;
		let closeTimer = 0;
		const defaultTip = tip.innerHTML;
		let lastCanvasWidth = 0;
		let lastCanvasHeight = 0;
		let parallaxX = 0;
		let parallaxY = 0;

		const resize = () => {
			const rect = canvas.getBoundingClientRect();
			if (rect.width < 1 || rect.height < 1) {
				return;
			}
			lastCanvasWidth = rect.width;
			lastCanvasHeight = rect.height;
			renderer.setSize(rect.width, rect.height, false);
			const aspect = rect.width / Math.max(rect.height, 1);
			const halfWorldWidth = 6.8;
			camera.left = -halfWorldWidth;
			camera.right = halfWorldWidth;
			camera.top = halfWorldWidth / aspect;
			camera.bottom = -halfWorldWidth / aspect;
			camera.updateProjectionMatrix();
		};

		const makeRoundedBox = (width, height, color) => {
			const shape = new THREE.Shape();
			const radius = 0.18;
			shape.moveTo(-width / 2 + radius, -height / 2);
			shape.lineTo(width / 2 - radius, -height / 2);
			shape.quadraticCurveTo(width / 2, -height / 2, width / 2, -height / 2 + radius);
			shape.lineTo(width / 2, height / 2 - radius);
			shape.quadraticCurveTo(width / 2, height / 2, width / 2 - radius, height / 2);
			shape.lineTo(-width / 2 + radius, height / 2);
			shape.quadraticCurveTo(-width / 2, height / 2, -width / 2, height / 2 - radius);
			shape.lineTo(-width / 2, -height / 2 + radius);
			shape.quadraticCurveTo(-width / 2, -height / 2, -width / 2 + radius, -height / 2);
			return new THREE.Mesh(
				new THREE.ShapeGeometry(shape),
				new THREE.MeshBasicMaterial({ color })
			);
		};

		const addIsland = (x, y, width, height, color) => {
			const island = makeRoundedBox(width, height, color);
			island.position.set(x, y, -0.2);
			scene.add(island);

			const edge = makeRoundedBox(width, 0.22, 0xb8977a);
			edge.position.set(x, y - height / 2 - 0.1, -0.1);
			scene.add(edge);
		};

		const addPath = (start, end) => {
			const points = [
				new THREE.Vector3(start[0], start[1], -0.05),
				new THREE.Vector3((start[0] + end[0]) / 2, (start[1] + end[1]) / 2 + 0.35, -0.05),
				new THREE.Vector3(end[0], end[1], -0.05),
			];
			const curve = new THREE.CatmullRomCurve3(points);
			const dotGeometry = new THREE.CircleGeometry(0.075, 12);
			for (let index = 0; index <= 18; index += 1) {
				const point = curve.getPoint(index / 18);
				const dot = new THREE.Mesh(
					dotGeometry,
					new THREE.MeshBasicMaterial({ color: index % 2 === 0 ? 0xd6c6f5 : 0xe9dfd1 })
				);
				dot.position.copy(point);
				scene.add(dot);
			}
		};

		const addCloud = (x, y, scale = 1) => {
			const group = new THREE.Group();
			const cloudShape = new THREE.Shape();
			cloudShape.moveTo(-0.62, -0.12);
			cloudShape.bezierCurveTo(-0.7, 0.06, -0.56, 0.28, -0.34, 0.28);
			cloudShape.bezierCurveTo(-0.26, 0.5, 0.06, 0.56, 0.22, 0.34);
			cloudShape.bezierCurveTo(0.46, 0.4, 0.7, 0.2, 0.68, -0.02);
			cloudShape.bezierCurveTo(0.66, -0.22, 0.48, -0.32, 0.28, -0.32);
			cloudShape.lineTo(-0.38, -0.32);
			cloudShape.bezierCurveTo(-0.56, -0.32, -0.68, -0.24, -0.62, -0.12);

			const cloudMaterial = new THREE.MeshBasicMaterial({
				color: 0xffffff,
				transparent: true,
				opacity: 0.78,
			});
			const mainCloud = new THREE.Mesh(new THREE.ShapeGeometry(cloudShape), cloudMaterial);
			mainCloud.position.set(0, 0, -0.35);
			group.add(mainCloud);

			const glow = new THREE.Mesh(new THREE.ShapeGeometry(cloudShape), new THREE.MeshBasicMaterial({
				color: 0xffffff,
				transparent: true,
				opacity: 0.2,
			}));
			glow.position.set(0, -0.02, -0.36);
			glow.scale.set(1.18, 1.18, 1);
			group.add(glow);

			group.position.set(x, y, -0.35);
			group.scale.setScalar(scale);
			group.userData = { drift: 0.12 + scale * 0.04 };
			scene.add(group);
			return group;
		};

		const addSparkle = (x, y, color = 0xf4a6bd) => {
			const sparkle = new THREE.Mesh(
				new THREE.CircleGeometry(0.06, 4),
				new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.72 })
			);
			sparkle.position.set(x, y, 0.25);
			scene.add(sparkle);
			return sparkle;
		};

		addIsland(-5.2, -1.85, 2.3, 1.35, 0xb8f2a3);
		addIsland(-2.7, 0.45, 2.2, 1.25, 0xf9e7a3);
		addIsland(0.2, -0.95, 2.5, 1.35, 0xf9e4e8);
		addIsland(2.8, 1.1, 2.3, 1.25, 0xd6c6f5);
		addIsland(5.2, -1.25, 2.4, 1.35, 0x9edff2);

		const clouds = [
			addCloud(-5.8, 2.2, 1.08),
			addCloud(-0.9, 2.6, 0.78),
			addCloud(4.8, 2.05, 0.96),
		];
		const sparkles = [
			addSparkle(-4.3, 0.45, 0xf4a6bd),
			addSparkle(-1.15, -1.55, 0xf9e7a3),
			addSparkle(1.6, 1.8, 0xa8d870),
			addSparkle(4.15, -0.15, 0xbfd7ed),
		];

		for (let index = 0; index < projects.length - 1; index += 1) {
			addPath(projects[index].position, projects[index + 1].position);
		}

		projects.forEach((project, index) => {
			const base = new THREE.Mesh(
				new THREE.CircleGeometry(0.56, 18),
				new THREE.MeshBasicMaterial({ color: 0xffffff })
			);
			base.position.set(project.position[0], project.position[1] - 0.03, 0.06);
			scene.add(base);

			const marker = new THREE.Mesh(
				new THREE.CircleGeometry(0.43, 18),
				new THREE.MeshBasicMaterial({ color: project.color })
			);
			marker.position.set(project.position[0], project.position[1], 0.14);
			marker.userData = { project, index };
			scene.add(marker);
			levelMeshes.push(marker);

			const flagTexture = textureLoader.load(project.flag);
			flagTexture.colorSpace = THREE.SRGBColorSpace;
			flagTexture.magFilter = THREE.NearestFilter;
			flagTexture.minFilter = THREE.NearestFilter;
			const flag = new THREE.Sprite(
				new THREE.SpriteMaterial({
					map: flagTexture,
					transparent: true,
					alphaTest: 0.05,
				})
			);
			flag.position.set(project.position[0] + 0.18, project.position[1] + 0.58, 0.32);
			flag.scale.set(1.12, 1.12, 1);
			flagSprites.push(flag);
			scene.add(flag);

			const hotspot = document.createElement('button');
			hotspot.type = 'button';
			hotspot.className = 'map-hotspot';
			hotspot.setAttribute('aria-label', `${project.level}: ${project.title}`);
			hotspot.innerHTML = `<span>${project.level.replace('LEVEL_', 'Lv ')}</span><strong>${project.title}</strong>`;
			hotspot.addEventListener('focus', () => {
				selected = marker;
				hovered = marker;
				updateTip(project);
				positionFloatingTip(marker);
			});
			hotspot.addEventListener('click', () => {
				if (project.href) {
					window.location.href = project.href;
					return;
				}
				selected = marker;
				hovered = marker;
				updateTip(project);
				positionFloatingTip(marker);
			});
			hotspotLayer.append(hotspot);
			hotspotButtons.push(hotspot);
		});

		const updateTip = (project) => {
			floatingTip.innerHTML = `
				<button class="tip-close" type="button" aria-label="Close project preview">x</button>
				<p class="tip-kicker">${project.level}</p>
				<h2>${project.title}</h2>
				<dl>
					<div>
						<dt>Type:</dt>
						<dd>${project.type}</dd>
					</div>
					<div>
						<dt>Mission:</dt>
						<dd>${project.mission}</dd>
					</div>
					<div>
						<dt>Role:</dt>
						<dd>${project.role}</dd>
					</div>
					<div>
						<dt>Difficulty:</dt>
						<dd>${project.difficulty}</dd>
					</div>
					<div>
						<dt>Rewards Unlocked:</dt>
						<dd class="tip-chip-list">
							${project.rewards.map((reward) => `<span>${reward}</span>`).join('')}
						</dd>
					</div>
				</dl>
				${
					project.href
						? `<a class="tip-enter" href="${project.href}">Enter Level</a>`
						: '<span class="tip-enter is-disabled">Locked</span>'
				}
			`;
			floatingTip.querySelector('.tip-close')?.addEventListener('click', resetPreview);
			floatingTip.classList.add('is-visible');
		};

		const positionFloatingTip = (mesh) => {
			const projected = mesh.position.clone().project(camera);
			const rect = canvas.getBoundingClientRect();
			const mapRect = canvas.parentElement?.getBoundingClientRect() ?? rect;
			const x = ((projected.x + 1) / 2) * rect.width + rect.left - mapRect.left;
			const y = ((-projected.y + 1) / 2) * rect.height + rect.top - mapRect.top;

			const placeLeft = x > rect.width * 0.58;
			const tooltipHeight = floatingTip.offsetHeight || 360;
			const placeAbove = y > tooltipHeight + 34;
			floatingTip.style.left = `${x}px`;
			floatingTip.style.top = `${y}px`;
			floatingTip.classList.toggle('is-left', placeLeft);
			floatingTip.classList.toggle('is-above', placeAbove);
		};

		const updatePointer = (event) => {
			const rect = canvas.getBoundingClientRect();
			pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
			pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
			if (!prefersReducedMotion) {
				parallaxX = pointer.x * 0.16;
				parallaxY = pointer.y * 0.1;
			}
		};

		const positionHotspots = () => {
			const rect = canvas.getBoundingClientRect();
			levelMeshes.forEach((mesh, index) => {
				const button = hotspotButtons[index];
				if (!button) {
					return;
				}
				const projected = mesh.position.clone().project(camera);
				const x = ((projected.x + 1) / 2) * rect.width;
				const y = ((-projected.y + 1) / 2) * rect.height;
				button.style.left = `${x}px`;
				button.style.top = `${y}px`;
				button.classList.toggle('is-active', mesh === hovered || mesh === selected);
			});
		};

		const resetPreview = () => {
			window.clearTimeout(closeTimer);
			pointer.set(-10, -10);
			hovered = null;
			selected = null;
			canvas.style.cursor = 'default';
			tip.innerHTML = defaultTip;
			hotspotButtons.forEach((button) => button.classList.remove('is-active'));
			floatingTip.classList.remove('is-visible', 'is-left', 'is-above');
		};

		const cancelClose = () => {
			window.clearTimeout(closeTimer);
		};

		const scheduleClose = () => {
			if (selected) {
				return;
			}
			window.clearTimeout(closeTimer);
			closeTimer = window.setTimeout(resetPreview, 260);
		};

		canvas.addEventListener('pointermove', (event) => {
			cancelClose();
			updatePointer(event);
		});

		floatingTip.addEventListener('pointerenter', cancelClose);
		floatingTip.addEventListener('pointermove', cancelClose);
		floatingTip.addEventListener('pointerleave', scheduleClose);

		window.addEventListener('pointermove', (event) => {
			const rect = canvas.getBoundingClientRect();
			const tipRect = floatingTip.getBoundingClientRect();
			const isOutsideCanvas =
				event.clientX < rect.left ||
				event.clientX > rect.right ||
				event.clientY < rect.top ||
				event.clientY > rect.bottom;
			const isOutsideFloatingTip =
				event.clientX < tipRect.left ||
				event.clientX > tipRect.right ||
				event.clientY < tipRect.top ||
				event.clientY > tipRect.bottom;
			let isOverLevel = false;

			if (!isOutsideCanvas) {
				updatePointer(event);
				raycaster.setFromCamera(pointer, camera);
				isOverLevel = raycaster.intersectObjects(levelMeshes).length > 0;
			}

			if (isOutsideFloatingTip && !isOverLevel && hovered) {
				scheduleClose();
			} else if (hovered) {
				cancelClose();
			}
		});

		canvas.addEventListener('click', (event) => {
			updatePointer(event);
			raycaster.setFromCamera(pointer, camera);
			const clickedLevel = raycaster.intersectObjects(levelMeshes)[0]?.object ?? hovered;
			const project = clickedLevel?.userData.project;
			if (project) {
				if (project.href) {
					window.location.href = project.href;
					return;
				}
				selected = clickedLevel;
				hovered = clickedLevel;
				updateTip(project);
				positionFloatingTip(clickedLevel);
			}
		});

		const render = () => {
			const rect = canvas.getBoundingClientRect();
			if (
				Math.abs(rect.width - lastCanvasWidth) > 1 ||
				Math.abs(rect.height - lastCanvasHeight) > 1
			) {
				resize();
			}

			const elapsed = clock.getElapsedTime();
			if (!prefersReducedMotion) {
				camera.position.x += (parallaxX - camera.position.x) * 0.035;
				camera.position.y += (parallaxY - camera.position.y) * 0.035;
				clouds.forEach((cloud, index) => {
					cloud.position.x += Math.sin(elapsed * cloud.userData.drift + index) * 0.0018;
					cloud.position.y += Math.cos(elapsed * cloud.userData.drift + index) * 0.0012;
				});
				sparkles.forEach((sparkle, index) => {
					const sparklePulse = 0.82 + Math.sin(elapsed * 1.6 + index) * 0.16;
					sparkle.scale.setScalar(sparklePulse);
				});
			}
			raycaster.setFromCamera(pointer, camera);
			const hits = raycaster.intersectObjects(levelMeshes);
			const nextHovered = hits[0]?.object ?? null;

			if (nextHovered && nextHovered !== hovered) {
				cancelClose();
				hovered = nextHovered;
				canvas.style.cursor = 'pointer';
				updateTip(hovered.userData.project);
			} else if (!nextHovered) {
				canvas.style.cursor = 'default';
			}

			levelMeshes.forEach((mesh, index) => {
				const isHovered = mesh === hovered;
				const pulse = prefersReducedMotion ? 0 : Math.sin(elapsed * 3 + index) * 0.04;
				const scale = isHovered ? 1.22 + pulse : 1 + pulse;
				mesh.scale.setScalar(scale);

				if (flagSprites[index]) {
					const flagScale = isHovered ? 1.24 + pulse : 1.08 + pulse * 0.35;
					flagSprites[index].scale.set(flagScale, flagScale, 1);
					flagSprites[index].position.y =
						mesh.userData.project.position[1] + 0.58 + (isHovered && !prefersReducedMotion ? 0.12 : 0);
				}
			});

			if (hovered) {
				positionFloatingTip(hovered);
			}
			positionHotspots();

			renderer.render(scene, camera);
			requestAnimationFrame(render);
		};

		window.addEventListener('resize', resize);
		new ResizeObserver(resize).observe(canvas);
		requestAnimationFrame(resize);
		resize();
		render();
	}
</script>

