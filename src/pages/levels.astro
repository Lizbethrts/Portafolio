---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Levels | Lizzy World" frame>
	<script is:inline>
	window.__i18nStrings = {
		en: {
			title: 'Levels', subtitle: 'Select a project level',
			tipKicker: 'Hover a level', tipTitle: 'Project preview', tipDesc: 'Move over a level marker to see a quick summary.',
			selectMode: 'Select mode', pressFlag: 'Press a flag',
			pressDesc: 'Hover or click a flag to preview the mission. Use Enter Level inside the card to open the project.',
			infoDefault: 'Project info', infoDefaultTitle: 'Select a level', infoDefaultDesc: 'Hover a flag on the map to see project details here.',
			allLevels: 'All levels', projectList: 'Project list',
			fallbackDesc: 'The same levels are available here for keyboard, mobile, and reduced-motion browsing.',
			resetMap: 'Reset',
		},
		es: {
			title: 'Niveles', subtitle: 'Selecciona un nivel de proyecto',
			tipKicker: 'Pasa el cursor sobre un nivel', tipTitle: 'Vista previa del proyecto', tipDesc: 'Mueve el cursor sobre un marcador de nivel para ver un resumen rápido.',
			selectMode: 'Modo de selección', pressFlag: 'Presiona una bandera',
			pressDesc: 'Pasa el cursor o haz clic en una bandera para previsualizar la misión. Usa "Entrar al nivel" dentro de la tarjeta para abrir el proyecto.',
			infoDefault: 'Info del proyecto', infoDefaultTitle: 'Selecciona un nivel', infoDefaultDesc: 'Pasa el cursor sobre una bandera para ver los detalles aquí.',
			allLevels: 'Todos los niveles', projectList: 'Lista de proyectos',
			fallbackDesc: 'Los mismos niveles están disponibles aquí para navegación por teclado, móvil y movimiento reducido.',
			resetMap: 'Reiniciar',
		},
	};
	</script>

	<main class="levels-screen" aria-labelledby="levels-title">
		<a class="back-link" href="/" aria-label="Back to Lizzy World menu" data-i18n="nav.back" data-i18n-aria="nav.backAria">Back</a>

		<header class="levels-header">
			<div class="screen-icon" aria-hidden="true">
				<img src="/img/menu/1.png" alt="" width="46" height="46" />
			</div>
			<div>
				<h1 id="levels-title" data-i18n="title">Levels</h1>
				<p data-i18n="subtitle">Select a project level</p>
			</div>
		</header>

		<!-- Instructions: horizontal row above map + info panel -->
		<div class="levels-instructions">
			<div class="map-tip map-tip-static" data-i18n-ignore>
				<p class="tip-kicker" data-i18n="tipKicker">Hover a level</p>
				<h2 data-i18n="tipTitle">Project preview</h2>
				<p data-i18n="tipDesc">Move over a level marker to see a quick summary.</p>
			</div>
			<article class="level-help">
				<p class="panel-kicker" data-i18n="selectMode">Select mode</p>
				<h2 data-i18n="pressFlag">Press a flag</h2>
				<p data-i18n="pressDesc">Hover or click a flag to preview the mission. Use Enter Level inside the card to open the project.</p>
			</article>
		</div>

		<section class="levels-playfield" aria-label="Interactive project map">
			<!-- Project info panel aligned with map -->
			<aside class="levels-sidebar">
				<div class="map-tip info-panel" id="map-tip" role="status" aria-live="polite">
					<p class="tip-kicker" data-i18n="infoDefault">Project info</p>
					<h2 data-i18n="infoDefaultTitle">Select a level</h2>
					<p data-i18n="infoDefaultDesc">Hover a flag on the map to see project details here.</p>
				</div>
			</aside>

			<div class="map-column">
				<div class="map-shell">
					<div class="map-sparkle map-sparkle-one" aria-hidden="true"></div>
					<div class="map-sparkle map-sparkle-two" aria-hidden="true"></div>
					<canvas id="level-map" aria-label="Three.js project world map"></canvas>
					<div class="player-marker" id="player-marker" aria-hidden="true">
						<img src="/images/lizzy-player-marker.png" alt="" />
						<span></span>
					</div>
					<div class="map-controls" aria-label="Map controls">
						<button type="button" data-zoom-in aria-label="Zoom in">+</button>
						<button type="button" data-zoom-out aria-label="Zoom out">-</button>
						<button type="button" data-reset-map aria-label="Reset map" data-i18n="resetMap">Reset</button>
					</div>
					<div class="map-hotspots" id="map-hotspots" aria-label="Keyboard project map controls"></div>
					<div class="floating-tip" id="floating-tip" role="dialog" aria-label="Project preview"></div>
				</div>
			</div>
		</section>

		<section class="levels-fallback" aria-labelledby="levels-fallback-title">
			<div class="fallback-heading">
				<p class="panel-kicker" data-i18n="allLevels">All levels</p>
				<h2 id="levels-fallback-title" data-i18n="projectList">Project list</h2>
				<p data-i18n="fallbackDesc">The same levels are available here for keyboard, mobile, and reduced-motion browsing.</p>
			</div>
			<div class="fallback-grid" id="fallback-grid"></div>
		</section>
	</main>
</Layout>

<script>
	import * as THREE from 'three';

	const projects = [
		{
			id: 'level-1',
			level: 'LEVEL_01',
			title: 'Learning Path Platform',
			type: 'EdTech UX / AI-Assisted Learning',
			mission:
				'Design a personalized learning platform for educators with limited time, low connectivity, and different levels of digital confidence.',
			role: 'UX Research · Learning Experience · Information Architecture',
			difficulty: '★★★★☆',
			rewards: [
				'User Personas',
				'Personalized Learning Routes',
				'AI Prompt Strategy',
				'Dashboard Thinking',
			],
			href: '/levels/learning-path-platform',
			flag: '/img/levels/flag-1.png',
			position: [-5.2, -1.7, 0],
			color: 0xf4a6bd,
		},
		{
			id: 'level-2',
			level: 'LEVEL_02',
			title: 'Digital Entertainment Redesign',
			type: 'Mobile App Redesign / Entertainment UX',
			mission:
				'Redesign an existing mobile app to make it more scalable, intuitive, trustworthy, and engaging across multiple entertainment sections.',
			role: 'UX Flow Design · Competitive Analysis · Mobile UI · A/B Testing',
			difficulty: '★★★★☆',
			rewards: [
				'App Redesign Strategy',
				'User Flow Optimization',
				'Cross-Discovery UX',
				'Scalable Components',
			],
			href: '/levels/digital-entertainment-redesign',
			flag: '/img/levels/flag-2.png',
			position: [-2.7, 0.6, 0],
			color: 0xa8d870,
		},
		{
			id: 'level-3',
			level: 'LEVEL_03',
			title: 'AI Hiring Platform',
			type: 'HR Tech / Gamified Recruitment UX',
			mission:
				'Design and refine selected screens for a gamified recruitment platform focused on skills-based matching and clearer hiring flows.',
			role: 'UI Screen Design / UX Flow Support / Visual Consistency',
			difficulty: '★★★☆☆',
			rewards: [
				'Screen Iteration',
				'HR Tech UX',
				'Visual Consistency',
				'Platform Flow Support',
			],
			href: '/levels/ai-hiring-platform',
			flag: '/img/levels/flag-3.png',
			position: [0.2, -0.8, 0],
			color: 0xd6c6f5,
		},
		{
			id: 'level-4',
			level: 'LEVEL_04',
			title: 'Traditional Food Brand Website',
			type: 'Web Design / Brand Experience',
			mission:
				'Create a web experience for a traditional food brand, supporting selected screens, visual layout, locations, and brand consistency.',
			role: 'Web Screen Design / Visual Layout Support / Brand Consistency',
			difficulty: '★★★☆☆',
			rewards: [
				'Brand Web Experience',
				'Locations Page Structure',
				'Visual Layout Support',
				'Responsive Web Thinking',
			],
			href: '/levels/traditional-food-brand-website',
			flag: '/img/levels/flag-4.png',
			position: [2.35, 1.25, 0],
			color: 0xf9e7a3,
		},
		{
			id: 'level-5',
			level: 'LEVEL_05',
			title: 'FIXIA Service Platform',
			type: 'Home Services / Marketplace UX',
			mission:
				'Create a clearer and safer way to diagnose household problems, compare verified technicians, and book trusted repair services.',
			role: 'UX Research / Service Flow / Mobile + Web UI',
			difficulty: '****-',
			rewards: [
				'Trust Signal Design',
				'AI Diagnosis Flow',
				'Verified Technician Cards',
				'Service Marketplace UX',
			],
			href: '/levels/fixia-service-platform',
			flag: '/img/levels/flag-5.png',
			position: [4.45, -0.35, 0],
			color: 0xbfd7ed,
		},
		{
			id: 'level-6',
			level: 'LEVEL_06',
			title: 'Healthcare Warehouse Management System',
			type: 'Enterprise UX / Healthcare Logistics',
			mission:
				'Design a guided warehouse platform that improves traceability, automates repetitive processes, and reduces operational errors across healthcare supply operations.',
			role: 'UX/UI Design · User Flows · Wireframing · Client Validation · Product Definition · Vibe Coding',
			difficulty: '★★★★★',
			rewards: [
				'Enterprise UX',
				'Complex Workflow Design',
				'Stakeholder Collaboration',
				'SAP Integration Thinking',
				'Operational Traceability',
			],
			href: '/levels/wms-healthcare-system',
			flag: '/img/levels/flag-6.png',
			position: [5.9, -1.95, 0],
			color: 0x9fd8c9,
		},
		{
			id: 'level-7',
			level: 'LEVEL_07',
			title: 'AI Location Intelligence Platform',
			type: 'SaaS UX / Geospatial Analytics',
			mission:
				'Design a self-service platform concept that helps businesses understand store performance, local markets, competitors, and expansion opportunities.',
			role: 'Product Definition · Benchmark Research · Information Architecture · User Flows · Wireframing',
			difficulty: '★★★★☆',
			rewards: [
				'Product Definition',
				'Data-Intensive UX',
				'Geospatial Experience',
				'Information Architecture',
			],
			href: '/levels/ai-location-intelligence-platform',
			flag: '/img/levels/flag-7.png',
			position: [7.8, 1.1, 0],
			color: 0xf2b78c,
		},
		{
			id: 'level-8',
			level: 'LEVEL_08',
			title: 'AI Business Valuation Platform',
			type: 'Financial UX / Product Discovery',
			mission:
				'Facilitate a collaborative discovery process and transform financial uncertainty into a guided digital product concept for small business owners.',
			role: 'Workshop Design · Facilitation · Stakeholder Research · Insight Synthesis',
			difficulty: '★★★★☆',
			rewards: [
				'Workshop Facilitation',
				'Stakeholder Collaboration',
				'Research Synthesis',
				'Opportunity Prioritization',
			],
			href: '/levels/ai-business-valuation-platform',
			flag: '/img/levels/flag-8.png',
			position: [9.7, -0.6, 0],
			color: 0xb8c4f0,
		},
	];

	const PROJECTS_ES = [
		{ level:'NIVEL_01', title:'Plataforma de Ruta de Aprendizaje', type:'EdTech UX / Aprendizaje Asistido por IA', mission:'Diseñar una plataforma de aprendizaje personalizada para educadores con tiempo limitado, baja conectividad y distintos niveles de confianza digital.', role:'Investigación UX · Experiencia de Aprendizaje · Arquitectura de la Información', rewards:['Personas de Usuario','Rutas de Aprendizaje Personalizadas','Estrategia de Prompts de IA','Pensamiento de Dashboard'] },
		{ level:'NIVEL_02', title:'Rediseño de Entretenimiento Digital', type:'Rediseño de App Móvil / UX de Entretenimiento', mission:'Rediseñar una app móvil existente para hacerla más escalable, intuitiva, confiable y atractiva en múltiples secciones de entretenimiento.', role:'Diseño de Flujo UX · Análisis Competitivo · UI Móvil · Pruebas A/B', rewards:['Estrategia de Rediseño de App','Optimización del Flujo de Usuario','UX de Descubrimiento Cruzado','Componentes Escalables'] },
		{ level:'NIVEL_03', title:'Plataforma de Reclutamiento con IA', type:'HR Tech / UX de Reclutamiento Gamificado', mission:'Diseñar y refinar pantallas seleccionadas para una plataforma de reclutamiento gamificada enfocada en coincidencias por habilidades y flujos de contratación más claros.', role:'Diseño de Pantalla UI / Soporte de Flujo UX / Consistencia Visual', rewards:['Iteración de Pantalla','UX de HR Tech','Consistencia Visual','Soporte de Flujo de Plataforma'] },
		{ level:'NIVEL_04', title:'Sitio Web de Marca de Alimento Tradicional', type:'Diseño Web / Experiencia de Marca', mission:'Crear una experiencia web para una marca de alimento tradicional, apoyando pantallas seleccionadas, disposición visual, ubicaciones y consistencia de marca.', role:'Diseño de Pantalla Web / Soporte de Disposición Visual / Consistencia de Marca', rewards:['Experiencia Web de Marca','Estructura de Página de Ubicaciones','Soporte de Disposición Visual','Pensamiento Web Responsivo'] },
		{ level:'NIVEL_05', title:'Plataforma de Servicios FIXIA', type:'Servicios del Hogar / UX de Marketplace', mission:'Crear una forma más clara y segura de diagnosticar problemas del hogar, comparar técnicos verificados y reservar servicios de reparación confiables.', role:'Investigación UX / Flujo de Servicio / UI Móvil + Web', rewards:['Diseño de Señales de Confianza','Flujo de Diagnóstico con IA','Tarjetas de Técnicos Verificados','UX de Marketplace de Servicios'] },
		{ level:'NIVEL_06', title:'Sistema de Gestión de Almacén para el Sector Salud', type:'UX Empresarial / Logística de Salud', mission:'Diseñar una plataforma de almacén guiada que mejore la trazabilidad, automatice procesos repetitivos y reduzca errores operativos en operaciones de suministro médico.', role:'Diseño UX/UI · Flujos de Usuario · Wireframing · Validación con Cliente · Definición de Producto · Vibe Coding', rewards:['UX Empresarial','Diseño de Flujos Complejos','Colaboración con Stakeholders','Pensamiento de Integración SAP','Trazabilidad Operativa'] },
		{ level:'NIVEL_07', title:'Plataforma de Inteligencia de Ubicación con IA', type:'UX SaaS / Analítica Geoespacial', mission:'Diseñar un concepto de plataforma de autoservicio que ayude a las empresas a entender el desempeño de sus tiendas, mercados locales, competidores y oportunidades de expansión.', role:'Definición de Producto · Investigación de Benchmark · Arquitectura de Información · Flujos de Usuario · Wireframing', rewards:['Definición de Producto','UX Intensivo en Datos','Experiencia Geoespacial','Arquitectura de Información'] },
		{ level:'NIVEL_08', title:'Plataforma de Valuación de Negocios con IA', type:'UX Financiero / Descubrimiento de Producto', mission:'Facilitar un proceso de descubrimiento colaborativo y transformar la incertidumbre financiera en un concepto de producto digital guiado para pequeños negocios.', role:'Diseño de Talleres · Facilitación · Investigación con Stakeholders · Síntesis de Insights', rewards:['Facilitación de Talleres','Colaboración con Stakeholders','Síntesis de Investigación','Priorización de Oportunidades'] },
	];

	const UI_STR = {
		en: { levelActive:'Level Active', levelPreview:'Level Preview', closeAria:'Close project preview', typeL:'Type:', missionL:'Mission:', roleL:'Role:', diffL:'Difficulty:', rewardsL:'Rewards Unlocked:', enter:'Enter Level', locked:'Locked', routeProgress:'Route Progress', selected:'selected', movingTo:(t:string)=>`Lizzy is moving toward ${t}. Use Enter Level in the active panel to open the project.`, fallbackType:'Type', fallbackRole:'Role', infoDefault:'Project info', infoDefaultTitle:'Select a level', infoDefaultDesc:'Hover a flag on the map to see project details here.' },
		es: { levelActive:'Nivel Activo', levelPreview:'Vista Previa del Nivel', closeAria:'Cerrar vista previa del proyecto', typeL:'Tipo:', missionL:'Misión:', roleL:'Rol:', diffL:'Dificultad:', rewardsL:'Recompensas:', enter:'Entrar al Nivel', locked:'Bloqueado', routeProgress:'Progreso de Ruta', selected:'seleccionado', movingTo:(t:string)=>`Lizzy se dirige hacia ${t}. Usa "Entrar al nivel" en el panel activo para abrir el proyecto.`, fallbackType:'Tipo', fallbackRole:'Rol', infoDefault:'Info del proyecto', infoDefaultTitle:'Selecciona un nivel', infoDefaultDesc:'Pasa el cursor sobre una bandera para ver los detalles aquí.' },
	};

	function getLang(): 'en'|'es' { return ((typeof localStorage!=='undefined'&&localStorage.getItem('lizzy-lang'))||'en') as 'en'|'es'; }
	function getUI() { return UI_STR[getLang()]||UI_STR.en; }
	function getProjectData(i: number) {
		const l = getLang();
		return l === 'es' ? { ...projects[i], ...PROJECTS_ES[i] } : projects[i];
	}

	const canvas = document.querySelector('#level-map');
	const tip = document.querySelector('#map-tip');
	const floatingTip = document.querySelector('#floating-tip');
	const hotspotLayer = document.querySelector('#map-hotspots');
	const fallbackGrid = document.querySelector('#fallback-grid');
	const playerMarker = document.querySelector('#player-marker');
	const zoomInButton = document.querySelector('[data-zoom-in]');
	const zoomOutButton = document.querySelector('[data-zoom-out]');
	const resetMapButton = document.querySelector('[data-reset-map]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function buildFallbackGrid() {
		if (!(fallbackGrid instanceof HTMLElement)) return;
		const ui = getUI();
		fallbackGrid.innerHTML = projects
			.map((p, i) => {
				const proj = getProjectData(i);
				return `
					<article class="fallback-card">
						<p class="tip-kicker">${proj.level}</p>
						<h3>${proj.title}</h3>
						<p>${proj.mission}</p>
						<dl>
							<div><dt>${ui.fallbackType}</dt><dd>${proj.type}</dd></div>
							<div><dt>${ui.fallbackRole}</dt><dd>${proj.role}</dd></div>
						</dl>
						<div class="fallback-chip-list">
							${proj.rewards.map((r) => `<span>${r}</span>`).join('')}
						</div>
						${p.href ? `<a class="tip-enter" href="${p.href}">${ui.enter}</a>` : `<span class="tip-enter is-disabled">${ui.locked}</span>`}
					</article>
				`;
			})
			.join('');
	}
	buildFallbackGrid();

	if (
		canvas instanceof HTMLCanvasElement &&
		tip &&
		floatingTip instanceof HTMLElement &&
		hotspotLayer instanceof HTMLElement &&
		playerMarker instanceof HTMLElement
	) {
		const playerMarkerImage = playerMarker.querySelector('img');
		if (playerMarkerImage instanceof HTMLImageElement) {
			playerMarkerImage.addEventListener('load', () => playerMarker.classList.add('has-image'));
			playerMarkerImage.addEventListener('error', () => playerMarker.classList.remove('has-image'));
		}

		const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, alpha: true });
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
		renderer.setClearColor(0x000000, 0);

		const scene = new THREE.Scene();
		// En embed mode hacemos zoom-out para que todo el mapa quepa sin desbordarse
		const isEmbed = document.documentElement.classList.contains('is-embed');
		const halfWorldWidth = isEmbed ? 9.2 : 6.8;
		const camera = new THREE.OrthographicCamera(-halfWorldWidth, halfWorldWidth, halfWorldWidth * 0.6, -halfWorldWidth * 0.6, 0.1, 100);
		camera.position.set(0, 0, 10);

		const raycaster = new THREE.Raycaster();
		const pointer = new THREE.Vector2(-10, -10);
		const levelMeshes = [];
		const flagSprites = [];
		const hotspotButtons = [];
		const pathSegments = [];
		const clock = new THREE.Clock();
		const textureLoader = new THREE.TextureLoader();
		let hovered = null;
		let selected = null;
		let hoveringHotspot = false;
		let closeTimer = 0;
		// defaultTip is rebuilt dynamically via DEFAULT_TIP_HTML
		let lastCanvasWidth = 0;
		let lastCanvasHeight = 0;
		let parallaxX = 0;
		let parallaxY = 0;
		let mapOffsetX = 0;
		let mapOffsetY = 0;
		let activePathToken = 0;
		let isDraggingMap = false;
		let didDragMap = false;
		let dragStartX = 0;
		let dragStartY = 0;
		let dragStartOffsetX = 0;
		let dragStartOffsetY = 0;
		let playerMarkerWorldPosition = new THREE.Vector3(projects[0].position[0], projects[0].position[1], 0);
		let playerMarkerAnimation = null;
		let playerMarkerTargetIndex = 0;

		const resize = () => {
			const rect = canvas.getBoundingClientRect();
			if (rect.width < 1 || rect.height < 1) {
				return;
			}
			lastCanvasWidth = rect.width;
			lastCanvasHeight = rect.height;
			renderer.setSize(rect.width, rect.height, false);
			const aspect = rect.width / Math.max(rect.height, 1);
			camera.left = -halfWorldWidth;
			camera.right = halfWorldWidth;
			camera.top = halfWorldWidth / aspect;
			camera.bottom = -halfWorldWidth / aspect;
			camera.updateProjectionMatrix();
		};

		const makeRoundedBox = (width, height, color) => {
			const shape = new THREE.Shape();
			const radius = 0.18;
			shape.moveTo(-width / 2 + radius, -height / 2);
			shape.lineTo(width / 2 - radius, -height / 2);
			shape.quadraticCurveTo(width / 2, -height / 2, width / 2, -height / 2 + radius);
			shape.lineTo(width / 2, height / 2 - radius);
			shape.quadraticCurveTo(width / 2, height / 2, width / 2 - radius, height / 2);
			shape.lineTo(-width / 2 + radius, height / 2);
			shape.quadraticCurveTo(-width / 2, height / 2, -width / 2, height / 2 - radius);
			shape.lineTo(-width / 2, -height / 2 + radius);
			shape.quadraticCurveTo(-width / 2, -height / 2, -width / 2 + radius, -height / 2);
			return new THREE.Mesh(
				new THREE.ShapeGeometry(shape),
				new THREE.MeshBasicMaterial({ color })
			);
		};

		const addIsland = (x, y, width, height, color) => {
			const island = makeRoundedBox(width, height, color);
			island.position.set(x, y, -0.2);
			scene.add(island);

			const edge = makeRoundedBox(width, 0.22, 0xb8977a);
			edge.position.set(x, y - height / 2 - 0.1, -0.1);
			scene.add(edge);
		};

		const addPath = (start, end) => {
			const points = [
				new THREE.Vector3(start[0], start[1], -0.05),
				new THREE.Vector3((start[0] + end[0]) / 2, (start[1] + end[1]) / 2 + 0.35, -0.05),
				new THREE.Vector3(end[0], end[1], -0.05),
			];
			const curve = new THREE.CatmullRomCurve3(points);
			const dotGeometry = new THREE.CircleGeometry(0.075, 12);
			const dots = [];
			for (let index = 0; index <= 18; index += 1) {
				const point = curve.getPoint(index / 18);
				const dotMaterial = new THREE.MeshBasicMaterial({
					color: index % 2 === 0 ? 0xd6c6f5 : 0xe9dfd1,
					transparent: true,
					opacity: 0.48,
				});
				const dot = new THREE.Mesh(
					dotGeometry,
					dotMaterial
				);
				dot.position.copy(point);
				dot.userData = { baseScale: 1, active: false };
				scene.add(dot);
				dots.push(dot);
			}
			pathSegments.push({ curve, dots });
		};

		const addCloud = (x, y, scale = 1) => {
			const group = new THREE.Group();
			const cloudShape = new THREE.Shape();
			cloudShape.moveTo(-0.62, -0.12);
			cloudShape.bezierCurveTo(-0.7, 0.06, -0.56, 0.28, -0.34, 0.28);
			cloudShape.bezierCurveTo(-0.26, 0.5, 0.06, 0.56, 0.22, 0.34);
			cloudShape.bezierCurveTo(0.46, 0.4, 0.7, 0.2, 0.68, -0.02);
			cloudShape.bezierCurveTo(0.66, -0.22, 0.48, -0.32, 0.28, -0.32);
			cloudShape.lineTo(-0.38, -0.32);
			cloudShape.bezierCurveTo(-0.56, -0.32, -0.68, -0.24, -0.62, -0.12);

			const cloudMaterial = new THREE.MeshBasicMaterial({
				color: 0xffffff,
				transparent: true,
				opacity: 0.78,
			});
			const mainCloud = new THREE.Mesh(new THREE.ShapeGeometry(cloudShape), cloudMaterial);
			mainCloud.position.set(0, 0, -0.35);
			group.add(mainCloud);

			const glow = new THREE.Mesh(new THREE.ShapeGeometry(cloudShape), new THREE.MeshBasicMaterial({
				color: 0xffffff,
				transparent: true,
				opacity: 0.2,
			}));
			glow.position.set(0, -0.02, -0.36);
			glow.scale.set(1.18, 1.18, 1);
			group.add(glow);

			group.position.set(x, y, -0.35);
			group.scale.setScalar(scale);
			group.userData = { drift: 0.12 + scale * 0.04 };
			scene.add(group);
			return group;
		};

		const addSparkle = (x, y, color = 0xf4a6bd) => {
			const sparkle = new THREE.Mesh(
				new THREE.CircleGeometry(0.06, 4),
				new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.72 })
			);
			sparkle.position.set(x, y, 0.25);
			scene.add(sparkle);
			return sparkle;
		};

		addIsland(-5.2, -1.85, 2.3, 1.35, 0xb8f2a3);
		addIsland(-2.7, 0.45, 2.2, 1.25, 0xf9e7a3);
		addIsland(0.2, -0.95, 2.5, 1.35, 0xf9e4e8);
		addIsland(2.35, 1.1, 2.3, 1.25, 0xd6c6f5);
		addIsland(4.45, -0.5, 2.35, 1.25, 0x9edff2);
		addIsland(5.9, -2.1, 2.2, 1.2, 0xf9e4e8);

		const clouds = [
			addCloud(-5.8, 2.2, 1.08),
			addCloud(-0.9, 2.6, 0.78),
			addCloud(4.8, 2.05, 0.96),
		];
		const sparkles = [
			addSparkle(-4.3, 0.45, 0xf4a6bd),
			addSparkle(-1.15, -1.55, 0xf9e7a3),
			addSparkle(1.6, 1.8, 0xa8d870),
			addSparkle(4.15, -0.15, 0xbfd7ed),
		];

		for (let index = 0; index < projects.length - 1; index += 1) {
			addPath(projects[index].position, projects[index + 1].position);
		}

		projects.forEach((project, index) => {
			const base = new THREE.Mesh(
				new THREE.CircleGeometry(0.56, 18),
				new THREE.MeshBasicMaterial({ color: 0xffffff })
			);
			base.position.set(project.position[0], project.position[1] - 0.03, 0.06);
			scene.add(base);

			const marker = new THREE.Mesh(
				new THREE.CircleGeometry(0.43, 18),
				new THREE.MeshBasicMaterial({ color: project.color })
			);
			marker.position.set(project.position[0], project.position[1], 0.14);
			marker.userData = { project, index };
			scene.add(marker);
			levelMeshes.push(marker);

			const flagTexture = textureLoader.load(project.flag);
			flagTexture.colorSpace = THREE.SRGBColorSpace;
			flagTexture.magFilter = THREE.NearestFilter;
			flagTexture.minFilter = THREE.NearestFilter;
			const flag = new THREE.Sprite(
				new THREE.SpriteMaterial({
					map: flagTexture,
					transparent: true,
					alphaTest: 0.05,
				})
			);
			flag.position.set(project.position[0] + 0.18, project.position[1] + 0.58, 0.32);
			flag.scale.set(1.12, 1.12, 1);
			flagSprites.push(flag);
			scene.add(flag);

			const hotspot = document.createElement('button');
			hotspot.type = 'button';
			hotspot.className = 'map-hotspot';
			hotspot.dataset.index = String(index);
			hotspot.setAttribute('aria-label', `${project.level}: ${project.title}`);
			hotspot.innerHTML = `<span>${project.level.replace('LEVEL_', 'Lv ')}</span><strong>${project.title}</strong>`;
			hotspot.addEventListener('mouseenter', () => {
				hoveringHotspot = true;
				showLevelPreview(marker);
			});
			hotspot.addEventListener('mouseleave', () => {
				hoveringHotspot = false;
				restoreSelectedPreview(marker);
			});
			hotspot.addEventListener('focus', () => {
				hoveringHotspot = true;
				showLevelPreview(marker);
			});
			hotspot.addEventListener('blur', () => {
				hoveringHotspot = false;
				restoreSelectedPreview(marker);
			});
			hotspot.addEventListener('click', () => {
				selectLevel(marker);
				if (marker.userData.project?.href) {
					window.location.href = marker.userData.project.href;
				}
			});
			hotspotLayer.append(hotspot);
			hotspotButtons.push(hotspot);
		});

		const updateTip = (project, isActive = false) => {
			const ui = getUI();
			floatingTip.innerHTML = `
				<p class="active-badge">${isActive ? ui.levelActive : ui.levelPreview}</p>
				<p class="tip-kicker">${project.level}</p>
				<h2>${project.title}</h2>
			`;
			floatingTip.classList.add('is-visible');
		};

		const showDefaultInfo = () => {
			const ui = getUI();
			tip.innerHTML = `
				<p class="tip-kicker">${ui.infoDefault}</p>
				<h2>${ui.infoDefaultTitle}</h2>
				<p>${ui.infoDefaultDesc}</p>
			`;
			tip.classList.remove('has-project');
		};

		const updateHoverPreview = (project) => {
			const ui = getUI();
			tip.innerHTML = `
				<p class="tip-kicker">${project.level}</p>
				<h2>${project.title}</h2>
				<dl class="tip-dl">
					<div><dt>${ui.typeL}</dt><dd>${project.type}</dd></div>
					<div><dt>${ui.missionL}</dt><dd>${project.mission}</dd></div>
					<div><dt>${ui.roleL}</dt><dd>${project.role}</dd></div>
					<div><dt>${ui.diffL}</dt><dd>${project.difficulty}</dd></div>
					<div><dt>${ui.rewardsL}</dt><dd class="tip-chip-list">${project.rewards.map((r) => `<span>${r}</span>`).join('')}</dd></div>
				</dl>
				${project.href ? `<a class="tip-enter" href="${project.href}">${ui.enter}</a>` : `<span class="tip-enter is-disabled">${ui.locked}</span>`}
			`;
			tip.classList.add('has-project');
		};

		const showLevelPreview = (mesh) => {
			if (!mesh) {
				return;
			}
			hovered = mesh;
			const { project } = mesh.userData;
			updateHoverPreview(project);
			updateTip(project, mesh === selected);
			updateActivePath(mesh.userData.index);
			positionFloatingTip(mesh);
			animatePlayerMarkerTo(mesh);
		};

		const restoreSelectedPreview = (mesh) => {
			if (hovered === mesh) {
				hovered = selected;
			}
			if (selected) {
				updateHoverPreview(selected.userData.project);
				updateTip(selected.userData.project, true);
				updateActivePath(selected.userData.index);
				positionFloatingTip(selected);
				animatePlayerMarkerTo(selected);
				return;
			}
			showDefaultInfo();
			updateActivePath(0);
			floatingTip.classList.remove('is-visible', 'is-left', 'is-above');
			animatePlayerMarkerTo(levelMeshes[0]);
		};

		const updateActivePath = (activeIndex) => {
			activePathToken += 1;
			const token = activePathToken;
			pathSegments.forEach(({ dots }, segmentIndex) => {
				const isActive = segmentIndex < activeIndex;
				dots.forEach((dot, dotIndex) => {
					dot.userData.active = false;
					dot.material.color.set(0xd6c6f5);
					dot.material.opacity = 0.42;
					if (isActive) {
						window.setTimeout(() => {
							if (token !== activePathToken) {
								return;
							}
							dot.userData.active = true;
							dot.material.color.set(segmentIndex % 2 === 0 ? 0xf4a6bd : 0xa8d870);
							dot.material.opacity = 0.95;
						}, prefersReducedMotion ? 0 : segmentIndex * 130 + dotIndex * 18);
					}
				});
			});
		};

		const selectLevel = (mesh) => {
			if (!mesh) {
				return;
			}
			selected = mesh;
			hovered = mesh;
			const { project, index } = mesh.userData;
			updateHoverPreview(project);
			updateTip(project, true);
			updateActivePath(index);
			positionFloatingTip(mesh);
			animatePlayerMarkerTo(mesh);
			hotspotButtons.forEach((button, buttonIndex) => {
				button.classList.toggle('is-selected', buttonIndex === index);
			});
		};

		const positionFloatingTip = (mesh) => {
			const projected = mesh.position.clone().project(camera);
			const rect = canvas.getBoundingClientRect();
			const mapRect = canvas.parentElement?.getBoundingClientRect() ?? rect;
			const x = ((projected.x + 1) / 2) * rect.width + rect.left - mapRect.left;
			const y = ((-projected.y + 1) / 2) * rect.height + rect.top - mapRect.top;

			const placeLeft = x > rect.width * 0.58;
			const tooltipHeight = floatingTip.offsetHeight || 360;
			const placeAbove = y > tooltipHeight + 34;
			floatingTip.style.left = `${x}px`;
			floatingTip.style.top = `${y}px`;
			floatingTip.classList.toggle('is-left', placeLeft);
			floatingTip.classList.toggle('is-above', placeAbove);
		};

		const positionPlayerMarkerAtWorld = (worldPosition = playerMarkerWorldPosition) => {
			const projected = worldPosition.clone().project(camera);
			const rect = canvas.getBoundingClientRect();
			const x = ((projected.x + 1) / 2) * rect.width;
			const y = ((-projected.y + 1) / 2) * rect.height;
			playerMarker.style.left = `${x}px`;
			playerMarker.style.top = `${y}px`;
		};

		const positionPlayerMarker = (mesh = selected ?? levelMeshes[0]) => {
			if (!mesh || playerMarkerAnimation) {
				return;
			}
			playerMarkerWorldPosition.set(mesh.position.x, mesh.position.y, 0);
			positionPlayerMarkerAtWorld();
			playerMarker.classList.toggle('is-moving', mesh !== levelMeshes[0] || Boolean(selected));
		};

		const getRoutePoints = (fromIndex, toIndex) => {
			if (fromIndex === toIndex) {
				return [new THREE.Vector3(projects[toIndex].position[0], projects[toIndex].position[1], 0)];
			}

			const route = [];
			const direction = toIndex > fromIndex ? 1 : -1;
			for (let index = fromIndex; index !== toIndex; index += direction) {
				const segmentIndex = direction > 0 ? index : index - 1;
				const segment = pathSegments[segmentIndex];
				if (!segment) {
					continue;
				}
				const steps = 18;
				for (let step = 0; step <= steps; step += 1) {
					const t = direction > 0 ? step / steps : 1 - step / steps;
					const point = segment.curve.getPoint(t);
					route.push(new THREE.Vector3(point.x, point.y, 0));
				}
			}
			return route;
		};

		const animatePlayerMarkerTo = (mesh) => {
			if (!mesh) {
				return;
			}
			const targetIndex = mesh.userData.index;
			if (targetIndex === playerMarkerTargetIndex && !playerMarkerAnimation) {
				positionPlayerMarker(mesh);
				return;
			}

			const routePoints = getRoutePoints(playerMarkerTargetIndex, targetIndex);
			if (routePoints.length < 2 || prefersReducedMotion) {
				playerMarkerTargetIndex = targetIndex;
				playerMarkerAnimation = null;
				playerMarkerWorldPosition.set(mesh.position.x, mesh.position.y, 0);
				positionPlayerMarkerAtWorld();
				return;
			}

			playerMarkerTargetIndex = targetIndex;
			playerMarkerAnimation = {
				points: routePoints,
				start: performance.now(),
				duration: Math.min(1150, Math.max(520, routePoints.length * 18)),
			};
			playerMarker.classList.add('is-moving');
		};

		const updatePointer = (event) => {
			const rect = canvas.getBoundingClientRect();
			pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
			pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
			if (!prefersReducedMotion) {
				parallaxX = pointer.x * 0.16;
				parallaxY = pointer.y * 0.1;
			}
		};

		const positionHotspots = () => {
			const rect = canvas.getBoundingClientRect();
			levelMeshes.forEach((mesh, index) => {
				const button = hotspotButtons[index];
				if (!button) {
					return;
				}
				const projected = mesh.position.clone().project(camera);
				const x = ((projected.x + 1) / 2) * rect.width;
				const y = ((-projected.y + 1) / 2) * rect.height;
				button.style.left = `${x}px`;
				button.style.top = `${y}px`;
				button.classList.toggle('is-active', mesh === hovered || mesh === selected);
			});
		};

		const resetPreview = () => {
			window.clearTimeout(closeTimer);
			pointer.set(-10, -10);
			hovered = null;
			selected = null;
			hoveringHotspot = false;
			canvas.style.cursor = 'default';
			showDefaultInfo();
			hotspotButtons.forEach((button) => button.classList.remove('is-active'));
			hotspotButtons.forEach((button) => button.classList.remove('is-selected'));
			updateActivePath(0);
			animatePlayerMarkerTo(levelMeshes[0]);
			floatingTip.classList.remove('is-visible', 'is-left', 'is-above');
		};

		const cancelClose = () => {
			window.clearTimeout(closeTimer);
		};

		const scheduleClose = () => {
			if (selected) {
				return;
			}
			window.clearTimeout(closeTimer);
			closeTimer = window.setTimeout(resetPreview, 850);
		};

		canvas.addEventListener('pointermove', (event) => {
			cancelClose();
			updatePointer(event);
			if (isDraggingMap) {
				const dx = (event.clientX - dragStartX) / Math.max(canvas.clientWidth, 1);
				const dy = (event.clientY - dragStartY) / Math.max(canvas.clientHeight, 1);
				mapOffsetX = Math.max(-0.65, Math.min(0.65, dragStartOffsetX - dx * 2.2));
				mapOffsetY = Math.max(-0.42, Math.min(0.42, dragStartOffsetY + dy * 1.4));
				didDragMap = Math.abs(event.clientX - dragStartX) > 4 || Math.abs(event.clientY - dragStartY) > 4;
				canvas.classList.add('is-grabbing');
			}
		});

		canvas.addEventListener('pointerdown', (event) => {
			isDraggingMap = true;
			didDragMap = false;
			dragStartX = event.clientX;
			dragStartY = event.clientY;
			dragStartOffsetX = mapOffsetX;
			dragStartOffsetY = mapOffsetY;
			canvas.classList.add('is-grabbing');
		});

		window.addEventListener('pointerup', () => {
			isDraggingMap = false;
			canvas.classList.remove('is-grabbing');
		});

		floatingTip.addEventListener('pointerenter', cancelClose);
		floatingTip.addEventListener('pointermove', cancelClose);
		floatingTip.addEventListener('pointerleave', scheduleClose);

		window.addEventListener('pointermove', (event) => {
			const rect = canvas.getBoundingClientRect();
			const tipRect = floatingTip.getBoundingClientRect();
			const tipReach = floatingTip.classList.contains('is-visible') ? 72 : 0;
			const isOutsideCanvas =
				event.clientX < rect.left ||
				event.clientX > rect.right ||
				event.clientY < rect.top ||
				event.clientY > rect.bottom;
			const isOutsideFloatingTip =
				event.clientX < tipRect.left - tipReach ||
				event.clientX > tipRect.right + tipReach ||
				event.clientY < tipRect.top - tipReach ||
				event.clientY > tipRect.bottom + tipReach;
			let isOverLevel = false;

			if (!isOutsideCanvas) {
				updatePointer(event);
				raycaster.setFromCamera(pointer, camera);
				isOverLevel = raycaster.intersectObjects(levelMeshes).length > 0;
			}

			if (
				isOutsideCanvas &&
				isOutsideFloatingTip &&
				selected &&
				hovered &&
				hovered !== selected &&
				!hoveringHotspot
			) {
				restoreSelectedPreview(hovered);
			} else if (isOutsideFloatingTip && !isOverLevel && hovered && hovered !== selected) {
				scheduleClose();
			} else if (hovered) {
				cancelClose();
			}
		});

		canvas.addEventListener('click', (event) => {
			if (didDragMap) {
				didDragMap = false;
				return;
			}
			updatePointer(event);
			raycaster.setFromCamera(pointer, camera);
			const clickedLevel = raycaster.intersectObjects(levelMeshes)[0]?.object ?? hovered;
			const project = clickedLevel?.userData.project;
			if (project) {
				selectLevel(clickedLevel);
				if (project.href) {
					window.location.href = project.href;
				}
			}
		});

		const setZoom = (nextZoom) => {
			camera.zoom = Math.max(0.9, Math.min(1.15, nextZoom));
			camera.updateProjectionMatrix();
		};

		zoomInButton?.addEventListener('click', () => setZoom(camera.zoom + 0.06));
		zoomOutButton?.addEventListener('click', () => setZoom(camera.zoom - 0.06));
		resetMapButton?.addEventListener('click', () => {
			mapOffsetX = 0;
			mapOffsetY = 0;
			setZoom(1);
			positionPlayerMarker(selected ?? levelMeshes[0]);
		});

		window.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				resetPreview();
			}
		});

		const render = () => {
			const rect = canvas.getBoundingClientRect();
			if (
				Math.abs(rect.width - lastCanvasWidth) > 1 ||
				Math.abs(rect.height - lastCanvasHeight) > 1
			) {
				resize();
			}

			const elapsed = clock.getElapsedTime();
			if (!prefersReducedMotion) {
				camera.position.x += (mapOffsetX + parallaxX - camera.position.x) * 0.035;
				camera.position.y += (mapOffsetY + parallaxY - camera.position.y) * 0.035;
				clouds.forEach((cloud, index) => {
					cloud.position.x += Math.sin(elapsed * cloud.userData.drift + index) * 0.0018;
					cloud.position.y += Math.cos(elapsed * cloud.userData.drift + index) * 0.0012;
				});
				sparkles.forEach((sparkle, index) => {
					const sparklePulse = 0.82 + Math.sin(elapsed * 1.6 + index) * 0.16;
					sparkle.scale.setScalar(sparklePulse);
				});
			}
			raycaster.setFromCamera(pointer, camera);
			const hits = raycaster.intersectObjects(levelMeshes);
			const nextHovered = hits[0]?.object ?? null;

			if (nextHovered && nextHovered !== hovered) {
				cancelClose();
				canvas.style.cursor = 'pointer';
				showLevelPreview(nextHovered);
			} else if (!nextHovered) {
				canvas.style.cursor = isDraggingMap ? 'grabbing' : 'grab';
				if (!hovered && !selected && !hoveringHotspot) {
					// panel is hidden — nothing to update
				}
			}

			levelMeshes.forEach((mesh, index) => {
				const isHovered = mesh === hovered;
				const isSelected = mesh === selected;
				const pulse = prefersReducedMotion ? 0 : Math.sin(elapsed * 3 + index) * 0.04;
				const scale = isSelected ? 1.28 + pulse : isHovered ? 1.17 + pulse : 1 + pulse;
				mesh.scale.setScalar(scale);

				if (flagSprites[index]) {
					const flagScale = isSelected ? 1.32 + pulse : isHovered ? 1.2 + pulse : 1.08 + pulse * 0.35;
					flagSprites[index].scale.set(flagScale, flagScale, 1);
					flagSprites[index].position.y =
						mesh.userData.project.position[1] + 0.58 + ((isHovered || isSelected) && !prefersReducedMotion ? 0.12 : 0);
				}
			});

			if (playerMarkerAnimation) {
				const progress = Math.min(1, (performance.now() - playerMarkerAnimation.start) / playerMarkerAnimation.duration);
				const eased = 1 - Math.pow(1 - progress, 3);
				const pointIndex = Math.min(
					playerMarkerAnimation.points.length - 1,
					Math.floor(eased * (playerMarkerAnimation.points.length - 1))
				);
				playerMarkerWorldPosition.copy(playerMarkerAnimation.points[pointIndex]);
				positionPlayerMarkerAtWorld();
				if (progress >= 1) {
					playerMarkerAnimation = null;
				}
			}

			pathSegments.forEach(({ dots }, segmentIndex) => {
				dots.forEach((dot, dotIndex) => {
					const pulse = dot.userData.active && !prefersReducedMotion
						? 1 + Math.sin(elapsed * 4 + dotIndex * 0.35 + segmentIndex) * 0.18
						: 1;
					dot.scale.setScalar(dot.userData.active ? pulse : 1);
				});
			});

			if (hovered || selected) {
				positionFloatingTip(hovered ?? selected);
			}
			positionHotspots();
			positionPlayerMarker(hovered ?? selected ?? levelMeshes[0]);

			renderer.render(scene, camera);
			requestAnimationFrame(render);
		};

		document.addEventListener('langchange', (e: Event) => {
			const l = (e as CustomEvent).detail.lang;
			buildFallbackGrid();
			levelMeshes.forEach((mesh, i) => {
				Object.assign(mesh.userData.project, getProjectData(i));
			});
			const ui = getUI();
			if (selected) {
				const proj = selected.userData.project;
				updateHoverPreview(proj);
				updateTip(proj, true);
			} else if (hovered) {
				updateHoverPreview(hovered.userData.project);
				if (floatingTip instanceof HTMLElement && floatingTip.classList.contains('is-visible')) {
					updateTip(hovered.userData.project, false);
				}
			} else {
				showDefaultInfo();
			}
			hotspotButtons.forEach((btn, i) => {
				const proj = getProjectData(i);
				btn.setAttribute('aria-label', `${proj.level}: ${proj.title}`);
				const strong = btn.querySelector('strong');
				if (strong) strong.textContent = proj.title;
			});
		});

		showDefaultInfo();
		window.addEventListener('resize', resize);
		new ResizeObserver(resize).observe(canvas);
		requestAnimationFrame(resize);
		resize();
		render();
	}
</script>

<style is:global>
