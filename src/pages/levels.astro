		color: inherit;
		text-decoration: none;
	}

	.levels-screen {
		min-height: 100svh;
		padding: clamp(92px, 12vh, 124px) clamp(20px, 5vw, 70px) 42px;
		background: #f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.levels-header {
		display: flex;
		align-items: center;
		gap: 18px;
		width: min(100%, 1180px);
		margin: 0 auto;
		padding-left: clamp(44px, 5vw, 72px);
	}

	.screen-icon {
		display: grid;
		place-items: center;
		width: 82px;
