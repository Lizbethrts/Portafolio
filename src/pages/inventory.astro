---
import Layout from '../layouts/Layout.astro';

const metadata = [
	['CLASS', 'UX/UI Designer'],
	['BACKGROUND', 'Animation & Video Games'],
	['SPECIALTY', 'Interactive Design'],
];

const equippedTools = [
	{
		name: 'Figma',
		icon: 'Fi',
		description: 'Wireframes, prototypes, user flows, and interface design.',
	},
	{
		name: 'React',
		icon: 'Rx',
		description: 'Interactive web interfaces and component-based development.',
	},
	{
		name: 'Next.js',
		icon: 'Nx',
		description: 'Web experiences, landing pages, and scalable frontend projects.',
	},
	{
		name: 'TypeScript',
		icon: 'Ts',
		description: 'Structured, maintainable, and scalable code.',
	},
	{
		name: 'Unity',
		icon: 'Un',
		description: 'Interactive experiences, gameplay systems, and immersive prototypes.',
	},
	{
		name: 'SwiftUI',
		icon: 'Sw',
		description: 'Mobile app interfaces and iOS product experiences.',
	},
];

const skillBranches = [
	{
		name: 'UX/UI Design',
		description: 'Designing clear, accessible, and enjoyable interfaces.',
		accent: 'pink',
		nodes: ['Wireframing', 'Prototyping', 'User Flows', 'Interface Design', 'User Testing', 'Interaction Design'],
	},
	{
		name: 'Frontend Development',
		description: 'Building digital interfaces with technical understanding.',
		accent: 'blue',
		nodes: ['React', 'Next.js', 'TypeScript', 'Responsive Layouts', 'Landing Pages', 'Design-to-Code Translation'],
	},
	{
		name: 'Interactive Experiences',
		description: 'Creating digital moments that respond, move, and feel alive.',
		accent: 'yellow',
		nodes: ['Interactive Prototyping', 'Microinteractions', 'Motion Thinking', 'Experience Design', 'Playful Interfaces'],
	},
	{
		name: 'Game & Immersive Design',
		description: 'Using game logic, interaction, and storytelling to create engaging experiences.',
		accent: 'green',
		nodes: ['Unity', 'C#', 'Gameplay Systems', 'Object Interaction', 'Physics-Based Experiences', 'VR / Haptic Experiences'],
	},
	{
		name: 'Research & Strategy',
		description: 'Understanding users, competitors, and context before designing solutions.',
		accent: 'lavender',
		nodes: ['User Research', 'Benchmarking', 'Problem Framing', 'Journey Thinking', 'Usability Improvements', 'Iterative Design'],
	},
];

const passiveAbilities = [
	['User-Centered Thinking', '+ User Empathy'],
	['Clear Communication', '+ Clear Communication'],
	['Multidisciplinary Collaboration', '+ Team Sync'],
	['Analytical Thinking', '+ Analytical Vision'],
	['Problem Solving', '+ Problem Solver Mode'],
];

const specialItems = [
	{
		name: 'Validated Prototype',
		icon: 'VP',
		description: 'Experience creating functional prototypes and improving them through user testing.',
	},
	{
		name: 'Usability Upgrade',
		icon: 'UX',
		description: 'Experience improving usability through design iterations.',
	},
	{
		name: 'UX + Code Bridge',
		icon: 'CB',
		description: 'Ability to connect design decisions with technical feasibility.',
	},
	{
		name: 'Swift Associate Badge',
		icon: 'SA',
		description: 'App Development with Swift Associate certification.',
	},
	{
		name: 'Unity Essentials Badge',
		icon: 'UE',
		description: 'Unity Essentials Pathway certification.',
	},
	{
		name: 'Interactive Design Scroll',
		icon: 'ID',
		description: 'Current specialization in Interactive Design.',
	},
];

const experienceSlots = [
	{
		role: 'UX/UI Designer',
		label: 'Design Class',
		description: 'Wireframes, user flows, prototypes, user testing, and iterative interface improvements.',
	},
	{
		role: 'Frontend Developer',
		label: 'Build Class',
		description: 'Web interfaces and landing pages built with React, Next.js, and TypeScript.',
	},
	{
		role: 'Gameplay Developer',
		label: 'Interaction Class',
		description: 'Interactive experiences and gameplay systems built in Unity.',
	},
];
---

<Layout title="Inventory | Lizzy World">
	<main class="inventory-screen" aria-labelledby="inventory-title">
		<a class="back-link" href="/" aria-label="Back to Lizzy World menu">Back</a>

		<header class="inventory-hero">
			<div class="inventory-icon" aria-hidden="true">
				<img src="/img/menu/4.png" alt="" width="46" height="46" />
			</div>
			<div class="hero-copy">
				<p class="pixel-kicker">Inventory</p>
				<h1 id="inventory-title">Inventory</h1>
				<p class="hero-subtitle">Equipped skills &amp; tools</p>
				<p>
					A collection of tools, skills, and special items I use to design, prototype,
					and build interactive digital experiences.
				</p>
			</div>
			<dl class="metadata-panel" aria-label="Player metadata">
				{metadata.map(([label, value]) => (
					<div>
						<dt>{label}</dt>
						<dd>{value}</dd>
					</div>
				))}
			</dl>
		</header>

		<section class="inventory-section" aria-labelledby="equipped-tools-title">
			<div class="section-heading">
				<p class="pixel-kicker">Loadout</p>
				<h2 id="equipped-tools-title">Equipped Tools</h2>
				<p>My main tools for designing, prototyping, and building digital products.</p>
			</div>

			<div class="tool-grid">
				{equippedTools.map((tool) => (
					<article class="inventory-card tool-card">
						<div class="item-slot" aria-hidden="true">{tool.icon}</div>
						<div>
							<span class="status-label">equipped</span>
							<h3>{tool.name}</h3>
							<p>{tool.description}</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="inventory-section skill-tree-section" aria-labelledby="skill-tree-title">
			<div class="section-heading">
				<p class="pixel-kicker">Ability Path</p>
				<h2 id="skill-tree-title">Skill Tree</h2>
				<p>How my abilities connect.</p>
			</div>

			<div class="skill-tree-grid">
				<div class="skill-tree-core">
					<span>Core Build</span>
					<strong>Interactive Digital Experiences</strong>
				</div>
				{skillBranches.map((branch) => (
					<article class:list={['skill-branch', `skill-branch-${branch.accent}`]}>
						<div class="branch-copy">
							<h3>{branch.name}</h3>
							<p>{branch.description}</p>
						</div>
						<ul class="branch-nodes" aria-label={`${branch.name} nodes`}>
							{branch.nodes.map((node) => <li>{node}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="inventory-section panel-card passive-panel" aria-labelledby="passive-abilities-title">
			<div class="section-heading">
				<p class="pixel-kicker">Always Active</p>
				<h2 id="passive-abilities-title">Passive Abilities</h2>
				<p>Soft skills that support the way I collaborate, solve problems, and design with users in mind.</p>
			</div>

			<div class="passive-list">
				{passiveAbilities.map(([ability, bonus]) => (
					<article>
						<span>{bonus}</span>
						<h3>{ability}</h3>
					</article>
				))}
			</div>
		</section>

		<section class="inventory-section" aria-labelledby="special-items-title">
			<div class="section-heading">
				<p class="pixel-kicker">Collected</p>
				<h2 id="special-items-title">Special Items</h2>
				<p>Achievements, certifications, and experience-based items collected along the way.</p>
			</div>

			<div class="special-row">
				{specialItems.map((item) => (
					<article class="inventory-card special-card">
						<div class="item-slot item-slot-small" aria-hidden="true">{item.icon}</div>
						<span class="status-label">special</span>
						<h3>{item.name}</h3>
						<p>{item.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="inventory-section" aria-labelledby="experience-slots-title">
			<div class="section-heading">
				<p class="pixel-kicker">Roles</p>
				<h2 id="experience-slots-title">Experience Slots</h2>
			</div>

			<div class="experience-grid">
				{experienceSlots.map((slot) => (
					<article class="experience-card">
						<span class="status-label">{slot.label}</span>
						<h3>{slot.role}</h3>
						<p>{slot.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="resume-scroll" aria-labelledby="resume-scroll-title">
			<div>
				<p class="pixel-kicker">Resume Scroll</p>
				<h2 id="resume-scroll-title">Want the full inventory?</h2>
			</div>
			<div class="cta-actions">
				<a
					class="primary-button"
					href="/resume.pdf"
					download="Lizbeth-Trujillo-CV.pdf"
					aria-label="Download resume PDF"
				>
					View Resume
				</a>
				<a class="secondary-button" href="/levels" aria-label="Back to levels map">Back to Map</a>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Pixelify+Sans:wght@400..700&display=swap');

	body {
		overflow-x: hidden;
		background: #f4f4de;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.inventory-screen {
		min-height: 100svh;
		padding: clamp(84px, 10vh, 112px) clamp(18px, 5vw, 70px) 54px;
		background:
			linear-gradient(180deg, rgba(255, 247, 241, 0.7), rgba(244, 244, 222, 0.96)),
			#f4f4de;
		color: #4a403a;
		font-family: 'Comfortaa', 'Trebuchet MS', sans-serif;
	}

	.back-link {
		position: fixed;
		top: 24px;
		left: 24px;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 92px;
		min-height: 34px;
		border-radius: 12px;
		background: #f4a6bd;
		color: #4a403a;
		font-size: 0.78rem;
		font-weight: 700;
	}

	.inventory-hero,
	.inventory-section,
	.dual-panel-grid,
	.resume-scroll {
		width: min(100%, 1180px);
		margin-inline: auto;
	}

	.inventory-hero {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: clamp(18px, 3vw, 34px);
		align-items: center;
		margin-bottom: 34px;
	}

	.hero-copy {
		min-width: 0;
	}

	.inventory-icon {
		display: grid;
		place-items: center;
		width: 82px;
		aspect-ratio: 1;
		border: 4px solid #d6c6f5;
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 12px 26px rgba(214, 198, 245, 0.2);
	}

	.inventory-icon img {
		image-rendering: pixelated;
	}

	.hero-copy h1,
	.section-heading h2,
	.resume-scroll h2 {
		margin: 0;
		color: #b8977a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		line-height: 0.95;
	}

	.hero-copy h1 {
		font-size: clamp(3.4rem, 8vw, 6.8rem);
	}

	.hero-subtitle {
		margin: 8px 0 0 !important;
		color: #4a403a !important;
		font-size: clamp(1.1rem, 2vw, 1.35rem) !important;
		font-weight: 800;
	}

	.hero-copy p:not(.pixel-kicker):not(.hero-subtitle),
	.section-heading p:not(.pixel-kicker),
	.resume-scroll p:not(.pixel-kicker) {
		max-width: 720px;
		margin: 14px 0 0;
		color: #6b625d;
		font-size: 0.98rem;
		line-height: 1.75;
	}

	.pixel-kicker {
		margin: 0 0 8px;
		color: #f4a6bd;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 0.94rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.metadata-panel {
		display: grid;
		grid-column: 1 / -1;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 10px;
		width: min(100%, 920px);
		margin: 18px 0 0;
		border: 5px solid #d6c6f5;
		border-radius: 26px;
		background: #ffffff;
		box-shadow: 0 18px 38px rgba(214, 198, 245, 0.18);
		padding: 18px;
		justify-self: start;
	}

	.metadata-panel div {
		display: grid;
		gap: 4px;
		border-radius: 16px;
		background: #fff7f1;
		padding: 12px;
	}

	.metadata-panel dt {
		color: #7b716c;
		font-size: 0.68rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.metadata-panel dd {
		margin: 0;
		color: #4a403a;
		font-size: 0.88rem;
		font-weight: 800;
		line-height: 1.4;
	}

	.inventory-section {
		margin-top: 28px;
	}

	.section-heading {
		margin-bottom: 16px;
	}

	.section-heading h2,
	.resume-scroll h2 {
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.tool-grid,
	.experience-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.inventory-card,
	.panel-card,
	.experience-card,
	.resume-scroll {
		border: 2px solid #d6c6f5;
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 12px 30px rgba(214, 198, 245, 0.18);
	}

	.inventory-card,
	.experience-card {
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.inventory-card:hover,
	.experience-card:hover {
		box-shadow: 0 18px 36px rgba(214, 198, 245, 0.26);
		transform: translateY(-3px);
	}

	.tool-card {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 16px;
		align-items: start;
		padding: 20px;
	}

	.item-slot {
		display: grid;
		place-items: center;
		width: 58px;
		aspect-ratio: 1;
		border: 3px solid #f9e4e8;
		border-radius: 16px;
		background:
			linear-gradient(135deg, rgba(249, 231, 163, 0.48), rgba(191, 215, 237, 0.36)),
			#fff7f1;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: 1.2rem;
		font-weight: 800;
	}

	.item-slot-small {
		width: 50px;
		margin-bottom: 12px;
	}

	.status-label,
	.skill-chip-grid span {
		display: inline-flex;
		width: fit-content;
		border-radius: 999px;
		background: #f9e4e8;
		color: #4a403a;
		font-size: 0.68rem;
		font-weight: 800;
		line-height: 1;
		padding: 7px 10px;
		text-transform: uppercase;
	}

	.inventory-card h3,
	.experience-card h3,
	.passive-list h3 {
		margin: 10px 0 8px;
		color: #4a403a;
		font-size: 1rem;
		line-height: 1.35;
	}

	.inventory-card p,
	.experience-card p {
		margin: 0;
		color: #6b625d;
		font-size: 0.88rem;
		line-height: 1.65;
	}

	.dual-panel-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
		gap: 20px;
		margin-top: 28px;
	}

	.panel-card {
		padding: 22px;
	}

	.dual-panel-grid .inventory-section {
		width: auto;
		margin-top: 0;
	}

	.skill-tree-section {
		border: 2px solid #d6c6f5;
		border-radius: 28px;
		background:
			radial-gradient(circle at 8% 18%, rgba(249, 228, 232, 0.32) 0 8%, rgba(249, 228, 232, 0.1) 14%, transparent 24%),
			radial-gradient(circle at 92% 12%, rgba(191, 215, 237, 0.28) 0 8%, rgba(191, 215, 237, 0.1) 14%, transparent 24%),
			#ffffff;
		box-shadow: 0 12px 30px rgba(214, 198, 245, 0.18);
		padding: clamp(20px, 4vw, 28px);
	}

	.skill-tree-grid {
		position: relative;
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 22px 18px;
		padding-top: 12px;
	}

	.skill-tree-grid::before {
		content: "";
		position: absolute;
		top: 86px;
		left: 10%;
		right: 10%;
		border-top: 3px dotted rgba(214, 198, 245, 0.88);
	}

	.skill-tree-core {
		position: relative;
		z-index: 2;
		display: grid;
		justify-items: center;
		gap: 8px;
		grid-column: 2 / span 4;
		border: 3px solid #d6c6f5;
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 14px 28px rgba(214, 198, 245, 0.18);
		padding: 18px;
		text-align: center;
	}

	.skill-tree-core::after {
		content: "";
		position: absolute;
		bottom: -28px;
		left: 50%;
		height: 28px;
		border-left: 3px dotted rgba(214, 198, 245, 0.88);
	}

	.skill-tree-core span {
		border-radius: 999px;
		background: #f9e4e8;
		color: #4a403a;
		font-size: 0.7rem;
		font-weight: 800;
		padding: 7px 11px;
		text-transform: uppercase;
	}

	.skill-tree-core strong {
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.5rem, 3vw, 2.15rem);
		line-height: 1;
	}

	.skill-branch {
		position: relative;
		display: grid;
		align-content: start;
		gap: 12px;
		border: 2px solid rgba(214, 198, 245, 0.88);
		border-radius: 22px;
		background: rgba(255, 247, 241, 0.76);
		padding: 18px;
		transition:
			box-shadow 180ms ease,
			transform 180ms ease,
			border-color 180ms ease;
	}

	.skill-branch:nth-child(2),
	.skill-branch:nth-child(3) {
		grid-column: span 3;
	}

	.skill-branch:nth-child(n + 4) {
		grid-column: span 2;
	}

	.skill-branch::before {
		content: "";
		position: absolute;
		top: -24px;
		left: 50%;
		height: 24px;
		border-left: 3px dotted rgba(214, 198, 245, 0.88);
	}

	.skill-branch:hover {
		border-color: #f4a6bd;
		box-shadow: 0 18px 36px rgba(214, 198, 245, 0.26);
		transform: translateY(-3px);
	}

	.branch-copy {
		position: relative;
		z-index: 1;
	}

	.branch-copy h3 {
		margin: 0 0 8px;
		color: #4a403a;
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.35rem, 2.3vw, 1.8rem);
		line-height: 1;
	}

	.branch-copy p {
		margin: 0;
		color: #6b625d;
		font-size: 0.86rem;
		line-height: 1.6;
	}

	.branch-nodes {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.branch-nodes li {
		position: relative;
		border: 1px solid rgba(214, 198, 245, 0.9);
		border-radius: 14px;
		background: #ffffff;
		color: #4a403a;
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1.25;
		padding: 8px 10px;
		transition:
			background 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.branch-nodes li::before {
		content: "";
		position: absolute;
		top: 50%;
		left: -5px;
		width: 7px;
		aspect-ratio: 1;
		border-radius: 50%;
		background: #d6c6f5;
		transform: translateY(-50%);
	}

	.branch-nodes li:hover {
		background: #fff0d6;
		box-shadow: 0 8px 18px rgba(244, 166, 189, 0.18);
		transform: translateY(-2px);
	}

	.passive-panel {
		width: min(100%, 1180px);
		margin-inline: auto;
	}

	.skill-chip-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.skill-chip-grid li {
		display: grid;
		gap: 8px;
		border: 2px solid rgba(191, 215, 237, 0.75);
		border-radius: 18px;
		background: #fff7f1;
		padding: 14px;
	}

	.skill-chip-grid strong {
		color: #4a403a;
		font-size: 0.9rem;
		line-height: 1.35;
	}

	.passive-list {
		display: grid;
		gap: 10px;
	}

	.passive-list article {
		border-left: 5px solid #a8d870;
		border-radius: 16px;
		background: #fbfff5;
		padding: 14px 16px;
	}

	.passive-list span {
		color: #7b716c;
		font-size: 0.78rem;
		font-weight: 800;
	}

	.passive-list h3 {
		margin-bottom: 0;
	}

	.special-row {
		display: grid;
		grid-template-columns: repeat(6, minmax(190px, 1fr));
		gap: 14px;
		overflow-x: auto;
		padding: 4px 4px 16px;
		scroll-snap-type: x mandatory;
	}

	.special-card {
		min-height: 250px;
		padding: 18px;
		scroll-snap-align: start;
	}

	.experience-card {
		padding: 22px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 247, 241, 0.86)),
			#ffffff;
	}

	.experience-card h3 {
		font-family: 'Pixelify Sans', 'Courier New', monospace;
		font-size: clamp(1.55rem, 2.5vw, 2rem);
		line-height: 1;
	}

	.resume-scroll {
